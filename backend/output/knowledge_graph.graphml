  <data key="d2">1</data>
</node>
<node id="HAVING A CHILD">
  <data key="d0">EVENT</data>
  <data key="d1">A significant life event that involves various expenses and requires financial planning.</data>
  <data key="d2">1</data>
</node>
<node id="BIRTH OR ADOPTION">
  <data key="d0">EVENT</data>
  <data key="d1">A life event involving the arrival of a child into a family, which requires financial planning.</data>
  <data key="d2">1</data>
</node>
<node id="TOOLS FOR WORK">
  <data key="d0">EVENT</data>
  <data key="d1">The act of acquiring significant tools needed for work, classified as a large purchase event.</data>
  <data key="d2">1</data>
</node>
<node id="BIRTHDAY OR RITE OF PASSAGE">
