  <data key="d0">ACTION</data>
  <data key="d1">Legal actions or proceedings initiated in a court, which can be filed by creditors or debt collectors for unpaid debts.</data>
  <data key="d2">1</data>
</node>
<node id="FRIENDS AND FAMILY">
  <data key="d0">PERSON</data>
  <data key="d1">Individuals who may lend money to others, becoming informal creditors.</data>
  <data key="d2">1</data>
</node>
<node id="COURT-ORDERED DEBT">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">Financial obligations that are legally mandated to be paid as a result of a court decision or order.</data>
  <data key="d2">1</data>
</node>
<node id="BANK ACCOUNT NUMBER">
  <data key="d0">RISK</data>
  <data key="d1">A unique identifier for a financial account at a bank, considered sensitive information that should not be shared with debt collectors due to potential risks of fraud.</data>
  <data key="d2">1</data>
</node>
<node id="DEBT SETTLEMENT COMPANY">
  <data key="d0">ORGANIZATION</data>
  <data key="d1">A company that negotiates with creditors on behalf of debtors to reduce the total amount of debt owed, often charging fees for their services.</data>
  <data key="d2">1</data>
</node>
<node id="NONPROFIT CREDIT COUNSELOR">
  <data key="d0">ORGANIZATION</data>
  <data key="d1">A non-profit organization or individual professional offering advice on managing money and debts, usually for a low or no fee, as an alternative to debt settlement companies.</data>
  <data key="d2">1</data>
</node>
<node id="HOMEOWNER'S HOPE HOTLINE">
  <data key="d0">ORGANIZATION</data>
  <data key="d1">A national hotline (888.995.HOPE) providing assistance and counseling services to homeowners at risk of foreclosure.</data>
  <data key="d2">1</data>
</node>
<node id="LEGAL AID">
  <data key="d0">ORGANIZATION</data>
  <data key="d1">An organization providing free or low-cost legal services to individuals who cannot afford an attorney, especially for those who qualify based on income and location.</data>
  <data key="d2">3</data>
</node>
<node id="STATE’S LEGAL AID DIRECTORY">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">A resource, often an online listing, provided by a state to help individuals find legal aid services and information on free legal assistance.</data>
  <data key="d2">1</data>
</node>
<node id="NAAG">
  <data key="d0">ORGANIZATION</data>
  <data key="d1">The National Association of Attorneys General (naag.org), an organization that facilitates cooperation and information sharing among state attorneys general.</data>
  <data key="d2">1</data>
</node>
<node id="MEDICAID CENTER">
  <data key="d0">ORGANIZATION</data>
  <data key="d1">A state-level office or agency responsible for administering the Medicaid program, which provides health coverage to low-income individuals, and can be contacted for information.</data>
  <data key="d2">1</data>
</node>
<node id="MEDICAID.GOV">
  <data key="d0">ORGANIZATION</data>
  <data key="d1">The official website for the U.S. government's Medicaid program (medicaid.gov), providing information and contact details for state Medicaid centers.</data>
  <data key="d2">1</data>
</node>
<node id="PRESSURE FROM DEBT">
  <data key="d0">RISK</data>
  <data key="d1">The burden or strain that debt places on an individual's budget, affecting their ability to manage other expenses.</data>
  <data key="d2">1</data>
</node>
<node id="ABILITY TO GET ADDITIONAL CREDIT">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">An individual's capacity to qualify for and obtain new loans or credit, often impacted by their existing debt levels and financial ratios.</data>
  <data key="d2">1</data>
</node>
<node id="FREEING UP MONEY">
  <data key="d0">ACTION</data>
  <data key="d1">The act of reducing debt or expenses to make more income available for other purposes like saving or emergencies.</data>
  <data key="d2">1</data>
</node>
<node id="FINANCIAL PLANNING">
  <data key="d0">ACTION</data>
  <data key="d1">The process of managing one's financial resources to achieve financial goals, often involving tools like debt-to-income calculators.</data>
  <data key="d2">1</data>
</node>
<node id="RECOMMENDED RATIOS">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">Guideline percentages for debt-to-income ratios that are suggested for maintaining financial health or qualifying for loans.</data>
  <data key="d2">1</data>
</node>
<node id="DEBT-TO-INCOME RATIO GUIDELINES">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">Specific percentage ranges suggested for debt-to-income ratios (e.g., 36% or less for homeowners, 15-20% for renters) to indicate good financial health.</data>
  <data key="d2">1</data>
</node>
<node id="MORTGAGE PRINCIPAL AND INTEREST">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">The core components of a mortgage payment, representing the repayment of the borrowed amount (principal) and the cost of borrowing (interest).</data>
  <data key="d2">1</data>
</node>
<node id="MORTGAGE DEBT-TO-INCOME RATIO GUIDELINES">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">Specific percentage ranges suggested for mortgage debt-to-income ratios for homeowners (e.g., 28-35%) to indicate manageable housing debt.</data>
  <data key="d2">1</data>
</node>
<node id="DEBT REPAYMENT STRATEGY">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">A planned approach or method for systematically paying off debts, often involving prioritizing certain debts over others to achieve debt reduction goals.</data>
  <data key="d2">1</data>
</node>
<node id="ACHIEVING FINANCIAL GOALS">
  <data key="d0">ACTION</data>
  <data key="d1">The process of working towards and successfully attaining objectives related to personal finances, such as debt reduction or saving.</data>
  <data key="d2">1</data>
</node>
<node id="PAY MORE THAN MINIMUM">
  <data key="d0">ACTION</data>
  <data key="d1">The act of paying a larger amount than the required minimum payment on a debt, typically to accelerate debt reduction.</data>
  <data key="d2">1</data>
</node>
<node id="DEBT REPAYMENT STRATEGY (SMALLEST TO LARGEST)">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">A debt repayment method where an individual focuses on paying off the smallest debts first, regardless of interest rate, to build momentum.</data>
  <data key="d2">1</data>
</node>
<node id="DEBT REPAYMENT STRATEGY (HIGHEST INTEREST FIRST)">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">A debt repayment method where an individual prioritizes paying off debts with the highest interest rates first to minimize the total amount of interest paid.</data>
  <data key="d2">1</data>
</node>
<node id="LOWERING DEBT-TO-INCOME RATIO">
  <data key="d0">ACTION</data>
  <data key="d1">The specific action of decreasing the percentage of income that goes towards debt payments, typically achieved through debt reduction.</data>
  <data key="d2">1</data>
</node>
<node id="SUPPORT THEMSELVES FINANCIALLY">
  <data key="d0">ACTION</data>
  <data key="d1">The act of an individual providing for their own financial needs, a value often emphasized in Western cultures.</data>
  <data key="d2">1</data>
</node>
<node id="FAMILY">
  <data key="d0">ORGANIZATION</data>
  <data key="d1">Individuals who may receive money sent from the United States, mentioned as a common recipient of international transfers.</data>
  <data key="d2">2</data>
</node>
<node id="FINANCIAL MUTUAL SUPPORT">
  <data key="d0">ACTION</data>
  <data key="d1">The act of family or community members providing financial assistance to one another, common in certain cultures.</data>
  <data key="d2">1</data>
</node>
<node id="EXTRA INCOME">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">Money remaining after necessary expenses, which can be allocated based on cultural values or personal choices.</data>
  <data key="d2">1</data>
</node>
<node id="EXTENDED FAMILY">
  <data key="d0">ORGANIZATION</data>
  <data key="d1">A broader family unit beyond the immediate household, which may receive financial support in some cultures.</data>
  <data key="d2">1</data>
</node>
<node id="NEIGHBORS">
  <data key="d0">PERSON</data>
  <data key="d1">Individuals living near one another, who may be part of a community's financial support system.</data>
  <data key="d2">1</data>
</node>
<node id="CULTURAL INFLUENCES">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">The pervasive effects of cultural norms and values on an individual's financial perspectives and decision-making.</data>
  <data key="d2">1</data>
</node>
<node id="FAMILY CULTURE">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">The specific norms, values, and practices related to money within an individual's family unit.</data>
  <data key="d2">1</data>
</node>
<node id="BROADER COMMUNITY">
  <data key="d0">ORGANIZATION</data>
  <data key="d1">A wider social group that can influence individual financial values, such as valuing material possessions.</data>
  <data key="d2">1</data>
</node>
<node id="MATERIAL THINGS">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">Tangible possessions or goods that individuals may value and purchase, often influenced by cultural pressures.</data>
  <data key="d2">1</data>
</node>
<node id="NEW CARS">
  <data key="d0">FINANCIAL_PRODUCT</data>
  <data key="d1">Vehicles purchased new, representing a significant expenditure and sometimes a cultural status symbol.</data>
  <data key="d2">1</data>
</node>
<node id="EXPENSIVE CLOTHES">
  <data key="d0">FINANCIAL_PRODUCT</data>
  <data key="d1">High-cost garments, often purchased due to cultural or social pressures related to material possessions.</data>
  <data key="d2">1</data>
</node>
<node id="CARING FINANCIALLY FOR PARENTS">
  <data key="d0">ACTION</data>
  <data key="d1">Providing financial support to aging parents, a responsibility valued differently across cultures and families.</data>
  <data key="d2">1</data>
</node>
<node id="PARENTS">
  <data key="d0">PERSON</data>
  <data key="d1">Individuals who may receive financial care from their children, depending on cultural and family traditions.</data>
  <data key="d2">1</data>
</node>
<node id="FAMILY CIRCUMSTANCES">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">The specific conditions and situations within a family that influence financial expectations and responsibilities.</data>
  <data key="d2">1</data>
</node>
<node id="TRADITIONS">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">Long-standing customs and beliefs within a family or culture that guide financial behaviors and expectations.</data>
  <data key="d2">1</data>
</node>
<node id="CLOTHES FOR SCHOOL">
  <data key="d0">FINANCIAL_PRODUCT</data>
  <data key="d1">Garments purchased for children's school attendance, representing a family need that can be a source of financial conflict.</data>
  <data key="d2">1</data>
</node>
<node id="CONFLICTS">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">Disagreements or disputes, particularly within a family, that can arise from differing financial priorities.</data>
  <data key="d2">1</data>
</node>
<node id="CONFUSION">
  <data key="d0">RISK</data>
  <data key="d1">A state of uncertainty or lack of clarity that can arise from financial conflicts, hindering effective decision-making.</data>
  <data key="d2">1</data>
</node>
<node id="OUTSIDE PRESSURES">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">External influences, such as community expectations or societal trends, that can sway financial decisions away from a plan.</data>
  <data key="d2">1</data>
</node>
<node id="MOTIVATION">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">The underlying reasons, desires, or goals that drive an individual's financial behavior and decisions.</data>
  <data key="d2">1</data>
</node>
<node id="CHALLENGES">
  <data key="d0">RISK</data>
  <data key="d1">Obstacles or difficulties encountered in managing finances or achieving financial goals.</data>
  <data key="d2">1</data>
</node>
<node id="FRIENDS">
  <data key="d0">PERSON</data>
  <data key="d1">Individuals who may receive money sent from the United States, mentioned as a common recipient of international transfers.</data>
  <data key="d2">2</data>
</node>
<node id="CHILDREN">
  <data key="d0">PERSON</data>
  <data key="d1">Young individuals who learn about money and financial habits from their parents and environment.</data>
  <data key="d2">1</data>
</node>
<node id="INSIGHTS">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">New understandings gained about one's values and attitudes toward money, facilitating positive financial changes.</data>
  <data key="d2">1</data>
</node>
<node id="FINANCIAL CHANGES">
  <data key="d0">ACTION</data>
  <data key="d1">Alterations in financial behavior or strategy, aimed at achieving goals or improving financial well-being.</data>
  <data key="d2">1</data>
</node>
<node id="CULTURAL FACTORS">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">Elements of a person's culture that significantly guide their financial behavior and choices.</data>
  <data key="d2">1</data>
</node>
<node id="DESIRES">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">Things that individuals wish for or want, which can drive their financial choices and goals.</data>
  <data key="d2">1</data>
</node>
<node id="PERSONAL VALUES">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">An individual's own deeply held beliefs and principles that influence their financial perspectives and advice-giving.</data>
  <data key="d2">1</data>
</node>
<node id="VALUES ABOUT MONEY">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">The specific principles and beliefs an individual holds regarding the importance, use, and management of money.</data>
  <data key="d2">1</data>
</node>
<node id="FINANCIAL ISSUES">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">Challenges or problems related to an individual's finances, such as debt, lack of savings, or income instability.</data>
  <data key="d2">1</data>
</node>
<node id="PREFERENCES">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">Personal inclinations or choices that can influence financial advice and decisions.</data>
  <data key="d2">1</data>
</node>
<node id="ADVICE">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">Recommendations or guidance offered to individuals regarding their financial choices.</data>
  <data key="d2">1</data>
</node>
<node id="SUPPORT">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">Assistance or encouragement provided to individuals in their financial journey.</data>
  <data key="d2">1</data>
</node>
<node id="BELIEFS">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">Fundamental convictions that influence an individual's financial worldview and decision-making.</data>
  <data key="d2">1</data>
</node>
<node id="FEELING JUDGED">
  <data key="d0">RISK</data>
  <data key="d1">An emotional reaction experienced when one perceives disapproval, which can hinder open discussion about financial matters.</data>
  <data key="d2">1</data>
</node>
<node id="SHORT-TERM GAIN">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">Immediate positive outcomes or benefits derived from a financial choice.</data>
  <data key="d2">1</data>
</node>
<node id="LONG-TERM IMPACT">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">The sustained or future consequences of a financial decision.</data>
  <data key="d2">1</data>
</node>
<node id="COURSE OF ACTION">
  <data key="d0">ACTION</data>
  <data key="d1">A specific plan or method chosen to achieve a goal or respond to a situation, particularly in financial decision-making.</data>
  <data key="d2">1</data>
</node>
<node id="CONSEQUENCES OF CHOICES">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">The outcomes or results, both positive and negative, that stem from financial decisions.</data>
  <data key="d2">1</data>
</node>
<node id="PERSPECTIVES">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">An individual's unique viewpoints and interpretations of financial matters, influenced by their experiences and background.</data>
  <data key="d2">1</data>
</node>
<node id="LONG-TERM CONSEQUENCES">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">The enduring or future impacts resulting from present financial decisions.</data>
  <data key="d2">1</data>
</node>
<node id="FAMILY BUSINESS">
  <data key="d0">ORGANIZATION</data>
  <data key="d1">An enterprise owned and/or operated by members of a single family, often influenced by family financial decisions.</data>
  <data key="d2">1</data>
</node>
<node id="SAVING FOR A CAR">
  <data key="d0">ACTION</data>
  <data key="d1">The act of accumulating money specifically for the purpose of purchasing a vehicle.</data>
  <data key="d2">1</data>
</node>
<node id="SAVING FOR A HOME">
  <data key="d0">ACTION</data>
  <data key="d1">The act of accumulating money specifically for the purpose of purchasing a residence.</data>
  <data key="d2">1</data>
</node>
<node id="CORE VALUES">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">The fundamental, deeply ingrained beliefs and principles that form the foundation of an individual's financial identity.</data>
  <data key="d2">1</data>
</node>
<node id="INHERITANCES">
  <data key="d0">FINANCIAL_CONCEPT</data>
