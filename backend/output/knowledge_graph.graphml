  <data key="d2">2</data>
</node>
<node id="PRIORITIZING EXPENSES">
  <data key="d0">ACTION</data>
  <data key="d1">The act of ranking expenses by importance, a core teaching of Module 4.</data>
  <data key="d2">1</data>
</node>
<node id="REDUCING EXPENSES">
  <data key="d0">ACTION</data>
  <data key="d1">The action of decreasing spending to save money, a goal taught in Module 4.</data>
  <data key="d2">1</data>
</node>
<node id="PAYING BILLS EFFICIENTLY">
  <data key="d0">ACTION</data>
