  <data key="d2">1</data>
</node>
<node id="POTENTIAL POLICYHOLDER">
  <data key="d0">PERSON</data>
  <data key="d1">An individual who is considering purchasing a life insurance policy.</data>
  <data key="d2">1</data>
</node>
<node id="HOME MAINTENANCE">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">The upkeep and repair of a home, a type of living cost.</data>
  <data key="d2">1</data>
</node>
<node id="LIFE INSURANCE POLICY EXPIRATION">
  <data key="d0">ACTION</data>
