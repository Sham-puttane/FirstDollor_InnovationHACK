  <data key="d0">ORGANIZATION</data>
  <data key="d1">A business that offers consumer goods to customers through rent-to-own agreements.</data>
  <data key="d2">1</data>
</node>
<node id="SMALL DOLLAR LOANS">
  <data key="d0">FINANCIAL_PRODUCT</data>
  <data key="d1">Loans generally under $500, characterized by quick repayment terms and often automatic payment withdrawals, making them prone to frequent re-borrowing.</data>
  <data key="d2">2</data>
</node>
<node id="TRADITIONAL CREDIT CHECK">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">A process of evaluating a borrower's creditworthiness by reviewing their credit history, which is generally not performed for payday loans.</data>
  <data key="d2">1</data>
</node>
<node id="ELECTRONIC ACCESS">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">Permission granted by a borrower to a lender to automatically withdraw funds from their bank or credit union account for loan repayment.</data>
  <data key="d2">1</data>
</node>
<node id="AUTHORIZATION">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">Formal permission granted by a borrower to a lender, for example, to take money directly from their bank account.</data>
  <data key="d2">1</data>
</node>
<node id="RENEW">
  <data key="d0">ACTION</data>
  <data key="d1">The act of extending the term of a loan, typically by paying an additional fee rather than the full principal and interest.</data>
  <data key="d2">1</data>
</node>
<node id="ROLLOVER">
  <data key="d0">ACTION</data>
  <data key="d1">An action similar to renewing, where a borrower extends a loan's term, usually incurring another fee, when they cannot repay the full amount.</data>
  <data key="d2">1</data>
</node>
<node id="REPAYING">
  <data key="d0">ACTION</data>
  <data key="d1">The act of paying back a loan, including the principal and any associated fees or interest, to the lender.</data>
  <data key="d2">1</data>
</node>
<node id="AUCTION">
  <data key="d0">EVENT</data>
  <data key="d1">A public sale where goods, such as repossessed cars, are sold to the highest bidder.</data>
  <data key="d2">1</data>
</node>
<node id="PURCHASE">
  <data key="d0">ACTION</data>
  <data key="d1">The act of acquiring ownership of an item or property, typically by paying its full price, as an option in rent-to-own.</data>
  <data key="d2">3</data>
</node>
<node id="RETURN">
  <data key="d0">ACTION</data>
  <data key="d1">The act of giving an item back to the seller or owner, as an option for the borrower in rent-to-own arrangements.</data>
  <data key="d2">1</data>
</node>
<node id="FREQUENT RE-BORROWING">
  <data key="d0">RISK</data>
  <data key="d1">The pattern of repeatedly taking out new loans to cover existing financial obligations, a common problem with short-term, small dollar loans.</data>
  <data key="d2">1</data>
</node>
<node id="PAYDAY LOAN TERM">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">The specified duration for which a payday loan is granted, typically 14 days.</data>
  <data key="d2">1</data>
</node>
<node id="RESTRICT">
  <data key="d0">ACTION</data>
  <data key="d1">To limit or control certain activities, such as payday lending, often by state law.</data>
  <data key="d2">1</data>
</node>
<node id="PROHIBIT">
  <data key="d0">ACTION</data>
  <data key="d1">To formally forbid something, such as certain lending practices, often by state law.</data>
  <data key="d2">1</data>
</node>
<node id="INVESTMENT ACCOUNT">
  <data key="d0">FINANCIAL_PRODUCT</data>
  <data key="d1">A type of account into which a savings plan, such as a 529 Plan, can be placed, often with special tax benefits.</data>
  <data key="d2">1</data>
</node>
<node id="INCOME TAX">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">A government levy on an individual's or entity's income, which may be incurred along with penalty fees if certain financial products are used for non-qualified purposes.</data>
  <data key="d2">1</data>
</node>
<node id="DEPOSIT FIXED AMOUNT OF MONEY">
  <data key="d0">ACTION</data>
  <data key="d1">The action of placing a specific, predetermined sum of money into an account or financial product, such as a Certificate of Deposit.</data>
  <data key="d2">1</data>
</node>
<node id="WITHDRAW MONEY AFTER MATURITY">
  <data key="d0">ACTION</data>
  <data key="d1">The action of taking out funds from a financial product, like a Certificate of Deposit, once the agreed-upon term has ended.</data>
  <data key="d2">1</data>
</node>
<node id="PAY PENALTY">
  <data key="d0">ACTION</data>
  <data key="d1">The action of incurring and remitting a charge or fine due to a specific financial action, such as early withdrawal from a Certificate of Deposit.</data>
  <data key="d2">1</data>
</node>
<node id="NEGATIVE EQUITY">
  <data key="d0">RISK</data>
  <data key="d1">The financial situation where the amount owed on an asset, such as a car, is greater than its current market value, often a risk with longer loan terms.</data>
  <data key="d2">1</data>
</node>
<node id="TITLE FEES">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">Charges incurred for the legal transfer of a vehicle's ownership title, which are non-negotiable and part of the upfront car costs.</data>
  <data key="d2">1</data>
</node>
<node id="NON-NEGOTIABLE FEES">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">Mandatory charges associated with a car purchase, including state and local taxes and title fees, that cannot be altered through negotiation.</data>
  <data key="d2">1</data>
</node>
<node id="NEGOTIABLE FEES">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">Charges associated with a car purchase or loan, such as delivery, origination, document, and preparation fees, whose amounts can potentially be reduced through negotiation.</data>
  <data key="d2">1</data>
</node>
<node id="DELIVERY CHARGES">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">A negotiable fee covering the cost of transporting a new vehicle from the factory to the dealership.</data>
  <data key="d2">1</data>
</node>
<node id="ORIGINATION FEES">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">A negotiable fee charged by a lender for processing a new loan application.</data>
  <data key="d2">1</data>
</node>
<node id="DOCUMENT FEES">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">A negotiable fee charged for preparing and processing the paperwork involved in a car purchase or loan.</data>
  <data key="d2">1</data>
</node>
<node id="PREPARATION FEES">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">A negotiable fee charged for cleaning, inspecting, and preparing a new vehicle for customer delivery.</data>
  <data key="d2">1</data>
</node>
<node id="COST OF THE CAR BEFORE INTEREST">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">The sum of the car's price, additional features, services, add-ons, and all associated taxes and fees, prior to the calculation of any loan interest.</data>
  <data key="d2">1</data>
</node>
<node id="DOWN PAYMENT">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">An initial cash payment made by the buyer at the time of purchase, which reduces the total amount of money that needs to be financed and lowers the overall loan cost.</data>
  <data key="d2">1</data>
</node>
<node id="TRADE-IN VALUE">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">The monetary value assigned to a buyer's existing vehicle when exchanged for a new one, which can be applied to reduce the total amount to finance for the new purchase.</data>
  <data key="d2">1</data>
</node>
<node id="TOTAL AMOUNT TO FINANCE">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">The remaining balance of the car's cost after applying the down payment and trade-in value, representing the principal amount that will be borrowed through a loan.</data>
  <data key="d2">1</data>
</node>
<node id="LENGTH OF LOAN">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">The specified duration, typically in months or years, over which a loan is scheduled to be repaid; a longer term generally results in higher total interest paid.</data>
  <data key="d2">1</data>
</node>
<node id="DEALER">
  <data key="d0">ORGANIZATION</data>
  <data key="d1">A business that sells cars and can provide information or services related to auto loans and car purchases.</data>
  <data key="d2">1</data>
</node>
<node id="TOTAL AMOUNT PAID ON THE LOAN">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">The cumulative sum of all monthly payments made throughout the entire term of an auto loan, encompassing both the principal borrowed and the interest accrued.</data>
  <data key="d2">1</data>
</node>
<node id="TOTAL COST OF YOUR PURCHASE">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">The comprehensive cost of acquiring a vehicle, encompassing the total amount paid on the loan, the down payment, and the trade-in value, reflecting the full financial outlay.</data>
  <data key="d2">1</data>
</node>
<node id="TOTAL INTEREST PAID OVER LIFE OF THE LOAN">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">The aggregate sum of all interest payments made from the beginning to the end of a loan's term.</data>
  <data key="d2">1</data>
</node>
<node id="NEGOTIATING">
  <data key="d0">ACTION</data>
  <data key="d1">The act of discussing and bargaining with parties such as lenders or dealers to reach mutually agreeable terms, particularly concerning prices, fees, or interest rates.</data>
  <data key="d2">1</data>
</node>
<node id="EVALUATING REPAYMENT PLANS">
  <data key="d0">ACTION</data>
  <data key="d1">The process of assessing and comparing different structured approaches for paying back student loans to determine which option best suits an individual's financial situation and needs.</data>
  <data key="d2">1</data>
</node>
<node id="MONEY CONVERSATION">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">A discussion about financial matters that the companion guides help contextualize.</data>
  <data key="d2">1</data>
</node>
<node id="FINANCIAL SITUATIONS">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">The unique financial circumstances that military life presents.</data>
  <data key="d2">1</data>
</node>
<node id="MILITARY CONSUMERS">
  <data key="d0">PERSON</data>
  <data key="d1">A specific group of consumers within the military communities who face particular financial challenges.</data>
  <data key="d2">1</data>
</node>
<node id="NATIVE COMMUNITY MEMBERS">
  <data key="d0">PERSON</data>
  <data key="d1">Individuals belonging to Native communities whose financial lives are addressed by a companion guide.</data>
  <data key="d2">1</data>
</node>
<node id="FINANCIAL LIVES">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">The overall financial circumstances and activities of individuals, particularly Native community members.</data>
  <data key="d2">1</data>
</node>
<node id="SEASONAL INCOME AND EXPENSES">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">Income and expenditure patterns that vary according to seasons, relevant for annual planning in Native communities.</data>
  <data key="d2">1</data>
</node>
<node id="ELDERS">
  <data key="d0">PERSON</data>
  <data key="d1">An older population group, particularly in Native communities, who are susceptible to financial exploitation.</data>
  <data key="d2">1</data>
</node>
<node id="DISABILITY COMMUNITY">
  <data key="d0">PERSON</data>
  <data key="d1">A population group consisting of people with disabilities, served by specific organizations and a CFPB guide.</data>
  <data key="d2">1</data>
</node>
<node id="INCOME FROM WORK">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">Earnings derived from employment, which can impact Social Security Income (SSI).</data>
  <data key="d2">1</data>
</node>
<node id="FINANCIALLY EMPOWER">
  <data key="d0">ACTION</data>
  <data key="d1">The act of providing individuals with the knowledge, skills, and resources to take control of their financial lives.</data>
  <data key="d2">1</data>
</node>
<node id="FAMILIES OF CRIMINAL JUSTICE-INVOLVED INDIVIDUALS">
  <data key="d0">PERSON</data>
  <data key="d1">Family members of individuals involved in the criminal justice system, who are also targeted by the reentry guide for financial empowerment.</data>
  <data key="d2">1</data>
</node>
<node id="FINANCIAL DECISIONMAKING">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">The process of making choices about how to manage money and other financial resources, especially for criminal justice-involved individuals.</data>
  <data key="d2">1</data>
</node>
<node id="FINANCES">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">The money and other liquid assets belonging to an individual, especially concerning preparation for incarceration.</data>
  <data key="d2">2</data>
</node>
<node id="TRANSITION">
  <data key="d0">EVENT</data>
  <data key="d1">The period of moving from incarceration back into community settings, requiring preparation of identification documents.</data>
  <data key="d2">1</data>
</node>
<node id="RELEASE">
  <data key="d0">EVENT</data>
  <data key="d1">The act of being set free from confinement, requiring financial and identification preparation.</data>
  <data key="d2">1</data>
</node>
<node id="COMMUNITY SETTINGS">
  <data key="d0">GEO</data>
  <data key="d1">Environments outside of incarceration, where individuals transition after release and may use reentry guides.</data>
  <data key="d2">1</data>
</node>
<node id="AUTOMATIC PAYMENT">
  <data key="d0">ACTION</data>
  <data key="d1">A scheduled withdrawal of funds from a borrower's bank account initiated by a lender to cover a loan payment.</data>
  <data key="d2">1</data>
</node>
<node id="REPAY LOAN">
  <data key="d0">ACTION</data>
  <data key="d1">The act of paying back a borrowed amount of money to the lender, fulfilling the financial obligation.</data>
  <data key="d2">1</data>
</node>
<node id="ALTERNATIVES TO SHORT-TERM LOANS">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">Various strategies and options available to individuals to avoid or replace the need for high-cost short-term borrowing, such as negotiating bills, using credit cards, or emergency savings.</data>
  <data key="d2">1</data>
</node>
<node id="SHORT ON CASH">
  <data key="d0">RISK</data>
  <data key="d1">A financial state where an individual has insufficient immediate funds to cover expenses or needs, often leading to considering borrowing options.</data>
  <data key="d2">1</data>
</node>
<node id="NEGOTIATE">
  <data key="d0">ACTION</data>
  <data key="d1">To discuss terms and reach an agreement, particularly for extending payment deadlines for a bill or loan.</data>
  <data key="d2">1</data>
</node>
<node id="NEED">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">An essential requirement or necessity for which money might be spent or borrowed, distinguished from obligations or wants.</data>
  <data key="d2">1</data>
</node>
<node id="OBLIGATION">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">A financial or moral duty to do something or to make a payment, such as paying rent or a loan installment.</data>
  <data key="d2">1</data>
</node>
<node id="WANT">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">A desire for something that is not essential or necessary, influencing discretionary spending and borrowing decisions.</data>
  <data key="d2">1</data>
</node>
<node id="SPEND LESS MONEY">
  <data key="d0">ACTION</data>
  <data key="d1">The activity of reducing expenditures and being more frugal with finances, often considered as an alternative to borrowing.</data>
  <data key="d2">1</data>
</node>
<node id="MONTHLY CARD PAYMENT">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">The periodic payment, typically once a month, required on a credit card balance.</data>
  <data key="d2">1</data>
</node>
<node id="MAXED OUT">
  <data key="d0">RISK</data>
  <data key="d1">The condition of a credit card account having reached its maximum credit limit, preventing further charges or cash advances.</data>
  <data key="d2">1</data>
</node>
<node id="LOWER-COST SHORT-TERM LOAN ALTERNATIVES">
  <data key="d0">FINANCIAL_PRODUCT</data>
  <data key="d1">More affordable borrowing options for short periods, typically available from credit unions or banks, offering better terms than high-cost short-term loans.</data>
  <data key="d2">1</data>
</node>
<node id="BORROW FROM A FRIEND OR FAMILY MEMBER">
  <data key="d0">ACTION</data>
  <data key="d1">The act of obtaining money from personal acquaintances, often an informal loan arrangement, presented as an alternative to formal loans.</data>
  <data key="d2">1</data>
</node>
<node id="EMERGENCY EXPENSE">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">An unexpected cost that arises suddenly and requires immediate payment, such as a car repair.</data>
  <data key="d2">1</data>
</node>
<node id="$350 (CAR REPAIR COST)">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">The specific monetary cost of the unexpected car repair used as an example in the comparative scenario.</data>
  <data key="d2">1</data>
</node>
<node id="COST INFORMATION">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">Data detailing the expenses, interest, and fees associated with different financial options for covering an emergency expense.</data>
  <data key="d2">1</data>
</node>
<node id="AMOUNT NEEDED">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">The specific sum of money required to cover an expense or to serve as the principal for a loan.</data>
  <data key="d2">1</data>
</node>
<node id="15.99 PERCENT APR">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">The specific annual percentage rate applied to the credit card in the comparative example for covering an emergency expense.</data>
  <data key="d2">1</data>
</node>
<node id="391 PERCENT APR">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">The specific annual percentage rate equivalent for the payday loan in the comparative example, calculated based on its fees and short term.</data>
  <data key="d2">1</data>
</node>
<node id="$15 FOR EVERY $100 BORROWED">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">The fee structure for the payday loan in the example scenario, meaning $15 is charged for each $100 of the principal.</data>
  <data key="d2">1</data>
</node>
<node id="FIXED MONTHLY PAYMENT OF $25">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">The specific, consistent amount paid each month for the credit card in the comparative example, used to calculate repayment time.</data>
  <data key="d2">1</data>
</node>
<node id="LOAN AMOUNT ($350)">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">The principal sum of $350 borrowed for the payday loan in the comparative example.</data>
  <data key="d2">1</data>
</node>
<node id="FEE ($52.50)">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">The specific $52.50 charge associated with the payday loan example for a 14-day term.</data>
  <data key="d2">1</data>
</node>
<node id="TIME TO REPAY">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">The duration provided or required for the borrower to fully pay back a loan or credit card balance.</data>
  <data key="d2">1</data>
</node>
<node id="16 MONTHS">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">The estimated repayment duration for the credit card in the comparative example, based on a fixed monthly payment of $25.</data>
  <data key="d2">1</data>
</node>
<node id="14 DAYS">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">The standard repayment duration for the payday loan in the comparative example.</data>
  <data key="d2">1</data>
</node>
<node id="$40 (CREDIT CARD FEES)">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">The specific total interest and fees incurred over 16 months when using the credit card in the comparative example.</data>
  <data key="d2">1</data>
</node>
<node id="$52.50 (PAYDAY LOAN FEE)">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">The specific fee incurred for a single 14-day payday loan in the comparative example.</data>
  <data key="d2">1</data>
</node>
<node id="TOTAL COST OF CAR REPAIR">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">The final overall expenditure for the car repair, factoring in the initial cost ($350) and any associated borrowing fees or interest.</data>
  <data key="d2">1</data>
</node>
<node id="$390 (CREDIT CARD TOTAL COST)">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">The total cost of the car repair ($350) plus credit card interest and fees ($40) when using a credit card.</data>
  <data key="d2">1</data>
</node>
<node id="$402.50 (PAYDAY LOAN TOTAL COST)">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">The total cost of the car repair ($350) plus payday loan fees ($52.50) if the loan is repaid on time.</data>
  <data key="d2">1</data>
</node>
<node id="RENEW OR ROLL OVER LOAN">
  <data key="d0">ACTION</data>
  <data key="d1">The act of extending a loan's term, typically a payday loan, by paying only the fees and re-borrowing the principal, which significantly increases the total cost and duration of debt.</data>
  <data key="d2">1</data>
</node>
<node id="10 WEEKS (DEBT DURATION)">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">The total duration of debt if a payday loan is renewed or rolled over four times, illustrating the extended impact of frequent re-borrowing.</data>
  <data key="d2">1</data>
</node>
<node id="$262.50 IN FEES">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">The cumulative fees incurred when a payday loan is renewed or rolled over four times, in addition to the original principal.</data>
  <data key="d2">1</data>
</node>
<node id="$350 (ORIGINAL BORROWED AMOUNT)">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">The initial principal sum of money borrowed in the payday loan rollover example.</data>
  <data key="d2">1</data>
</node>
<node id="$612.50 (TOTAL PAYDAY LOAN COST)">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">The total amount paid for a payday loan, including the original principal and accumulated fees, after multiple rollovers.</data>
  <data key="d2">1</data>
</node>
<node id="SPECIAL PROTECTION">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">Specific legal safeguards or benefits provided to certain groups, such as active duty servicemembers and their dependents, under laws like the Military Lending Act.</data>
  <data key="d2">1</data>
</node>
<node id="HOPES, WANTS, AND DREAMS">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">Future desires and aspirations that individuals hold for themselves and their family, which can be turned into specific goals through planning and financial consideration.</data>
  <data key="d2">1</data>
</node>
<node id="PLAN">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">A structured strategy or approach developed to achieve specific goals, often involving financial considerations and steps to turn hopes, wants, and dreams into reality.</data>
  <data key="d2">1</data>
</node>
<node id="HOLIDAYS">
  <data key="d0">EVENT</data>
  <data key="d1">A recurring event for which individuals might set a short-term financial goal, such as saving money to buy gifts.</data>
  <data key="d2">1</data>
</node>
<node id="SMART GOAL METHOD">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">A structured approach to goal setting that ensures goals are Specific, Measurable, Achievable, Relevant, and Time-bound, increasing their effectiveness and likelihood of accomplishment.</data>
  <data key="d2">1</data>
</node>
<node id="SPECIFIC">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">The characteristic of a SMART goal requiring it to be clearly defined and precise, rather than general, to increase its chances of being met.</data>
  <data key="d2">2</data>
</node>
<node id="MEASURABLE">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">The characteristic of a SMART goal requiring its progress to be trackable, allowing individuals to determine if they are on course to achieve it.</data>
  <data key="d2">2</data>
</node>
<node id="ACHIEVABLE">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">The characteristic of a SMART goal requiring it to be realistic and attainable, avoiding extreme or impossible objectives, possibly by breaking down larger goals.</data>
  <data key="d2">2</data>
</node>
<node id="RELEVANT">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">The characteristic of a SMART goal requiring it to be personally important and aligned with one's priorities, increasing the motivation to achieve it.</data>
  <data key="d2">2</data>
</node>
<node id="TIME BOUND">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">The characteristic of a SMART goal requiring a clearly defined time frame, including a target or deadline date, to ensure measurability and timely action.</data>
  <data key="d2">2</data>
</node>
<node id="TRAINING OR EDUCATIONAL EXPENSES">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">Costs associated with acquiring new skills, knowledge, or qualifications, often categorized as a significant financial outlay or large purchase.</data>
  <data key="d2">2</data>
</node>
<node id="TOOLS OR EQUIPMENT FOR YOUR JOB">
  <data key="d0">FINANCIAL_PRODUCT</data>
  <data key="d1">Physical items or machinery necessary for one's occupation, often considered a large purchase requiring financial planning.</data>
  <data key="d2">1</data>
</node>
<node id="COMPLAINT HOTLINE">
  <data key="d0">ACTION</data>
  <data key="d1">A phone service, accessible via (855) 411-2372, provided by the CFPB for submitting complaints about financial products or services.</data>
  <data key="d2">1</data>
</node>
<node id="GROCERY, RETAIL, OR OTHER STORE">
  <data key="d0">ORGANIZATION</data>
  <data key="d1">Various types of retail establishments that may offer bill payment services or check cashing services.</data>
  <data key="d2">3</data>
</node>
<node id="DEFAULT ON THE LOAN">
  <data key="d0">RISK</data>
  <data key="d1">The failure to make required payments on a loan, leading to potential consequences like foreclosure for a mortgage.</data>
  <data key="d2">1</data>
</node>
<node id="LOAN ISN'T REPAID AS AGREED">
  <data key="d0">RISK</data>
  <data key="d1">The failure to repay a loan according to the terms and conditions set, which can lead to additional fees or the loss of collateral.</data>
  <data key="d2">1</data>
</node>
<node id="PAYDAY LOAN PROVIDER">
  <data key="d0">ORGANIZATION</data>
  <data key="d1">A business that offers small, short-term loans, typically repaid on the borrower's next payday.</data>
  <data key="d2">2</data>
</node>
<node id="SALARY OR WAGES">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">The regular financial compensation an employee receives from an employer for work performed.</data>
  <data key="d2">1</data>
</node>
<node id="SERVICE FEES">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">Charges incurred for using a financial product or service, such as those associated with payroll cards or prepaid cards.</data>
  <data key="d2">1</data>
</node>
<node id="ELECTRONIC ERROR">
  <data key="d0">RISK</data>
  <data key="d1">A technical malfunction or mistake in an electronic financial transaction that can lead to loss of funds, against which consumer protections often apply.</data>
  <data key="d2">1</data>
</node>
<node id="PEER-TO-PEER TRANSFER SERVICE">
  <data key="d0">FINANCIAL_PRODUCT</data>
  <data key="d1">An electronic service enabling individuals to send and receive funds directly from one person to another, typically via mobile devices or computers, often incurring a fee.</data>
  <data key="d2">3</data>
</node>
<node id="MOBILE DEVICE">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">A portable electronic device, such as a smartphone, used for financial activities, hosting financial apps, and requiring security measures like password protection and remote access features.</data>
  <data key="d2">3</data>
</node>
<node id="COMPUTER">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">An electronic device used to access and perform financial transactions, such as peer-to-peer transfers or online banking.</data>
  <data key="d2">2</data>
</node>
<node id="MONTHLY MAINTENANCE FEE">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">A recurring charge applied to an account or card, often a prepaid card, to cover administrative costs.</data>
  <data key="d2">1</data>
</node>
<node id="USAGE FEE">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">A charge applied each time a specific service or feature of a financial product, like a prepaid card, is utilized.</data>
  <data key="d2">1</data>
</node>
<node id="INSURED FUNDS">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">Money held in financial accounts that is protected by government agencies up to a certain limit in case the financial institution fails.</data>
  <data key="d2">1</data>
</node>
<node id="BANK FAILS">
  <data key="d0">RISK</data>
  <data key="d1">The event where a bank becomes insolvent and is unable to meet its financial obligations to its depositors and creditors, potentially leading to loss of uninsured funds.</data>
  <data key="d2">1</data>
</node>
<node id="INSURED DEPOSITS">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">Funds placed in a savings account that are guaranteed by a government entity, protecting the depositor in case the bank fails.</data>
  <data key="d2">1</data>
</node>
<node id="DEPOSIT (FOR SECURED CREDIT CARD)">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">The amount of money paid by a cardholder that acts as collateral for a secured credit card, often determining the credit limit.</data>
  <data key="d2">1</data>
</node>
<node id="BALANCE (CREDIT CARD)">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">The total amount of money owed on a credit card at a particular time.</data>
  <data key="d2">1</data>
</node>
<node id="FREQUENT TRANSACTIONS">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">Numerous and regular financial activities (deposits, withdrawals, purchases), which savings accounts are generally not intended for.</data>
  <data key="d2">1</data>
</node>
<node id="BUY A HOUSE">
  <data key="d0">ACTION</data>
  <data key="d1">The action of purchasing real estate for residential purposes, typically financed through a mortgage.</data>
  <data key="d2">2</data>
</node>
<node id="REPAY MONTHLY">
  <data key="d0">ACTION</data>
  <data key="d1">The action of making regular, typically monthly, payments on a loan over a set period of time.</data>
  <data key="d2">2</data>
</node>
<node id="GET SMALL LOANS QUICKLY">
  <data key="d0">ACTION</data>
  <data key="d1">The act of obtaining a small amount of money in a short timeframe, characteristic of pawn loans and payday loans.</data>
  <data key="d2">1</data>
</node>
<node id="PAID CASH">
  <data key="d0">ACTION</data>
  <data key="d1">The act of giving physical currency as payment or in exchange for an item, as done in a pawn loan transaction.</data>
  <data key="d2">1</data>
</node>
<node id="CASHES A CHECK">
  <data key="d0">ACTION</data>
  <data key="d1">The act of a lender converting a borrower's check into cash, or holding it for future deposit, as part of a payday loan process.</data>
  <data key="d2">1</data>
</node>
<node id="ELECTRONICALLY DEBITS THE PAYMENT">
  <data key="d0">ACTION</data>
  <data key="d1">The act of a lender withdrawing funds from a borrower's bank account digitally to collect a loan payment, common with payday loans.</data>
  <data key="d2">1</data>
</node>
<node id="RENEW (A LOAN)">
  <data key="d0">ACTION</data>
  <data key="d1">The act of extending the term of an existing loan, often by paying an additional fee, if the original loan isn't repaid as agreed.</data>
  <data key="d2">1</data>
</node>
<node id="DIRECTLY DEPOSITED">
  <data key="d0">ACTION</data>
  <data key="d1">The act of transferring funds electronically into a bank account or onto a card, such as an employer depositing salary onto a payroll card.</data>
  <data key="d2">1</data>
</node>
<node id="LOADS (SALARY OR WAGES)">
  <data key="d0">ACTION</data>
  <data key="d1">The act of an employer transferring salary or wages onto a payroll card for an employee.</data>
  <data key="d2">1</data>
</node>
<node id="USE (CARD)">
  <data key="d0">ACTION</data>
  <data key="d1">The act of utilizing a financial card (like a payroll, prepaid, or debit card) for transactions such as purchases.</data>
  <data key="d2">1</data>
</node>
<node id="ELECTRONICALLY TRANSFER FUNDS">
  <data key="d0">ACTION</data>
  <data key="d1">The act of moving money digitally from one account or person to another, a core function of peer-to-peer transfer services.</data>
  <data key="d2">1</data>
</node>
<node id="SEND AND RECEIVE FUNDS">
  <data key="d0">ACTION</data>
  <data key="d1">The dual action of initiating and accepting money transfers, typically using a mobile device or computer for services like peer-to-peer transfers.</data>
  <data key="d2">1</data>
</node>
<node id="KEEP MONEY (SECURELY)">
  <data key="d0">ACTION</data>
  <data key="d1">The act of storing funds in a safe manner, often in a secure place like a prepaid card or savings account.</data>
  <data key="d2">1</data>
</node>
<node id="PAY AND MANAGE BILLS">
  <data key="d0">ACTION</data>
  <data key="d1">The act of settling financial obligations and overseeing their payment schedule, which can be done with a prepaid card.</data>
  <data key="d2">1</data>
</node>
<node id="SET ASIDE FUNDS">
  <data key="d0">ACTION</data>
  <data key="d1">The act of designating money for a specific future purpose, often facilitated by prepaid cards or savings accounts.</data>
  <data key="d2">1</data>
</node>
<node id="ACCESS MONEY">
  <data key="d0">ACTION</data>
  <data key="d1">The act of retrieving or utilizing funds available in an account or on a card, such as from a prepaid card.</data>
  <data key="d2">1</data>
</node>
<node id="PAID OR LOADED IN ADVANCE">
  <data key="d0">ACTION</data>
  <data key="d1">The act of depositing funds into a card or account before use, characteristic of prepaid cards.</data>
  <data key="d2">1</data>
</node>
<node id="TAKE OUT MONEY FROM AN ATM">
  <data key="d0">ACTION</data>
  <data key="d1">The act of withdrawing cash from an Automated Teller Machine, a function available with some prepaid cards.</data>
  <data key="d2">1</data>
</node>
<node id="RELOAD MONEY ONTO THE CARD">
  <data key="d0">ACTION</data>
  <data key="d1">The act of adding more funds to an existing prepaid card.</data>
  <data key="d2">1</data>
</node>
<node id="SAVE FOR YOUR GOALS">
  <data key="d0">ACTION</data>
  <data key="d1">The act of accumulating money over time to achieve specific financial objectives, supported by savings wallet features or savings accounts.</data>
  <data key="d2">1</data>
</node>
<node id="DEPOSIT AND WITHDRAW MONEY">
  <data key="d0">ACTION</data>
  <data key="d1">The basic actions of placing funds into and taking funds out of a financial account, fundamental to a savings account.</data>
  <data key="d2">1</data>
</node>
<node id="EARNS INTEREST">
  <data key="d0">ACTION</data>
  <data key="d1">The action of an account or investment generating additional money over time, a characteristic of savings accounts.</data>
  <data key="d2">1</data>
</node>
<node id="BUILD UP MONEY FOR SAVINGS OR EMERGENCIES">
  <data key="d0">ACTION</data>
  <data key="d1">The act of accumulating funds specifically for future savings or unexpected urgent needs, typically done with a savings account.</data>
  <data key="d2">1</data>
</node>
<node id="BUILD A CREDIT HISTORY">
  <data key="d0">ACTION</data>
  <data key="d1">The act of establishing and improving a record of borrowing and repayment, often accomplished using a secured credit card.</data>
  <data key="d2">1</data>
</node>
<node id="ASPE.HHS.GOV/POVERTY-GUIDELINES">
  <data key="d0">ORGANIZATION</data>
  <data key="d1">A website providing the current Federal Poverty Guidelines, which are used in calculating discretionary income for income-driven repayment plans.</data>
  <data key="d2">1</data>
</node>
<node id="COMMUNITY RESOURCE">
  <data key="d0">ORGANIZATION</data>
  <data key="d1">An appropriate local organization or service that provides additional financial help or guidance, to which the toolkit can refer individuals when needed.</data>
  <data key="d2">1</data>
</node>
<node id="FINANCIAL EDUCATION CURRICULUM">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">A structured, sequential program of financial education with a concrete set of goals, which the toolkit is explicitly stated as being different from due to its flexible, needs-based approach.</data>
  <data key="d2">2</data>
</node>
<node id="WESTERN CULTURE">
  <data key="d0">GEO</data>
  <data key="d1">A broad cultural context, often associated with Western countries, characterized by values like individuality and personal well-being, which influences financial behavior and expectations of financial self-sufficiency.</data>
  <data key="d2">2</data>
</node>
<node id="FINANCIAL HABITS">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">Patterns of financial behavior, which can be good or bad, influencing how individuals manage their money and pursue their financial goals.</data>
  <data key="d2">2</data>
</node>
<node id="FINANCIAL PLAN">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">A structured outline or strategy for managing financial resources and achieving financial goals, which individuals may agree to but can struggle to stick to due to emotional or cultural influences.</data>
  <data key="d2">3</data>
</node>
<node id="HIGHEST INTEREST RATE STRATEGY">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">A debt repayment approach where individuals prioritize paying off debts with the highest interest rates first to minimize total interest paid over time.&gt;</data>
  <data key="d2">1</data>
</node>
<node id="OVERTIME INCOME">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">Additional earnings received for working hours beyond the standard workweek, increasing disposable income.&gt;</data>
  <data key="d2">1</data>
</node>
<node id="SECOND JOB INCOME">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">Earnings from an additional employment position, contributing to overall income for expenses or debt repayment.&gt;</data>
  <data key="d2">1</data>
</node>
<node id="SEASONAL SNAPSHOT TOOL">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">A financial planning tool or method to analyze and understand how personal expenses fluctuate throughout the year, aiding in preparation for variable costs.&gt;</data>
  <data key="d2">1</data>
</node>
<node id="HOLIDAY GIFTS">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">An example of a common seasonal expense that requires financial planning.&gt;</data>
  <data key="d2">1</data>
</node>
<node id="HEATING COSTS">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">An example of a variable or seasonal utility expense.&gt;</data>
  <data key="d2">1</data>
</node>
<node id="HOME REPAIRS">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">An example of an unexpected or variable expense related to property maintenance.&gt;</data>
  <data key="d2">1</data>
</node>
<node id="TAX PAYMENTS">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">Mandatory financial contributions to government revenue, which are often planned expenses.&gt;</data>
  <data key="d2">1</data>
</node>
<node id="SUMMER ACTIVITIES COSTS">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">An example of seasonal expenses related to recreational activities during summer months.&gt;</data>
  <data key="d2">1</data>
</node>
<node id="CAR INSURANCE BILL">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">A recurring financial obligation for vehicle insurance coverage.&gt;</data>
  <data key="d2">1</data>
</node>
<node id="BACK-TO-SCHOOL SUPPLIES">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">An example of a seasonal expense incurred for educational purposes.&gt;</data>
  <data key="d2">1</data>
</node>
<node id="NEW CLOTHES">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">An example of a variable expense for personal apparel.&gt;</data>
  <data key="d2">1</data>
</node>
<node id="PRIORITIZING DEBT PAYMENTS STRATEGY">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">A financial strategy used to decide which debts to pay first, especially during periods of limited funds, to mitigate risks.&gt;</data>
  <data key="d2">1</data>
</node>
<node id="OVERDUE NOTICES">
  <data key="d0">RISK</data>
  <data key="d1">Formal communications indicating a missed payment and often warning of penalties or further actions.&gt;</data>
  <data key="d2">1</data>
</node>
<node id="DISCONTINUATION OF SERVICE">
  <data key="d0">RISK</data>
  <data key="d1">The risk of essential services, such as utilities (gas, electric, water), being shut off due to non-payment.</data>
  <data key="d2">2</data>
</node>
<node id="MONTHLY SNAPSHOT TOOL">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">A financial planning tool used to track and balance monthly income, expenses, and debt payments for better financial control.&gt;</data>
  <data key="d2">1</data>
</node>
<node id="RENT COSTS">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">The regular payment made by a tenant to a landlord for the use of property.&gt;</data>
  <data key="d2">1</data>
</node>
<node id="UTILITIES COSTS">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">Expenses for essential services like electricity, water, and gas.&gt;</data>
  <data key="d2">1</data>
</node>
<node id="TRANSPORTATION COSTS">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">Expenses related to travel, commuting, and vehicle maintenance.&gt;</data>
  <data key="d2">1</data>
</node>
<node id="CHILDCARE COSTS">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">Expenses incurred for the care and supervision of children.&gt;</data>
  <data key="d2">1</data>
</node>
<node id="CELL PHONE BILL">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">A recurring expense for mobile telecommunication services.&gt;</data>
  <data key="d2">1</data>
</node>
<node id="GROCERIES COSTS">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">Expenses for food and other household provisions.&gt;</data>
  <data key="d2">1</data>
</node>
<node id="GOVERNMENT PROGRAMS INCOME">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">Financial assistance or benefits received from government initiatives.&gt;</data>
  <data key="d2">1</data>
</node>
<node id="CAR (ASSET)">
  <data key="d0">FINANCIAL_PRODUCT</data>
  <data key="d1">A motor vehicle, often used as collateral for secured loans.&gt;</data>
  <data key="d2">1</data>
</node>
<node id="HOUSE (ASSET)">
  <data key="d0">FINANCIAL_PRODUCT</data>
  <data key="d1">A residential property, often used as collateral for secured loans like mortgages.&gt;</data>
  <data key="d2">1</data>
</node>
<node id="FOOD AND CLOTHING">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">Essential basic living expenses for individuals and families, which life insurance can provide funds for in the absence of the insured's income.</data>
  <data key="d2">1</data>
</node>
<node id="TERM LIFE INSURANCE">
  <data key="d0">FINANCIAL_PRODUCT</data>
  <data key="d1">A type of life insurance that provides coverage for a specific period (term), paying a death benefit if the insured dies within that term.</data>
  <data key="d2">2</data>
</node>
<node id="WHOLE LIFE INSURANCE">
  <data key="d0">FINANCIAL_PRODUCT</data>
  <data key="d1">A type of permanent life insurance that remains in force for the insured's entire life and typically accumulates cash value.</data>
  <data key="d2">2</data>
</node>
<node id="LIFE ENHANCED MOBILE APP">
  <data key="d0">ORGANIZATION</data>
  <data key="d1">A mobile application offered by State Farm that provides guidance and motivation for overall wellness.</data>
  <data key="d2">1</data>
</node>
<node id="RATES">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">The price of insurance, set at the group level, based on common factors shared by multiple policyholders, like age or location, used to calculate individual premiums.</data>
  <data key="d2">1</data>
</node>
<node id="ACCIDENT STATISTICS">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">Data representing the frequency and severity of accidents, used by insurers to estimate the cost of future claims and determine car insurance rates.</data>
  <data key="d2">1</data>
</node>
<node id="VEHICLE REPAIR AND REPLACEMENT COSTS">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">The expenses associated with fixing or replacing a damaged vehicle, which are key data points in calculating car insurance rates.</data>
  <data key="d2">1</data>
</node>
<node id="LOCATION">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">A geographical factor used in insurance calculations, indicating the likelihood of being in an accident or experiencing theft, influencing premiums.</data>
  <data key="d2">1</data>
</node>
<node id="CLAIMS HISTORY">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">A record of a policyholder's past insurance claims, used by insurers to predict the likelihood and frequency of future claims and adjust premiums.</data>
  <data key="d2">1</data>
</node>
<node id="VEHICLE SAFETY FEATURES">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">Attributes of a vehicle designed to prevent accidents or mitigate their severity, which can influence insurance rates.</data>
  <data key="d2">1</data>
</node>
<node id="DRIVING BEHAVIORS">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">Patterns and habits exhibited by a driver, analyzed as data to estimate future claims and determine insurance rates.</data>
  <data key="d2">1</data>
</node>
<node id="INSURERS">
  <data key="d0">ORGANIZATION</data>
  <data key="d1">General term for insurance companies that collect information, assess risk, and calculate premiums for policies like car insurance.</data>
  <data key="d2">1</data>
</node>
<node id="CREDIT CHARACTERISTICS">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">Aspects of an individual's financial history and behavior that insurers may review to understand financial responsibility and risk, influencing premiums.</data>
  <data key="d2">1</data>
</node>
<node id="DRIVING RECORD">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">A documented history of a driver's traffic violations, indicating their behavior on the road and significantly affecting insurance premiums.</data>
  <data key="d2">1</data>
</node>
<node id="PRIOR INSURANCE COVERAGE">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">Information regarding a policyholder's previous insurance policies, which can be reviewed by insurers to assess continuity and risk.</data>
  <data key="d2">1</data>
</node>
<node id="ANNUAL MILEAGE">
  <data key="d0">FINANCIAL_CONCEPT</data>
