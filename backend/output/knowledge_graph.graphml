  <data key="d2">1</data>
</node>
<node id="U.S. DEPARTMENT OF LABOR">
  <data key="d0">ORGANIZATION</data>
  <data key="d1">The U.S. Department of Labor is a federal department providing services and information related to employment and workforce development, including a service locator for programs.</data>
  <data key="d2">1</data>
</node>
<node id="DOL.GOV">
  <data key="d0">ORGANIZATION</data>
