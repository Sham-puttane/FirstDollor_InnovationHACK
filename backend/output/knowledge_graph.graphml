  <data key="d2">3</data>
</node>
<node id="RENT (HOUSING EXPENSE)">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">The recurring cost of occupying a property or dwelling, representing a significant living expense.</data>
  <data key="d2">1</data>
</node>
<node id="TRANSPORTATION (EXPENSE)">
  <data key="d0">FINANCIAL_CONCEPT</data>
