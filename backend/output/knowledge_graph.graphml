  <data key="d2">1</data>
</node>
<node id="REPAID QUICKLY">
  <data key="d0">RISK</data>
  <data key="d1">The characteristic of a loan requiring very short repayment periods, which increases the likelihood of re-borrowing and financial difficulty.</data>
  <data key="d2">1</data>
</node>
<node id="AUTOMATIC WITHDRAWAL">
  <data key="d0">ACTION</data>
  <data key="d1">A process where a lender is authorized to automatically deduct loan payments directly from a borrower's bank account on scheduled dates.</data>
  <data key="d2">1</data>
</node>
<node id="PAY OFF">
  <data key="d0">ACTION</data>
  <data key="d1">To fully discharge a debt or loan by making the complete outstanding payment.</data>
  <data key="d2">1</data>
</node>
<node id="SEIZE">
  <data key="d0">ACTION</data>
  <data key="d1">To take sudden and forcible possession of an asset, often by a lender due to a borrower's default on a loan.</data>
  <data key="d2">1</data>
</node>
<node id="SELL">
  <data key="d0">ACTION</data>
  <data key="d1">To exchange goods or services for money, typically referring to a repossessed car being sold by the lender.</data>
  <data key="d2">1</data>
</node>
<node id="TRADITIONAL OVERDRAFT SERVICES">
  <data key="d0">FINANCIAL_PRODUCT</data>
  <data key="d1">Standard banking services that automatically cover transactions that exceed an account's balance, often for a fee, and which are explicitly stated as not being covered by the Military Lending Act.</data>
  <data key="d2">2</data>
</node>
<node id="LOAN TO BUY PERSONAL PROPERTY">
  <data key="d0">FINANCIAL_PRODUCT</data>
