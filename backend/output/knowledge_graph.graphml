  <data key="d2">1</data>
</node>
<node id="ORGANIZING BILLS">
  <data key="d0">ACTION</data>
  <data key="d1">The act of arranging bills systematically for easier management, a key topic in Module 4.</data>
  <data key="d2">1</data>
</node>
<node id="TRACKING BILLS">
  <data key="d0">ACTION</data>
  <data key="d1">The process of monitoring bills to understand due dates and amounts, emphasized in Module 4.</data>
  <data key="d2">1</data>
</node>
<node id="ORGANIZING EXPENSES">
  <data key="d0">ACTION</data>
  <data key="d1">The act of arranging expenses systematically for easier management, also covered in Module 4.</data>
  <data key="d2">1</data>
</node>
<node id="TRACKING EXPENSES">
  <data key="d0">ACTION</data>
