  <data key="d1">Coverage that pays for covered roadside assistance services when a vehicle is disabled, including towing, locksmith services, jumpstarts, and tire changes.</data>
  <data key="d2">3</data>
</node>
<node id="GAP COVERAGE">
  <data key="d0">FINANCIAL_PRODUCT</data>
  <data key="d1">Gap coverage is a type of insurance, usually offered by an auto loan provider rather than an insurance company, that covers the difference between your car loan amount and its value if your vehicle is totaled.</data>
  <data key="d2">2</data>
</node>
<node id="FULL COVERAGE">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">A colloquial term in car insurance, referring to a combination of various types of coverage. Its value depends on individual circumstances.</data>
  <data key="d2">1</data>
</node>
<node id="AUTO INSURANCE PRODUCT">
  <data key="d0">FINANCIAL_PRODUCT</data>
  <data key="d1">A specific insurance product offered by State Farm to cover automobiles.</data>
  <data key="d2">1</data>
</node>
<node id="RENTERS INSURANCE PRODUCT">
  <data key="d0">FINANCIAL_PRODUCT</data>
  <data key="d1">A specific insurance product offered by State Farm to cover renters' belongings and liabilities.</data>
  <data key="d2">1</data>
</node>
<node id="MOTORCYCLE INSURANCE PRODUCT">
  <data key="d0">FINANCIAL_PRODUCT</data>
  <data key="d1">A specific insurance product offered by State Farm to cover motorcycles.</data>
  <data key="d2">1</data>
</node>
<node id="HOMEOWNERS INSURANCE PRODUCT">
  <data key="d0">FINANCIAL_PRODUCT</data>
  <data key="d1">A specific insurance product offered by State Farm to cover homes and homeowners' liabilities.</data>
  <data key="d2">1</data>
</node>
<node id="CONDO OWNERS INSURANCE PRODUCT">
  <data key="d0">FINANCIAL_PRODUCT</data>
  <data key="d1">A specific insurance product offered by State Farm to cover condominium units and owners' liabilities.</data>
  <data key="d2">1</data>
</node>
<node id="SMALL BUSINESS INSURANCE PRODUCT">
  <data key="d0">FINANCIAL_PRODUCT</data>
  <data key="d1">A specific insurance product offered by State Farm to cover the needs of small businesses.</data>
  <data key="d2">1</data>
</node>
<node id="LIFE INSURANCE PRODUCT">
  <data key="d0">FINANCIAL_PRODUCT</data>
  <data key="d1">A specific insurance product offered by State Farm providing coverage for an individual's life.</data>
  <data key="d2">1</data>
</node>
<node id="MEDICARE SUPPLEMENT INSURANCE PRODUCT">
  <data key="d0">FINANCIAL_PRODUCT</data>
  <data key="d1">A specific insurance product offered by State Farm to supplement Medicare coverage.</data>
  <data key="d2">1</data>
</node>
<node id="SUPPLEMENTAL HEALTH INSURANCE PRODUCT">
  <data key="d0">FINANCIAL_PRODUCT</data>
  <data key="d1">A specific insurance product offered by State Farm providing additional health coverage.</data>
  <data key="d2">1</data>
</node>
<node id="PET INSURANCE PRODUCT">
  <data key="d0">FINANCIAL_PRODUCT</data>
  <data key="d1">A specific insurance product offered by State Farm to cover veterinary expenses for pets.</data>
  <data key="d2">1</data>
</node>
<node id="CAR INSURANCE CALCULATION">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">The methodology and factors used to determine car insurance premiums and rates.</data>
  <data key="d2">1</data>
</node>
<node id="BUNDLING INSURANCE">
  <data key="d0">ACTION</data>
  <data key="d1">A strategic financial practice of combining multiple insurance policies (e.g., auto, home, renters, life) with a single provider like State Farm to achieve discounts, cost savings, and simplified policy management.</data>
  <data key="d2">2</data>
</node>
<node id="INSURANCE AGENT">
  <data key="d0">PERSON</data>
  <data key="d1">An insurance agent is a professional who helps individuals understand their auto insurance options, provides quotes for different deductibles, and assists in selecting the right policy to fit their needs and budget.</data>
  <data key="d2">3</data>
</node>
<node id="AUTO INSURANCE QUOTE">
  <data key="d0">ACTION</data>
  <data key="d1">An estimated price for car insurance coverage tailored to an individual's specific circumstances, provided by an insurer like State Farm.</data>
  <data key="d2">2</data>
</node>
<node id="$0 MONTHLY PAYMENT">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">A specific payment amount in certain income-driven repayment plans where no payment is currently required from the borrower.</data>
  <data key="d2">1</data>
</node>
<node id="STUDENT LOAN PAYMENTS">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">Regular monetary installments made by a borrower to repay a student loan.</data>
  <data key="d2">1</data>
</node>
<node id="PAYBACK OPTIONS">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">The various choices and alternatives available to borrowers for repaying their loans or managing debt.</data>
  <data key="d2">1</data>
</node>
<node id="REDUCE YOUR DEBT">
  <data key="d0">ACTION</data>
  <data key="d1">The goal or process of decreasing the total amount of money owed by a borrower.</data>
  <data key="d2">1</data>
</node>
<node id="MINIMUM PAYMENTS">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">The smallest amount of money a borrower is obligated to pay on a debt within a specific period to avoid penalties.</data>
  <data key="d2">1</data>
</node>
<node id="CHANGE DUE DATE">
  <data key="d0">ACTION</data>
  <data key="d1">The act of requesting or negotiating with a creditor to adjust the scheduled date by which a payment is required, potentially to align with income cycles.</data>
  <data key="d2">2</data>
</node>
<node id="PAY MORE ON CREDIT CARD">
  <data key="d0">ACTION</data>
  <data key="d1">The proactive financial action of submitting a payment that exceeds the minimum required amount on a credit card statement, often to reduce interest and principal faster.</data>
  <data key="d2">2</data>
</node>
<node id="PROBLEM">
  <data key="d0">RISK</data>
  <data key="d1">An issue or difficulty encountered by consumers with financial products or services, which can lead to a complaint being submitted to the Consumer Financial Protection Bureau.</data>
  <data key="d2">1</data>
</node>
<node id="REFER TO THE TOOLKIT">
  <data key="d0">ACTION</data>
  <data key="d1">The act of consulting the "Your Money, Your Goals" toolkit for information and guidance, primarily by service providers.</data>
  <data key="d2">1</data>
</node>
<node id="MODULE 9: PROTECTING YOUR MONEY">
  <data key="d0">ORGANIZATION</data>
  <data key="d1">A specific module within the CFPB YMYG Toolkit, designed to educate consumers on protecting their money, understanding financial rights, and handling identity theft and fraud.</data>
  <data key="d2">9</data>
</node>
<node id="STRUGGLING TO MAKE ENDS MEET">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">A financial situation where individuals find it difficult to cover their basic expenses and current needs.</data>
  <data key="d2">1</data>
</node>
<node id="LACK OF SAVINGS">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">A situation where an individual perceives they do not have sufficient funds available to put aside for future goals or emergencies.</data>
  <data key="d2">1</data>
</node>
<node id="FINAL EXPENSES">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">Costs associated with one's own death, such as funeral arrangements, which should be planned for in advance.</data>
  <data key="d2">2</data>
</node>
<node id="COLLEGE TUITION">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">The cost of academic instruction for higher education, often a significant financial goal for parents.</data>
  <data key="d2">2</data>
</node>
<node id="DREAMS">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">Aspirational and usually vague desires that individuals hold, which can serve as the foundation for setting more specific goals.</data>
  <data key="d2">3</data>
</node>
<node id="MARRIAGE">
  <data key="d0">EVENT</data>
  <data key="d1">A planned life event that often involves financial implications and requires saving in advance.</data>
  <data key="d2">1</data>
</node>
<node id="SEPARATION">
  <data key="d0">EVENT</data>
  <data key="d1">An unplanned life event marking the formal or informal end of a marital or partnership relationship, often with financial consequences.</data>
  <data key="d2">1</data>
</node>
<node id="DIVORCE">
  <data key="d0">EVENT</data>
  <data key="d1">The legal dissolution of a marriage, a life event that can necessitate a reassessment of life insurance needs due to changed financial and family situations.</data>
  <data key="d2">2</data>
</node>
<node id="WIDOWHOOD">
  <data key="d0">EVENT</data>
  <data key="d1">The state of having lost one's spouse to death, an unplanned life event requiring financial adjustment.</data>
  <data key="d2">1</data>
</node>
<node id="BIRTH OF A CHILD">
  <data key="d0">EVENT</data>
  <data key="d1">A planned or unplanned life event that involves significant financial planning and expenses.</data>
  <data key="d2">1</data>
</node>
<node id="ADOPTION OF A CHILD">
  <data key="d0">EVENT</data>
  <data key="d1">A planned life event involving the legal process of becoming a parent to a child, requiring financial foresight.</data>
  <data key="d2">1</data>
</node>
<node id="LANDMARK BIRTHDAY">
  <data key="d0">EVENT</data>
  <data key="d1">A significant celebratory event that may require financial planning for expenses.</data>
  <data key="d2">1</data>
</node>
<node id="ANNIVERSARY CELEBRATION">
  <data key="d0">EVENT</data>
  <data key="d1">A celebratory event marking a yearly recurrence, often requiring financial planning.</data>
  <data key="d2">1</data>
</node>
<node id="ACCOMPLISHMENT CELEBRATION">
  <data key="d0">EVENT</data>
  <data key="d1">A celebratory event marking a significant achievement, which may require financial planning.</data>
  <data key="d2">1</data>
</node>
<node id="RITE OF PASSAGE">
  <data key="d0">EVENT</data>
  <data key="d1">A ceremony or event marking an important stage in someone's life, which may involve financial preparation.</data>
  <data key="d2">1</data>
</node>
<node id="ILLNESS">
  <data key="d0">EVENT</data>
  <data key="d1">An unplanned life event (type of risk) that can incur significant medical or living expenses and requires advanced financial planning.</data>
  <data key="d2">2</data>
</node>
<node id="SHORT- OR LONG-TERM DISABILITY">
  <data key="d0">EVENT</data>
  <data key="d1">An unplanned life event (type of risk) that impairs an individual's ability to work, potentially leading to loss of income and requiring financial planning.</data>
  <data key="d2">1</data>
</node>
<node id="LOSS OF A JOB">
  <data key="d0">EVENT</data>
  <data key="d1">An unplanned life event (type of risk) involving unemployment, which can create a financial gap if not adequately covered by unemployment benefits or savings.</data>
  <data key="d2">1</data>
</node>
<node id="DEATH OF A FAMILY MEMBER">
  <data key="d0">EVENT</data>
  <data key="d1">An unplanned life event (type of risk) that can bring emotional and financial challenges, including funeral expenses and adjustment to changed household finances.</data>
  <data key="d2">1</data>
</node>
<node id="SETTING SMART GOALS (TOOL)">
  <data key="d0">ACTION</data>
  <data key="d1">A tool and process within the toolkit for identifying goals that are Specific, Measurable, Achievable, Relevant, and Time-bound.</data>
  <data key="d2">1</data>
</node>
<node id="PUTTING GOALS INTO ACTION (TOOL)">
  <data key="d0">ACTION</data>
  <data key="d1">A tool within the toolkit used to create a concrete plan and steps necessary to achieve identified goals.</data>
  <data key="d2">1</data>
</node>
<node id="PLANNING FOR LIFE EVENTS AND LARGE PURCHASES (TOOL)">
  <data key="d0">ACTION</data>
  <data key="d1">A tool within the toolkit designed to help individuals develop strategies to pay for significant life events and large purchases.</data>
  <data key="d2">1</data>
</node>
<node id="REVISING GOALS (HANDOUT)">
  <data key="d0">ACTION</data>
  <data key="d1">A handout within the toolkit used to update or modify existing goals as circumstances change or progress is made.</data>
  <data key="d2">1</data>
</node>
<node id="READJUSTING GOALS">
  <data key="d0">ACTION</data>
  <data key="d1">The process of modifying or changing established objectives as needed to adapt to new circumstances or progress.</data>
  <data key="d2">1</data>
</node>
<node id="REEVALUATING PLANS">
  <data key="d0">ACTION</data>
  <data key="d1">The process of reassessing and modifying strategies or actions designed to achieve goals, ensuring they remain effective and relevant.</data>
  <data key="d2">1</data>
</node>
<node id="CREDIT ACCOUNTS">
  <data key="d0">FINANCIAL_PRODUCT</data>
  <data key="d1">General term for accounts that allow a consumer to borrow money, such as credit cards or loans, subject to a credit limit.</data>
  <data key="d2">3</data>
</node>
<node id="ACCOUNT STATEMENT">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">A document provided by lenders, such as credit card companies, that may include a free credit score.</data>
  <data key="d2">1</data>
</node>
<node id="ONLINE ACCOUNT">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">A digital platform or access point provided by a card issuer where users can manage their financial product, check balances, or perform other transactions online.</data>
  <data key="d2">2</data>
</node>
<node id="THIRD PARTY">
  <data key="d0">ORGANIZATION</data>
  <data key="d1">Any entity, besides banks and lenders, that may use credit scores to assess an individual's creditworthiness.</data>
  <data key="d2">1</data>
</node>
<node id="CREDIT QUALITY">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">An assessment of an individual's ability to manage credit, as viewed by creditors.</data>
  <data key="d2">1</data>
</node>
<node id="CREDIT STANDING">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">An individual's overall status or position regarding their credit, which a credit score indicates.</data>
  <data key="d2">1</data>
</node>
<node id="EXPERTS">
  <data key="d0">PERSON</data>
  <data key="d1">Individuals who provide advice on financial topics, such as credit utilization rates.</data>
  <data key="d2">1</data>
</node>
<node id="REVOLVING CREDIT ACCOUNTS">
  <data key="d0">FINANCIAL_PRODUCT</data>
  <data key="d1">A type of credit account that allows for continuous borrowing up to a preset limit, with payments based on the outstanding balance, typically exemplified by credit cards.</data>
  <data key="d2">2</data>
</node>
<node id="NONPROFIT COUNSELORS">
  <data key="d0">ORGANIZATION</data>
  <data key="d1">Organizations that provide financial guidance and educational services to consumers, including help with accessing credit scores and reports.</data>
  <data key="d2">2</data>
</node>
<node id="TREATMENTS">
  <data key="d0">ACTION</data>
  <data key="d1">Medical procedures or services received by an individual, often incurring costs that may be covered by financial assistance.</data>
  <data key="d2">1</data>
</node>
<node id="CREDIT CARD BALANCE">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">The outstanding amount of money owed on a credit card account, which is used in the calculation of credit utilization rate.</data>
  <data key="d2">4</data>
</node>
<node id="PAYING OFF CREDIT CARD IMMEDIATELY">
  <data key="d0">ACTION</data>
  <data key="d1">The action of settling the entire outstanding balance of a credit card without delay to avoid interest charges.</data>
  <data key="d2">1</data>
</node>
<node id="MEDICAL CHARGES">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">Individual costs or fees for specific medical services or items, which contribute to a total medical bill.</data>
  <data key="d2">1</data>
</node>
<node id="EVALUATING LOAN APPLICATIONS">
  <data key="d0">ACTION</data>
  <data key="d1">The process by which creditors assess the creditworthiness of an applicant and the viability of a loan request, considering factors like existing debt.</data>
  <data key="d2">1</data>
</node>
<node id="CAREERONESTOP.ORG">
  <data key="d0">ORGANIZATION</data>
  <data key="d1">CareerOneStop.org is a website sponsored by the U.S. Department of Labor that provides tools and resources for career exploration, training, and job searching.</data>
  <data key="d2">3</data>
</node>
<node id="PLANNING FOR RETIREMENT TOOL">
  <data key="d0">FINANCIAL_PRODUCT</data>
  <data key="d1">A tool provided by the CFPB at consumerfinance.gov/consumer-tools/retirement/before-you-claim that helps individuals understand how their Social Security payments will grow each year that they delay claiming.</data>
  <data key="d2">2</data>
</node>
<node id="SUPPLEMENTAL NUTRITION ASSISTANCE PROGRAM (SNAP)">
  <data key="d0">FINANCIAL_PRODUCT</data>
  <data key="d1">A program designed to help with groceries and household expenses, subject to an asset limit, with information available via fns.usda.gov.</data>
  <data key="d2">7</data>
</node>
<node id="MEDICAID">
  <data key="d0">FINANCIAL_PRODUCT</data>
  <data key="d1">A federal and state program that provides health coverage to low-income Americans, including children, pregnant women, the elderly, and people with disabilities.</data>
  <data key="d2">7</data>
</node>
<node id="GOVERNMENT BENEFITS CARDS">
  <data key="d0">FINANCIAL_PRODUCT</data>
  <data key="d1">Prepaid cards arranged by a government agency for distributing benefits, which may be a mandated method of payment for certain programs.</data>
  <data key="d2">2</data>
</node>
<node id="VETERANS' BENEFITS">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">Financial assistance provided by the government to veterans, which may be exempt from garnishment with additional protections if directly deposited into a bank account.</data>
  <data key="d2">4</data>
</node>
<node id="COMMUNITY COLLEGES">
  <data key="d0">ORGANIZATION</data>
  <data key="d1">Community colleges are post-secondary educational institutions that offer associate degrees and vocational training, often serving local communities.</data>
  <data key="d2">3</data>
</node>
<node id="CHOOSING HOW TO GET PAID TOOL">
  <data key="d0">FINANCIAL_PRODUCT</data>
  <data key="d1">A tool designed to help individuals understand the pros and cons of different methods of receiving income and managing associated costs.</data>
  <data key="d2">3</data>
</node>
<node id="SERVICE LOCATOR">
  <data key="d0">FINANCIAL_PRODUCT</data>
  <data key="d1">A tool available on careeronestop.org that helps individuals find local career and workforce development services and assistance.</data>
  <data key="d2">1</data>
</node>
<node id="STATE CAREER OR WORKFORCE DEVELOPMENT WEBSITE">
  <data key="d0">ORGANIZATION</data>
  <data key="d1">A website provided by a state government offering online assessments, links to in-person and online training, and other resources for career and workforce development.</data>
  <data key="d2">2</data>
</node>
<node id="ONLINE ASSESSMENTS">
  <data key="d0">FINANCIAL_PRODUCT</data>
  <data key="d1">Tools available on state career websites and through community colleges designed to evaluate an individual's interests and skills for career planning.</data>
  <data key="d2">1</data>
</node>
<node id="IN-PERSON TRAINING">
  <data key="d0">ACTION</data>
  <data key="d1">Educational or skill-building programs conducted face-to-face, offered as a resource for workforce development by state websites and community colleges.</data>
  <data key="d2">1</data>
</node>
<node id="ONLINE TRAINING">
  <data key="d0">ACTION</data>
  <data key="d1">Educational or skill-building programs delivered virtually, offered as a resource for workforce development by state websites and community colleges.</data>
  <data key="d2">1</data>
</node>
<node id="INCREASING INCOME">
  <data key="d0">ACTION</data>
  <data key="d1">The objective of financial strategies, such as optimizing Social Security claiming, to boost an individual's earnings and financial well-being.</data>
  <data key="d2">1</data>
</node>
<node id="CLAIMING SOCIAL SECURITY">
  <data key="d0">ACTION</data>
  <data key="d1">The process and decision of when to apply for and begin receiving Social Security retirement benefits, which is a significant financial decision.</data>
  <data key="d2">2</data>
</node>
<node id="RETIREMENT AGE">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">The typical age at which individuals consider ending their working careers and becoming eligible for retirement benefits like Social Security.</data>
  <data key="d2">2</data>
</node>
<node id="SOCIAL SECURITY RETIREMENT BENEFITS">
  <data key="d0">FINANCIAL_PRODUCT</data>
  <data key="d1">Monthly payments from the Social Security Administration designed to provide income to retirees, with the amount influenced by claiming age.</data>
  <data key="d2">2</data>
</node>
<node id="FINANCIAL DECISION">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">A choice or judgment concerning money management and economic well-being, such as deciding when to claim Social Security benefits.</data>
  <data key="d2">2</data>
</node>
<node id="PRIMARY SOURCE OF INCOME">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">The main or most significant contributor to an individual's or household's total income, often becoming Social Security in later life.</data>
  <data key="d2">1</data>
</node>
<node id="MEDICAL AND HEALTH COSTS">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">Expenses incurred for healthcare services, treatments, and medications, which often increase significantly in later life.</data>
  <data key="d2">2</data>
</node>
<node id="ELIGIBILITY AGE (62)">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">The earliest age (62) at which individuals can begin receiving reduced Social Security retirement benefits.</data>
  <data key="d2">1</data>
</node>
<node id="AGE 70">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">The age (70) at which delaying Social Security retirement benefits results in the maximum possible monthly payment amount due to delayed retirement credits.</data>
  <data key="d2">1</data>
</node>
<node id="HEALTH">
  <data key="d0">RISK</data>
  <data key="d1">A personal factor and potential risk (e.g., poor health leading to higher medical costs) that influences the strategic decision of when to claim Social Security.</data>
  <data key="d2">2</data>
</node>
<node id="OTHER SOURCES OF INCOME">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">Any income streams an individual has in addition to Social Security or public benefits, considered when making financial decisions for retirement.</data>
  <data key="d2">1</data>
</node>
<node id="LIFE EXPECTANCY">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">The statistical estimate of how long a person is expected to live, a crucial factor in retirement planning and deciding when to claim Social Security.</data>
  <data key="d2">1</data>
</node>
<node id="LOCAL GOVERNMENT AGENCIES">
  <data key="d0">ORGANIZATION</data>
  <data key="d1">Administrative bodies at the municipal or county level that may provide public benefits to residents within their jurisdiction.</data>
  <data key="d2">1</data>
</node>
<node id="STATE GOVERNMENT AGENCIES">
  <data key="d0">ORGANIZATION</data>
  <data key="d1">Administrative bodies at the state level that may provide public benefits and regulate various aspects, including employment practices and payment methods.</data>
  <data key="d2">1</data>
</node>
<node id="TRIBAL GOVERNMENT AGENCIES">
  <data key="d0">ORGANIZATION</data>
  <data key="d1">Governmental bodies of federally recognized Native American tribes that may provide public benefits to their members.</data>
  <data key="d2">1</data>
</node>
<node id="FEDERAL GOVERNMENT AGENCIES">
  <data key="d0">ORGANIZATION</data>
  <data key="d1">Administrative bodies at the national level responsible for federal programs and the distribution of federal benefits.</data>
  <data key="d2">1</data>
</node>
<node id="BASIC LIVING EXPENSES">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">Fundamental costs necessary for survival, such as housing, food, and utilities, which public benefits are often designed to help cover.</data>
  <data key="d2">1</data>
</node>
<node id="ASSETS">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">Items of value owned by an individual, including money in accounts, cars, homes, business inventory, and land, which may count towards eligibility for public benefits.</data>
  <data key="d2">6</data>
</node>
<node id="VEHICLE">
  <data key="d0">FINANCIAL_PRODUCT</data>
  <data key="d1">An automobile or other form of transportation, considered an asset when determining eligibility for public benefits.</data>
  <data key="d2">1</data>
</node>
<node id="INVESTMENTS">
  <data key="d0">FINANCIAL_PRODUCT</data>
  <data key="d1">Assets or schemes acquired with the expectation of generating income or appreciation, often promised with high returns and little risk in scams.</data>
  <data key="d2">4</data>
</node>
<node id="DEPENDENTS">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">Individuals, such as spouses and children, who rely on the income and support of an active duty servicemember and are also covered by the Military Lending Act.</data>
  <data key="d2">2</data>
</node>
<node id="GROCERIES">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">Food and household items purchased for consumption, which benefits from programs like SNAP are specifically designated to cover.</data>
  <data key="d2">7</data>
</node>
<node id="QUALIFIED HEALTH EXPENSES">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">Specific medical costs that meet the criteria for coverage under health programs like Medicaid, ensuring only certain expenses are paid.</data>
  <data key="d2">1</data>
</node>
<node id="CAR REPAIRS">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">The cost of maintaining or fixing a vehicle, an example of a living expense not usually covered by public benefits but can be paid with freed-up cash.</data>
  <data key="d2">3</data>
</node>
<node id="CELL PHONE SERVICE">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">The recurring cost for mobile communication services, an example of a living expense not usually covered by public benefits but can be paid with freed-up cash.</data>
  <data key="d2">1</data>
</node>
<node id="WRITTEN CONSENT">
  <data key="d0">ACTION</data>
  <data key="d1">Formal, documented permission from an individual, sometimes required by state law before an employer can pay wages via a payroll card.</data>
  <data key="d2">1</data>
</node>
<node id="UNEMPLOYMENT BENEFITS">
  <data key="d0">FINANCIAL_PRODUCT</data>
  <data key="d1">Financial aid provided to individuals who have lost their jobs, intended to cover income gaps during periods of unemployment.</data>
  <data key="d2">2</data>
</node>
<node id="FEDERALLY INSURED PREPAID CARD">
  <data key="d0">FINANCIAL_PRODUCT</data>
  <data key="d1">A prepaid card where the funds are protected by a federal insurance agency (e.g., FDIC), offering security for deposited benefits.</data>
  <data key="d2">1</data>
</node>
<node id="MANAGE INCOME">
  <data key="d0">ACTION</data>
  <data key="d1">The activity of organizing, budgeting, and making informed decisions about how to use one's financial earnings and resources effectively.</data>
  <data key="d2">1</data>
</node>
<node id="PHONE NUMBER">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">A contact number provided on prepaid cards and in cardholder agreements for customer service or support in case of card issues.</data>
  <data key="d2">1</data>
</node>
<node id="CARD NUMBER">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">The unique identification number printed on a payment card, essential for transactions and security purposes.</data>
  <data key="d2">2</data>
</node>
<node id="CHECKING ACCOUNT FEES">
  <data key="d0">RISK</data>
  <data key="d1">Specific charges associated with checking accounts that the toolkit provides tools to help avoid.</data>
  <data key="d2">1</data>
</node>
<node id="COMMUNITY-BASED ORGANIZATIONS">
  <data key="d0">ORGANIZATION</data>
  <data key="d1">Types of organizations that use the toolkit to provide financial assistance and guidance to people living with low incomes within their communities.</data>
  <data key="d2">1</data>
</node>
<node id="PRIVATE SECTOR ORGANIZATIONS">
  <data key="d0">ORGANIZATION</data>
  <data key="d1">Types of organizations that use the toolkit to provide financial assistance and guidance to people living with low incomes.</data>
  <data key="d2">1</data>
</node>
<node id="LUMP-SUM PAYMENT">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">A single, large payment due at one time, requiring prior saving.</data>
  <data key="d2">1</data>
</node>
<node id="SCHOOL TUITION">
  <data key="d0">FINANCIAL_PRODUCT</data>
  <data key="d1">The fee charged by an educational institution for instruction, often a large lump-sum or periodic payment.</data>
  <data key="d2">3</data>
</node>
<node id="TAX">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">A compulsory financial contribution levied by a government, typically withheld from paychecks.</data>
  <data key="d2">1</data>
</node>
<node id="ALLOWANCES (EXEMPTIONS)">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">Numbers selected on tax forms (e.g., W-4) that determine how much income tax is withheld from a paycheck; also known as exemptions.</data>
  <data key="d2">1</data>
</node>
<node id="IRS.GOV/INDIVIDUALS/IRS-WITHHOLDING-CALCULATOR">
  <data key="d0">FINANCIAL_PRODUCT</data>
  <data key="d1">An online tool provided by the IRS to help individuals estimate and adjust their income tax withholding.</data>
  <data key="d2">1</data>
</node>
<node id="DEBT CONSOLIDATION">
  <data key="d0">ACTION</data>
  <data key="d1">The strategy of combining multiple debts into a single, new loan, often to simplify payments or reduce interest rates.</data>
  <data key="d2">1</data>
</node>
<node id="CONSUMERFINANCE.GOV/ASKCFPB/1451">
  <data key="d0">FINANCIAL_PRODUCT</data>
  <data key="d1">An online resource from the CFPB that helps individuals find and contact certified credit counselors.</data>
  <data key="d2">1</data>
</node>
<node id="HOME REFINANCING">
  <data key="d0">ACTION</data>
  <data key="d1">The process of replacing an existing home loan with a new one, often to secure a lower interest rate, change loan terms, or access home equity.</data>
  <data key="d2">1</data>
</node>
<node id="LOAN MODIFICATION">
  <data key="d0">ACTION</data>
  <data key="d1">The act of a private lender changing the terms of a loan based on a borrower's financial circumstances, often on a case-by-case basis.</data>
  <data key="d2">2</data>
</node>
<node id="HOME LOAN">
  <data key="d0">FINANCIAL_PRODUCT</data>
  <data key="d1">A general term for a loan taken out to purchase or refinance a residential property.</data>
  <data key="d2">1</data>
</node>
<node id="CONSUMERFINANCE.GOV/OWNING-A-HOME">
  <data key="d0">FINANCIAL_PRODUCT</data>
  <data key="d1">An online resource from the CFPB offering guidance and information on choosing and managing home loans.</data>
  <data key="d2">1</data>
</node>
<node id="CAR SALE">
  <data key="d0">ACTION</data>
  <data key="d1">The act of selling a vehicle, often undertaken to reduce auto loan payments or overall cost of ownership.</data>
  <data key="d2">1</data>
</node>
<node id="AUTO LOAN PAYMENTS">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">Regular payments made to repay a loan used to finance the purchase of an automobile.</data>
  <data key="d2">1</data>
</node>
<node id="COST OF OWNERSHIP">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">The total financial outlay associated with possessing and maintaining an asset, like a car, including purchase price, insurance, fuel, and maintenance.</data>
  <data key="d2">1</data>
</node>
<node id="FUEL">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">The cost of gasoline or other energy sources required for vehicle operation, contributing to the cost of ownership.</data>
  <data key="d2">1</data>
</node>
<node id="MAINTENANCE">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">The expenses associated with routine upkeep and repairs of an asset, such as a car, affecting its cost of ownership.</data>
  <data key="d2">1</data>
</node>
<node id="AUTO LOAN REFINANCING">
  <data key="d0">ACTION</data>
  <data key="d1">The process of replacing an existing auto loan with a new one, typically to obtain a lower interest rate or reduce monthly payments.</data>
  <data key="d2">1</data>
</node>
<node id="AUTO LOANS">
  <data key="d0">FINANCIAL_PRODUCT</data>
  <data key="d1">A type of secured loan taken out to purchase a car, where the car serves as collateral. The lender can repossess the car if payments are not made.</data>
  <data key="d2">4</data>
</node>
<node id="CONSUMERFINANCE.GOV/CONSUMER-TOOLS/AUTO-LOANS">
  <data key="d0">FINANCIAL_PRODUCT</data>
  <data key="d1">An online resource from the CFPB providing tools and information to help consumers shop for and compare auto loans.</data>
  <data key="d2">1</data>
</node>
<node id="STUDENT LOAN PAYMENT">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">Regular payments required to repay money borrowed for educational expenses.</data>
  <data key="d2">1</data>
</node>
<node id="INCOME-BASED REPAYMENT PLAN">
  <data key="d0">FINANCIAL_PRODUCT</data>
  <data key="d1">A student loan repayment option that adjusts monthly payments based on the borrower's income and family size.</data>
  <data key="d2">1</data>
</node>
<node id="ADJUSTING CASH FLOW">
  <data key="d0">ACTION</data>
  <data key="d1">The strategic modification of income and expenses to create a better balance between money coming in and money going out.</data>
  <data key="d2">1</data>
</node>
<node id="DUE DATES OF BILLS">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">The specific calendar dates by which financial obligations, such as loan payments or utility bills, must be paid.</data>
  <data key="d2">1</data>
</node>
<node id="PERIODIC BILLS">
  <data key="d0">FINANCIAL_PRODUCT</data>
  <data key="d1">Recurring financial obligations that are due at regular intervals, such as monthly utility bills or annual insurance premiums.</data>
  <data key="d2">1</data>
</node>
<node id="IMPROVING CASH FLOW TOOL">
  <data key="d0">FINANCIAL_PRODUCT</data>
  <data key="d1">A specific interactive tool that helps users brainstorm and identify practical strategies and habits to achieve and maintain a positive cash flow position.</data>
  <data key="d2">3</data>
</node>
<node id="CREDIT UTILIZATION">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">The ratio of an individual's current outstanding credit card balances to their total available credit limits, expressed as a percentage.</data>
  <data key="d2">1</data>
</node>
<node id="TOTAL CREDIT LIMIT">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">The sum of all available credit across all of an individual's credit accounts.</data>
  <data key="d2">1</data>
</node>
<node id="POOR PAYMENT HISTORY">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">A record indicating a pattern of late or missed payments for financial obligations, negatively affecting creditworthiness.</data>
  <data key="d2">1</data>
</node>
<node id="CREDIT SCORING MODELS">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">Algorithms or methodologies used to evaluate and assign numerical credit scores to consumers, which consider factors like how recently and frequently a person applies for credit.</data>
  <data key="d2">2</data>
</node>
<node id="RECENT CREDIT ACTIVITY">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">The recent history of an individual's credit applications, new accounts, and changes in credit balances, which lenders use to assess credit need.</data>
  <data key="d2">1</data>
</node>
<node id="ECONOMIC CIRCUMSTANCES">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">The overall financial situation of an individual or entity, encompassing income, assets, debts, and spending habits.</data>
  <data key="d2">1</data>
</node>
<node id="BANKRUPTCIES">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">A legal status indicating a person or entity cannot repay debts, often leading to asset liquidation or financial reorganization, and which negatively affects credit.</data>
  <data key="d2">2</data>
</node>
<node id="EVICTIONS">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">The forced removal of a tenant from a rental property, often due to unpaid rent, which can negatively impact future housing and credit assessments.</data>
  <data key="d2">1</data>
</node>
<node id="MONTHLY PAYMENTS">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">Regular, recurring payments, such as those for car insurance, that can be influenced by financial decisions like deductible changes.</data>
  <data key="d2">3</data>
</node>
<node id="MODULE 7">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">A specific section or unit within a larger document or toolkit (like 'Your Money, Your Goals Toolkit') that contains tools or information related to credit reports.</data>
  <data key="d2">3</data>
</node>
<node id="LOAN BILLS">
  <data key="d0">FINANCIAL_PRODUCT</data>
  <data key="d1">Statements requesting payment for money borrowed, usually from a bank or financial institution.</data>
  <data key="d2">1</data>
</node>
<node id="CREDIT REPORTING COMPANY">
  <data key="d0">ORGANIZATION</data>
  <data key="d1">An organization that collects and maintains credit information on consumers and provides credit reports. They are responsible for investigating disputes regarding incorrect information on credit reports.</data>
  <data key="d2">5</data>
</node>
<node id="FURNISHER">
  <data key="d0">ORGANIZATION</data>
  <data key="d1">A business or individual that provides credit information about consumers to credit reporting companies. They are responsible for correcting inaccurate information they reported if an error is found.</data>
  <data key="d2">2</data>
</node>
<node id="MISSING BILL PAYMENTS">
  <data key="d0">RISK</data>
  <data key="d1">Failing to pay financial obligations by their due dates, which can negatively impact credit scores and lead to debt collection.</data>
  <data key="d2">1</data>
</node>
<node id="MAXING OUT CREDIT CARDS">
  <data key="d0">RISK</data>
  <data key="d1">Reaching or exceeding the maximum credit limit on a credit card, which can severely harm credit scores by increasing credit utilization.</data>
  <data key="d2">1</data>
</node>
<node id="INCREASING CREDIT UTILIZATION">
  <data key="d0">RISK</data>
  <data key="d1">The act of raising the proportion of available credit that is being used, which can negatively impact credit scores.</data>
  <data key="d2">1</data>
</node>
<node id="NEGATIVE INFORMATION ON CREDIT REPORTS">
  <data key="d0">RISK</data>
  <data key="d1">Derogatory entries on a credit report, such as late payments, defaults, judgments, bankruptcies, or evictions, which significantly harm creditworthiness.</data>
  <data key="d2">1</data>
</node>
<node id="BUILDING A STRONG CREDIT HISTORY">
  <data key="d0">ACTION</data>
  <data key="d1">The act of establishing a positive credit record through responsible financial habits, such as on-time payments and low credit utilization.</data>
  <data key="d2">1</data>
</node>
<node id="IMPROVING YOUR EXISTING CREDIT HISTORY">
  <data key="d0">ACTION</data>
  <data key="d1">The process of taking steps to enhance a pre-existing credit record, typically by correcting negative behaviors and adopting positive ones.</data>
  <data key="d2">1</data>
</node>
<node id="BUILDING A NEW CREDIT HISTORY">
  <data key="d0">ACTION</data>
  <data key="d1">The initial process of establishing a credit record for individuals with no prior borrowing history.</data>
  <data key="d2">1</data>
</node>
<node id="STRATEGY FOR IMPROVING AND MAINTAINING CREDIT HISTORY">
  <data key="d0">ACTION</data>
  <data key="d1">A planned approach or set of actions designed to enhance and preserve a positive credit record over time.</data>
  <data key="d2">1</data>
</node>
<node id="MONITOR CREDIT SCORE IMPROVEMENT">
  <data key="d0">ACTION</data>
  <data key="d1">The act of regularly checking one's credit score to observe changes and progress resulting from implemented credit strategies.</data>
  <data key="d2">1</data>
</node>
<node id="MAINTAIN A STRONG CREDIT HISTORY">
  <data key="d0">ACTION</data>
  <data key="d1">The ongoing practice of responsible financial habits to preserve a positive and healthy credit record.</data>
  <data key="d2">1</data>
</node>
<node id="DISPUTING ERRORS ON CREDIT REPORTS">
  <data key="d0">ACTION</data>
  <data key="d1">The process of formally challenging inaccuracies or incorrect information found on one's credit reports with credit reporting companies and furnishers.</data>
  <data key="d2">1</data>
</node>
<node id="PAYING BILLS ON TIME">
  <data key="d0">ACTION</data>
  <data key="d1">The act of remitting payments for financial obligations by their due dates, which is crucial for building a positive credit history and improving credit scores.</data>
  <data key="d2">3</data>
</node>
<node id="ELECTRONIC REMINDERS">
  <data key="d0">ACTION</data>
  <data key="d1">Digital notifications, such as email or app alerts, used to prompt individuals about upcoming payment due dates.</data>
  <data key="d2">1</data>
</node>
<node id="GET CURRENT AND STAY CURRENT">
  <data key="d0">ACTION</data>
  <data key="d1">The act of bringing overdue accounts up to date and continuing to make timely payments thereafter to avoid further negative impact.</data>
  <data key="d2">1</data>
</node>
<node id="SPENDING UNDER CREDIT LIMIT">
  <data key="d0">ACTION</data>
  <data key="d1">The practice of keeping credit card balances significantly below the maximum allowed credit limit to positively influence credit scores.</data>
  <data key="d2">1</data>
</node>
<node id="KEEP BALANCES LOW">
  <data key="d0">ACTION</data>
  <data key="d1">The practice of maintaining a small outstanding debt relative to the total available credit to improve credit utilization.</data>
  <data key="d2">1</data>
</node>
<node id="CLOSING CREDIT CARD ACCOUNTS">
  <data key="d0">ACTION</data>
  <data key="d1">The act of formally terminating credit card accounts with the issuing financial institution, which can affect total credit limit and utilization.</data>
  <data key="d2">1</data>
</node>
<node id="LEAVE CREDIT CARDS OPEN">
  <data key="d0">ACTION</data>
  <data key="d1">The practice of maintaining active credit card accounts, even if not regularly used, to preserve or increase total available credit and improve credit utilization.</data>
  <data key="d2">1</data>
</node>
<node id="PAYING OFF CREDIT CARD BALANCE ON TIME">
  <data key="d0">ACTION</data>
  <data key="d1">The practice of remitting the full outstanding amount owed on a credit card by the due date each month to avoid interest and build good credit.</data>
  <data key="d2">1</data>
</node>
<node id="TEXT ALERT REMINDERS">
  <data key="d0">ACTION</data>
  <data key="d1">Short Message Service (SMS) notifications used to remind individuals about upcoming bill due dates.</data>
  <data key="d2">1</data>
</node>
<node id="APPLYING FOR CREDIT">
  <data key="d0">ACTION</data>
  <data key="d1">The act of formally submitting a request to a lender for a new credit account, which typically results in a hard inquiry on a credit report.</data>
  <data key="d2">2</data>
</node>
<node id="SUBMITTING A DISPUTE">
  <data key="d0">ACTION</data>
  <data key="d1">The act of formally challenging inaccurate or incomplete information on a credit report with the relevant credit reporting company and data furnisher.</data>
  <data key="d2">1</data>
</node>
<node id="REPAYING FEDERAL STUDENT LOANS">
  <data key="d0">ACTION</data>
  <data key="d1">The process of making scheduled payments on federal student loans, with various options available to make them more affordable.</data>
  <data key="d2">1</data>
</node>
<node id="GOOD STANDING">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">The status of a loan when payments are made on time, which is important for qualifying for alternative repayment plans and avoiding negative credit impact.</data>
  <data key="d2">1</data>
</node>
<node id="PAYMENT SCHEDULE">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">The structured timeline detailing when and how much a borrower is required to pay towards a loan, under which payments must continue until an alternative is approved.</data>
  <data key="d2">1</data>
</node>
<node id="ALTERNATIVE LOANS">
  <data key="d0">FINANCIAL_PRODUCT</data>
  <data key="d1">A common term for private student loans, indicating they are not federal loans and may have different terms.</data>
  <data key="d2">2</data>
</node>
<node id="INSTITUTIONAL LOANS">
  <data key="d0">FINANCIAL_PRODUCT</data>
  <data key="d1">A name that some private student loans may have, often indicating they are made by a school or other institution.</data>
  <data key="d2">2</data>
</node>
<node id="BORROWER PROTECTIONS">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">Safeguards or benefits provided to borrowers, which are generally more limited for private student loans compared to federal student loans.</data>
  <data key="d2">1</data>
</node>
<node id="REPAYING PRIVATE STUDENT LOANS">
  <data key="d0">ACTION</data>
  <data key="d1">The process of making scheduled payments on private student loans, with generally more limited options than for federal loans, requiring communication with the loan servicer in case of difficulty.</data>
  <data key="d2">1</data>
</node>
<node id="UNPAID STUDENT LOANS">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">Student loans for which payments are not being made, leading to specific collection methods for federal loans and regular debt collection practices for private loans.</data>
  <data key="d2">1</data>
</node>
<node id="DEBT COLLECTION PRACTICES">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">The methods used by debt collectors to recover unpaid debts, which differ for federal and private student loans.</data>
  <data key="d2">1</data>
</node>
<node id="WAGE GARNISHMENT">
  <data key="d0">ACTION</data>
  <data key="d1">A legal process where a creditor obtains a court order to compel an employer to take part of an employee's paycheck and send it directly to the creditor to repay unpaid debts.</data>
  <data key="d2">3</data>
</node>
<node id="MODULE 6">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">A specific section or unit within a larger document or toolkit (like 'Your Money, Your Goals Toolkit') dedicated to information and strategies for dealing with debt.</data>
  <data key="d2">3</data>
</node>
<node id="EXEMPT FEDERAL BENEFITS">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">Federal benefits that cannot be garnished by debt collectors or private student loan collectors, distinguishing them from other federal benefits that the Department of Education can garnish.</data>
  <data key="d2">1</data>
</node>
<node id="PRIVATE STUDENT LOAN COLLECTORS">
  <data key="d0">PERSON</data>
  <data key="d1">Individuals or entities specifically tasked with collecting unpaid private student loans, who cannot garnish exempt federal benefits but can report bad debt and sue in court.</data>
  <data key="d2">2</data>
</node>
<node id="CONSUMERFINANCE.GOV/PAYING-FOR-COLLEGE">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">A specific section of the CFPB's website dedicated to helping people plan for education and training after high school, offering tools and resources.</data>
  <data key="d2">1</data>
</node>
<node id="ELECTRONIC PAY">
  <data key="d0">ACTION</data>
  <data key="d1">A method of payment where wages are transferred electronically, such as via direct deposit or payroll card, as opposed to a paper check.</data>
  <data key="d2">1</data>
</node>
<node id="CARD BALANCE">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">The current amount of money available on a prepaid card, which users are advised to check to avoid decline fees.</data>
  <data key="d2">1</data>
</node>
<node id="TRANSACTION FEES">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">Charges applied per individual transaction made using a card, which can be an alternative to a monthly fee plan.</data>
  <data key="d2">1</data>
</node>
<node id="MONTHLY FEE PLAN">
  <data key="d0">FINANCIAL_CONCEPT</data>
