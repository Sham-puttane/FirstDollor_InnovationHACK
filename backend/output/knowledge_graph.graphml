  <data key="d0">ORGANIZATION</data>
  <data key="d1">An office under the Department of Housing and Urban Development that provides information about public housing and eligibility.</data>
  <data key="d2">1</data>
</node>
<node id="AMERICAN JOB CENTERS">
  <data key="d0">ORGANIZATION</data>
  <data key="d1">Organizations that assist with job searching and provide information about requirements for different careers.</data>
  <data key="d2">1</data>
</node>
<node id="NATIONAL FOUNDATION FOR CREDIT COUNSELING (NFCC)">
  <data key="d0">ORGANIZATION</data>
  <data key="d1">An organization that provides services for debt management.</data>
  <data key="d2">1</data>
</node>
<node id="LEGAL SERVICES CORPORATION">
  <data key="d0">ORGANIZATION</data>
  <data key="d1">An organization that funds Legal Services programs providing legal assistance.</data>
  <data key="d2">1</data>
</node>
<node id="PUBLIC HOUSING">
  <data key="d0">FINANCIAL_PRODUCT</data>
  <data key="d1">Government-supported housing assistance programs designed to provide affordable living arrangements for eligible low-income individuals and families.</data>
  <data key="d2">5</data>
</node>
<node id="LEGAL SERVICES PROGRAM">
  <data key="d0">FINANCIAL_PRODUCT</data>
  <data key="d1">A program offering legal assistance, funded by the Legal Services Corporation.</data>
  <data key="d2">1</data>
</node>
<node id="CHIP PROGRAMS">
  <data key="d0">FINANCIAL_PRODUCT</data>
  <data key="d1">Children's Health Insurance Program, a state and federal program providing health coverage for children, with information available at medicaid.gov.</data>
  <data key="d2">1</data>
</node>
<node id="SHIP PROGRAMS">
  <data key="d0">FINANCIAL_PRODUCT</data>
  <data key="d1">State Health Insurance Assistance Programs that provide local help with Medicare.</data>
  <data key="d2">1</data>
</node>
<node id="STUDENT DEBT">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">A type of financial obligation related to education, with more information available through the CFPB.</data>
  <data key="d2">1</data>
</node>
<node id="DEBT MANAGEMENT">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">The process of handling and reducing an individual's outstanding debts, supported by organizations like NFCC.</data>
  <data key="d2">1</data>
</node>
<node id="JOB INCOME">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">Money earned from employment.</data>
  <data key="d2">1</data>
</node>
<node id="EDUCATION">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">The process of acquiring knowledge or skills, representing a significant future expense (e.g., children's college) that life insurance can help protect.</data>
  <data key="d2">4</data>
</node>
<node id="HEALTH CARE BILLS">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">Expenses incurred for medical services and treatments.</data>
  <data key="d2">1</data>
</node>
<node id="MONEY QUESTIONS">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">Queries related to personal finance and financial management, for which the CFPB offers resources.</data>
  <data key="d2">2</data>
</node>
<node id="VARIABLE INTEREST RATE">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">An interest rate that can increase or decrease over the life of the loan, common for private student loans.</data>
  <data key="d2">1</data>
</node>
<node id="GRADUATED PAYMENT PLANS">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">A repayment plan offered by some private lenders where payments start low and gradually increase over the loan term.</data>
  <data key="d2">1</data>
</node>
<node id="FORBEARANCE OPTIONS">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">Options offered by private lenders that allow borrowers to temporarily delay some loan payments.</data>
  <data key="d2">1</data>
</node>
<node id="BAD DEBT">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">A financial concept referring to debt often associated with fees and interest, used for consumable items, and not typically building assets, such as credit card debt, short-term loans, and pawn loans.</data>
  <data key="d2">2</data>
</node>
<node id="VETERANS’ ASSISTANCE BENEFITS">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">Specific federal benefits that can be garnished by the Department of Education for unpaid federal student loans.</data>
  <data key="d2">1</data>
</node>
<node id="SCHOOL">
  <data key="d0">ORGANIZATION</data>
  <data key="d1">An educational institution that can be a lender for private student loans and whose permanent closure can lead to loan forgiveness.</data>
  <data key="d2">1</data>
</node>
<node id="LEGAL AID ORGANIZATION">
  <data key="d0">ORGANIZATION</data>
  <data key="d1">An organization providing legal assistance, for example, to individuals considering filing for bankruptcy regarding student loan debt.</data>
  <data key="d2">1</data>
</node>
<node id="BORROWER">
  <data key="d0">PERSON</data>
  <data key="d1">An individual who takes out student loans and is responsible for repaying them, potentially eligible for various repayment plans, forgiveness, or facing consequences for non-payment.</data>
  <data key="d2">5</data>
</node>
<node id="TEACHER">
  <data key="d0">PERSON</data>
  <data key="d1">A professional working full-time in certain educational settings for five complete and consecutive academic years, who may qualify for teacher loan forgiveness.</data>
  <data key="d2">1</data>
</node>
<node id="BANKRUPTCY LAWYER">
  <data key="d0">PERSON</data>
  <data key="d1">A legal professional who advises individuals on the process of filing for bankruptcy, especially concerning student loan debt.</data>
  <data key="d2">1</data>
</node>
<node id="CO-SIGNER">
  <data key="d0">PERSON</data>
  <data key="d1">An individual whose signature may be required to qualify for some private student loans, sharing responsibility for the loan.</data>
  <data key="d2">2</data>
</node>
<node id="LOAN CANCELLATION">
  <data key="d0">EVENT</data>
  <data key="d1">An event where a borrower is no longer expected to repay a loan due to specific circumstances, similar to loan forgiveness or discharge.</data>
  <data key="d2">1</data>
</node>
<node id="LOAN DISCHARGE">
  <data key="d0">EVENT</data>
  <data key="d1">An event where a borrower is no longer expected to repay a loan due to specific circumstances, similar to loan forgiveness or cancellation.</data>
  <data key="d2">1</data>
</node>
<node id="TEACHER LOAN FORGIVENESS">
  <data key="d0">EVENT</data>
  <data key="d1">A specific program allowing teachers to have their federal student loans forgiven under certain employment conditions.</data>
  <data key="d2">1</data>
</node>
<node id="PUBLIC SERVICE LOAN FORGIVENESS">
  <data key="d0">EVENT</data>
  <data key="d1">A program allowing borrowers working in the public service sector (government agency or non-profit) to have Direct Loans forgiven after 120 qualifying payments.</data>
  <data key="d2">1</data>
</node>
<node id="TOTAL AND PERMANENT DISABILITY">
  <data key="d0">EVENT</data>
  <data key="d1">A medical condition that, when confirmed, can lead to the forgiveness or discharge of student loans.</data>
  <data key="d2">1</data>
</node>
<node id="DEATH">
  <data key="d0">EVENT</data>
  <data key="d1">The passing of a borrower, which allows for the loan to be forgiven, cancelled, or discharged on their behalf.</data>
  <data key="d2">1</data>
</node>
<node id="FILING FOR BANKRUPTCY">
  <data key="d0">EVENT</data>
  <data key="d1">The legal process undertaken by an individual who cannot repay their debts; it is generally very difficult to eliminate federal student loan debt through this process.</data>
  <data key="d2">1</data>
</node>
<node id="MISSING PAYMENTS">
  <data key="d0">RISK</data>
  <data key="d1">Failure to make scheduled loan payments, which can hurt a borrower's ability to qualify for alternative repayment plans and lead to collections.</data>
  <data key="d2">1</data>
</node>
<node id="GARNISHMENT">
  <data key="d0">ACTION</data>
  <data key="d1">The act by which the Department of Education can take federal benefits or tax refunds to collect unpaid federal student loan debt without a court order, or by which debt collectors can take wages with a court order.</data>
  <data key="d2">3</data>
</node>
<node id="STATE FARM EDITORIAL TEAM">
  <data key="d0">ORGANIZATION</data>
  <data key="d1">The State Farm Editorial Team is a group responsible for writing and publishing informative content, such as articles on auto insurance deductibles, for State Farm's "Simple Insights" platform.</data>
  <data key="d2">7</data>
</node>
<node id="AUTO FULL COVERAGE">
  <data key="d0">FINANCIAL_PRODUCT</data>
  <data key="d1">Auto full coverage is a common term referring to a combination of auto insurance coverages, typically including liability, collision, and comprehensive coverage, designed to protect individuals and their vehicles in various situations.</data>
  <data key="d2">1</data>
</node>
<node id="BODILY INJURY LIABILITY">
  <data key="d0">FINANCIAL_PRODUCT</data>
  <data key="d1">Bodily Injury Liability is a specific category of auto liability insurance that helps cover medical expenses, pain and suffering, lost wages, and other special damages for third parties injured in an accident where the insured is at fault.</data>
  <data key="d2">2</data>
</node>
<node id="PROPERTY DAMAGE LIABILITY">
  <data key="d0">FINANCIAL_PRODUCT</data>
  <data key="d1">Property Damage Liability is a specific category of auto liability insurance that helps cover costs for damaged property and potential loss of use for third parties affected by an accident where the insured is at fault.</data>
  <data key="d2">2</data>
</node>
<node id="MED PAY">
  <data key="d0">FINANCIAL_PRODUCT</data>
  <data key="d1">Med Pay (Medical Payments coverage) is an optional auto insurance add-on that covers medical expenses for you or your passengers after an accident, regardless of fault.</data>
  <data key="d2">1</data>
</node>
<node id="PERSONAL INJURY PROTECTION">
  <data key="d0">FINANCIAL_PRODUCT</data>
  <data key="d1">Personal Injury Protection (PIP) is an optional auto insurance add-on that covers medical expenses for you and passengers, regardless of fault, often serving a similar purpose to Med Pay.</data>
  <data key="d2">1</data>
</node>
<node id="CAR RENTAL REIMBURSEMENT COVERAGE">
  <data key="d0">FINANCIAL_PRODUCT</data>
  <data key="d1">Car rental reimbursement coverage is an optional auto insurance add-on that covers rental costs while your vehicle is being repaired after a covered claim.</data>
  <data key="d2">1</data>
</node>
<node id="NATURAL DISASTERS">
  <data key="d0">RISK</data>
  <data key="d1">Severe events resulting from natural processes of the Earth, such as hurricanes, earthquakes, or floods, which can cause widespread damage and disruption.</data>
  <data key="d2">2</data>
</node>
<node id="FLOODS">
  <data key="d0">RISK</data>
  <data key="d1">Floods are risks of a vehicle being damaged by water, typically covered under comprehensive auto insurance.</data>
  <data key="d2">1</data>
</node>
<node id="FINANCE">
  <data key="d0">ACTION</data>
  <data key="d1">To finance a car means to obtain funds, often through a loan, to purchase it, which typically results in lenders requiring collision and comprehensive insurance.</data>
  <data key="d2">1</data>
</node>
<node id="CLAIM">
  <data key="d0">ACTION</data>
  <data key="d1">A claim is a formal request made by a policyholder to an insurance company for payment or services under the terms of the insurance policy, often involving a deductible.</data>
  <data key="d2">1</data>
</node>
<node id="TOTALED">
  <data key="d0">EVENT</data>
  <data key="d1">Totaled is the event when a vehicle's repair costs exceed its market value, leading to it being declared a total loss by the insurer, and potentially triggering gap coverage.</data>
  <data key="d2">1</data>
</node>
<node id="PRIORITIES">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">The relative importance assigned to different financial goals and expenditures, shaped by personal background, values, and culture.</data>
  <data key="d2">2</data>
</node>
<node id="TOTAL AMOUNT">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">The full sum that the consumer will pay the remittance transfer provider for a money transfer, including fees and taxes.</data>
  <data key="d2">2</data>
</node>
<node id="LENGTH OF TIME">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">The duration over which an individual plans to save money to achieve a specific financial goal, which can be adjusted.</data>
  <data key="d2">1</data>
</node>
<node id="ADJUSTING GOALS">
  <data key="d0">ACTION</data>
  <data key="d1">The process of modifying financial objectives and plans in response to changing personal or financial circumstances.</data>
  <data key="d2">1</data>
</node>
<node id="REPLENISH EMERGENCY SAVINGS">
  <data key="d0">ACTION</data>
  <data key="d1">The act of refilling an emergency fund after it has been utilized, ensuring financial readiness for future unexpected events.</data>
  <data key="d2">1</data>
</node>
<node id="EXISTING SAVINGS">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">Funds that have already been accumulated towards a financial goal, which can be reallocated if that goal changes or is no longer relevant.</data>
  <data key="d2">1</data>
</node>
<node id="MONEY ON HAND">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">Funds that are readily available for use to cover expenses and bills.</data>
  <data key="d2">1</data>
</node>
<node id="PAYING BY MAIL">
  <data key="d0">ACTION</data>
  <data key="d1">A method of bill payment involving sending a physical check or money order through postal services.</data>
  <data key="d2">1</data>
</node>
<node id="IN-PERSON BILL PAYMENT">
  <data key="d0">ACTION</data>
  <data key="d1">A method of bill payment where the payer physically goes to a designated location to make a payment, often using cash.</data>
  <data key="d2">1</data>
</node>
<node id="PERSON">
  <data key="d0">PERSON</data>
  <data key="d1">An individual to whom money is owed, as might be the case for some personal debts or services.</data>
  <data key="d2">1</data>
</node>
<node id="AMOUNT DUE">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">The precise monetary value that is required to be paid for a bill or outstanding debt.</data>
  <data key="d2">1</data>
</node>
<node id="PAYMENT LOCATION">
  <data key="d0">GEO</data>
  <data key="d1">A physical place where an individual can go to make a payment for their bills, particularly for cash payments.</data>
  <data key="d2">1</data>
</node>
<node id="GAS MONEY">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">Funds specifically allocated or spent on fuel for transportation, often an additional cost for in-person bill payments.</data>
  <data key="d2">1</data>
</node>
<node id="TRANSIT FARE">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">The cost incurred for using public transportation, an expense related to reaching a payment location.</data>
  <data key="d2">1</data>
</node>
<node id="RECEIPT">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">A document provided by the remittance transfer provider after a money transfer, detailing transfer information, fees, and consumer rights.</data>
  <data key="d2">3</data>
</node>
<node id="ACCOUNT FUNDS">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">Money held within a bank account, such as a checking account, available for payments and withdrawals.</data>
  <data key="d2">1</data>
</node>
<node id="OWNER">
  <data key="d0">PERSON</data>
  <data key="d1">The person who legally possesses a safe deposit box and whose access rights may be subject to state laws or determined by illness or death.</data>
  <data key="d2">1</data>
</node>
<node id="TRUSTED FRIEND OR RELATIVE">
  <data key="d0">PERSON</data>
  <data key="d1">An individual, close to the family, who can be entrusted with paper copies of important documents from an Emergency Financial First Aid Kit for safekeeping.</data>
  <data key="d2">1</data>
</node>
<node id="INSURANCE PROVIDER">
  <data key="d0">ORGANIZATION</data>
  <data key="d1">A company or entity that offers and administers insurance policies, and with whom changes in coverage or plans should prompt an update to an Emergency Financial First Aid Kit.</data>
  <data key="d2">3</data>
</node>
<node id="FINANCIAL PAPERWORK">
  <data key="d0">FINANCIAL_PRODUCT</data>
  <data key="d1">A general term for documents related to an individual's financial affairs, which should be reviewed regularly for accuracy and currency.</data>
  <data key="d2">1</data>
</node>
<node id="ACCOUNT RECORDS">
  <data key="d0">FINANCIAL_PRODUCT</data>
  <data key="d1">Official documentation detailing transactions and balances for bank accounts or other financial accounts, important to keep with an Emergency Financial First Aid Kit.</data>
  <data key="d2">1</data>
</node>
<node id="STATEMENTS">
  <data key="d0">FINANCIAL_PRODUCT</data>
  <data key="d1">Periodic summaries, typically from banks or other financial institutions, detailing account activity, which should be regularly downloaded or printed.</data>
  <data key="d2">1</data>
</node>
<node id="YOUR BIRTHDAY">
  <data key="d0">EVENT</data>
  <data key="d1">An annual personal observance suggested as a regular reminder to review and update the Emergency Financial First Aid Kit.</data>
  <data key="d2">1</data>
</node>
<node id="START OF A NEW YEAR">
  <data key="d0">EVENT</data>
  <data key="d1">The beginning of a calendar year, suggested as a regular reminder to review and update the Emergency Financial First Aid Kit.</data>
  <data key="d2">1</data>
</node>
<node id="CHANGE IN RESIDENCE">
  <data key="d0">EVENT</data>
  <data key="d1">A relocation to a new home or apartment, necessitating prompt updates to various documents and insurance within the Emergency Financial First Aid Kit.</data>
  <data key="d2">1</data>
</node>
<node id="HAVE A CHILD">
  <data key="d0">EVENT</data>
  <data key="d1">A life event involving the birth or adoption of a child, which requires updates to the Emergency Financial First Aid Kit due to new family needs and responsibilities.</data>
  <data key="d2">1</data>
</node>
<node id="CHILD CHANGES SCHOOLS">
  <data key="d0">EVENT</data>
  <data key="d1">An event related to a child's education, serving as a reminder to update relevant information in the Emergency Financial First Aid Kit.</data>
  <data key="d2">1</data>
</node>
<node id="PURCHASE A HOME">
  <data key="d0">ACTION</data>
  <data key="d1">The act of acquiring a residential property, which triggers updates to financial paperwork and insurance policies within the Emergency Financial First Aid Kit.</data>
  <data key="d2">1</data>
</node>
<node id="RENT AN APARTMENT">
  <data key="d0">ACTION</data>
  <data key="d1">The act of securing a residential lease for an apartment, requiring updates to documents and renters insurance within the Emergency Financial First Aid Kit.</data>
  <data key="d2">1</data>
</node>
<node id="OPEN OR CLOSE BANK ACCOUNTS">
  <data key="d0">ACTION</data>
  <data key="d1">The process of initiating or terminating banking relationships, which necessitates immediate updates to the financial documentation within the Emergency Financial First Aid Kit.</data>
  <data key="d2">1</data>
</node>
<node id="EMERGENCY PURCHASES">
  <data key="d0">ACTION</data>
  <data key="d1">The act of buying essential goods or services during an urgent situation, for which having cash on hand is recommended.</data>
  <data key="d2">1</data>
</node>
<node id="&quot;PAY BILLS&quot;">
  <data key="d0">"ACTION"</data>
  <data key="d1">"The act of settling financial obligations.</data>
  <data key="d2">1</data>
</node>
<node id="&quot;SAVE MONEY&quot;">
  <data key="d0">"ACTION"</data>
  <data key="d1">"The act of accumulating funds or reducing expenditures.</data>
  <data key="d2">1</data>
</node>
<node id="&quot;EVALUATE BENEFITS AND RISKS&quot;">
  <data key="d0">"ACTION"</data>
  <data key="d1">"The process of assessing the advantages and disadvantages of different bill payment methods.</data>
  <data key="d2">1</data>
</node>
<node id="&quot;BILL PAYMENT METHOD&quot;">
  <data key="d0">"FINANCIAL_CONCEPT"</data>
  <data key="d1">"The various strategies and instruments available for settling financial obligations.</data>
  <data key="d2">1</data>
</node>
<node id="&quot;CASH&quot;">
  <data key="d0">"FINANCIAL_PRODUCT"</data>
  <data key="d1">"Physical currency commonly used for transactions.</data>
  <data key="d2">1</data>
</node>
<node id="&quot;FEES&quot;">
  <data key="d0">"FINANCIAL_CONCEPT"</data>
  <data key="d1">"Monetary charges incurred for financial services or transactions.</data>
  <data key="d2">1</data>
</node>
<node id="&quot;MONEY ORDER&quot;">
  <data key="d0">"FINANCIAL_PRODUCT"</data>
  <data key="d1">"A payment instrument purchased for a specific amount, often used for secure mail payments.</data>
  <data key="d2">1</data>
</node>
<node id="&quot;PREPAID CARD&quot;">
  <data key="d0">"FINANCIAL_PRODUCT"</data>
  <data key="d1">"A payment card loaded with a specific amount of money in advance.</data>
  <data key="d2">1</data>
</node>
<node id="&quot;RECEIPT&quot;">
  <data key="d0">"FINANCIAL_CONCEPT"</data>
  <data key="d1">"A document providing proof of payment.</data>
  <data key="d2">1</data>
</node>
<node id="&quot;THEFT RISK&quot;">
  <data key="d0">"RISK"</data>
  <data key="d1">"The potential for money, personal, or financial information to be stolen.</data>
  <data key="d2">1</data>
</node>
<node id="&quot;CHECK&quot;">
  <data key="d0">"FINANCIAL_PRODUCT"</data>
  <data key="d1">"A written instruction to a bank to pay a specified sum of money from an account.</data>
  <data key="d2">1</data>
</node>
<node id="&quot;CHECKING ACCOUNT&quot;">
  <data key="d0">"FINANCIAL_PRODUCT"</data>
  <data key="d1">"A bank account designed for frequent deposits and withdrawals for daily transactions.</data>
  <data key="d2">1</data>
</node>
<node id="&quot;MAIL PAYMENT&quot;">
  <data key="d0">"ACTION"</data>
  <data key="d1">"The process of sending payments through the postal service.</data>
  <data key="d2">1</data>
</node>
<node id="&quot;PROVE PAYMENT&quot;">
  <data key="d0">"ACTION"</data>
  <data key="d1">"The act of providing evidence or documentation that a payment has been completed.</data>
  <data key="d2">1</data>
</node>
<node id="&quot;PAYMENT DISPUTE&quot;">
  <data key="d0">"FINANCIAL_CONCEPT"</data>
  <data key="d1">"A disagreement or contention regarding a financial transaction or payment.</data>
  <data key="d2">1</data>
</node>
<node id="&quot;FUNDS SECURITY&quot;">
  <data key="d0">"FINANCIAL_CONCEPT"</data>
  <data key="d1">"The measures and conditions that protect money held in financial accounts from loss or unauthorized access.</data>
  <data key="d2">1</data>
</node>
<node id="&quot;NEGATIVE BANKING HISTORY&quot;">
  <data key="d0">"FINANCIAL_CONCEPT"</data>
  <data key="d1">"A record of past financial mismanagement or issues associated with a bank account.</data>
  <data key="d2">1</data>
</node>
<node id="&quot;NONSUFFICIENT FUND (NSF) FEES&quot;">
  <data key="d0">"FINANCIAL_CONCEPT"</data>
  <data key="d1">"Charges applied when an account lacks the necessary funds to cover a payment or check.</data>
  <data key="d2">1</data>
</node>
<node id="&quot;OVERDRAFT FEES&quot;">
  <data key="d0">"FINANCIAL_CONCEPT"</data>
  <data key="d1">"Charges incurred when an account's balance falls below zero due to a withdrawal or payment.</data>
  <data key="d2">1</data>
</node>
<node id="&quot;PAYMENT LOSS IN MAIL&quot;">
  <data key="d0">"RISK"</data>
  <data key="d1">"The danger of a physical payment instrument (like a check or money order) being lost or intercepted during postal delivery.</data>
  <data key="d2">1</data>
</node>
<node id="&quot;CREDIT CARD&quot;">
  <data key="d0">"FINANCIAL_PRODUCT"</data>
  <data key="d1">"A payment card that allows users to borrow funds up to a pre-approved credit limit.</data>
  <data key="d2">1</data>
</node>
<node id="&quot;ONLINE PAYMENT&quot;">
  <data key="d0">"ACTION"</data>
  <data key="d1">"The act of conducting financial transactions over the internet.</data>
  <data key="d2">1</data>
</node>
<node id="&quot;PHONE PAYMENT&quot;">
  <data key="d0">"ACTION"</data>
  <data key="d1">"The act of making payments via a telephone call.</data>
  <data key="d2">1</data>
</node>
<node id="&quot;ONE-TIME PAYMENTS&quot;">
  <data key="d0">"FINANCIAL_CONCEPT"</data>
  <data key="d1">"Individual, non-recurring financial transactions.</data>
  <data key="d2">1</data>
</node>
<node id="&quot;RECURRING (AUTOMATIC) PAYMENTS&quot;">
  <data key="d0">"FINANCIAL_CONCEPT"</data>
  <data key="d1">"Scheduled payments that are automatically deducted from an account at regular intervals.</data>
  <data key="d2">1</data>
</node>
<node id="&quot;LATE PAYMENT RISK&quot;">
  <data key="d0">"RISK"</data>
  <data key="d1">"The potential for penalties, fees, or negative credit implications due to delayed bill payments.</data>
  <data key="d2">1</data>
</node>
<node id="&quot;UNAUTHORIZED CHARGES&quot;">
  <data key="d0">"RISK"</data>
  <data key="d1">"Financial transactions made or attempted without the account holder's permission.</data>
  <data key="d2">1</data>
</node>
<node id="&quot;DEBT&quot;">
  <data key="d0">"FINANCIAL_CONCEPT"</data>
  <data key="d1">"An obligation to pay money or provide services to another party.</data>
  <data key="d2">1</data>
</node>
<node id="&quot;BORROW MONEY&quot;">
  <data key="d0">"ACTION"</data>
  <data key="d1">"To obtain funds from a lender with a promise of repayment, often with interest.</data>
  <data key="d2">1</data>
</node>
<node id="&quot;INTEREST&quot;">
  <data key="d0">"FINANCIAL_CONCEPT"</data>
  <data key="d1">"The cost charged for borrowing money, or the income earned from lending money.</data>
  <data key="d2">1</data>
</node>
<node id="&quot;DEBIT CARD&quot;">
  <data key="d0">"FINANCIAL_PRODUCT"</data>
  <data key="d1">"A payment card that directly withdraws funds from a linked checking account.</data>
  <data key="d2">1</data>
</node>
<node id="&quot;REPLACE CARD&quot;">
  <data key="d0">"ACTION"</data>
  <data key="d1">"The process of obtaining a new payment card, typically due to loss, theft, damage, or expiration.</data>
  <data key="d2">1</data>
</node>
<node id="&quot;UPDATE INFORMATION&quot;">
  <data key="d0">"ACTION"</data>
  <data key="d1">"The act of revising or submitting current personal, account, or payment details to an entity.</data>
  <data key="d2">1</data>
</node>
<node id="&quot;BILLER&quot;">
  <data key="d0">"ORGANIZATION"</data>
  <data key="d1">"An entity or individual that issues invoices or requests payment for goods or services.</data>
  <data key="d2">1</data>
</node>
<node id="&quot;INCONVENIENCE&quot;">
  <data key="d0">"RISK"</data>
  <data key="d1">"A state or situation causing difficulty, trouble, or discomfort, such as buying a money order or setting up online payments.</data>
  <data key="d2">1</data>
</node>
<node id="&quot;ONLINE OR MOBILE BILL PAYMENT&quot;">
  <data key="d0">"FINANCIAL_PRODUCT"</data>
  <data key="d1">"A digital service allowing bills to be paid through web browsers or dedicated mobile applications.</data>
  <data key="d2">1</data>
</node>
<node id="&quot;BANK&quot;">
  <data key="d0">"ORGANIZATION"</data>
  <data key="d1">"A financial institution offering various services such as deposits, loans, and payment processing.</data>
  <data key="d2">1</data>
</node>
<node id="&quot;CREDIT UNION&quot;">
  <data key="d0">"ORGANIZATION"</data>
  <data key="d1">"A member-owned financial cooperative that provides banking and credit services.</data>
  <data key="d2">1</data>
</node>
<node id="&quot;ACCOUNT PROVIDER&quot;">
  <data key="d0">"ORGANIZATION"</data>
  <data key="d1">"An institution (e.g., bank, credit union) that offers and manages financial accounts for customers.</data>
  <data key="d2">1</data>
</node>
<node id="&quot;ONLINE WEBSITE&quot;">
  <data key="d0">"FINANCIAL_PRODUCT"</data>
  <data key="d1">"A web-based platform used by account providers or billers for managing accounts and processing payments.</data>
  <data key="d2">1</data>
</node>
<node id="&quot;MOBILE APP&quot;">
  <data key="d0">"FINANCIAL_PRODUCT"</data>
  <data key="d1">"A software application designed for mobile devices, often used for banking, payments, or account management.</data>
  <data key="d2">1</data>
</node>
<node id="&quot;WARNINGS OR ALERTS&quot;">
  <data key="d0">"FINANCIAL_CONCEPT"</data>
  <data key="d1">"Notifications or messages provided to users about their account status or transactions.</data>
  <data key="d2">1</data>
</node>
<node id="&quot;ACCOUNT BALANCE&quot;">
  <data key="d0">"FINANCIAL_CONCEPT"</data>
  <data key="d1">"The total amount of money currently available in a financial account.</data>
  <data key="d2">1</data>
</node>
<node id="&quot;REJECTED PAYMENT&quot;">
  <data key="d0">"RISK"</data>
  <data key="d1">"A payment attempt that failed to be processed, often due to insufficient funds, incorrect details, or other issues.</data>
  <data key="d2">1</data>
</node>
<node id="&quot;DATA COLLECTION AND SHARING RISK&quot;">
  <data key="d0">"RISK"</data>
  <data key="d1">"The potential for personal or financial data to be gathered, stored, and disseminated without adequate consent or security protocols.</data>
  <data key="d2">1</data>
</node>
<node id="&quot;MOBILE DEVICE LOSS OR THEFT&quot;">
  <data key="d0">"RISK"</data>
  <data key="d1">"The risk of a mobile device being lost, misplaced, or stolen, potentially compromising stored financial information.</data>
  <data key="d2">1</data>
</node>
<node id="&quot;FINANCIAL INFORMATION ACCESS RISK&quot;">
  <data key="d0">"RISK"</data>
  <data key="d1">"The potential for unauthorized individuals to gain access to sensitive financial data.</data>
  <data key="d2">1</data>
</node>
<node id="&quot;CARD AGREEMENT&quot;">
  <data key="d0">"FINANCIAL_CONCEPT"</data>
  <data key="d1">"The legal document outlining the terms, conditions, fees, and responsibilities associated with a payment card.</data>
  <data key="d2">1</data>
</node>
<node id="&quot;CUTTING EXPENSES&quot;">
  <data key="d0">"ACTION"</data>
  <data key="d1">"The practice of reducing expenditure to manage finances more effectively or save money.</data>
  <data key="d2">1</data>
</node>
<node id="&quot;AFFORD NECESSITIES&quot;">
  <data key="d0">"ACTION"</data>
  <data key="d1">"The ability to have sufficient funds to cover essential goods and services required for living.</data>
  <data key="d2">1</data>
</node>
<node id="&quot;SAVE FOR GOALS&quot;">
  <data key="d0">"ACTION"</data>
  <data key="d1">"The act of accumulating money over time specifically to achieve future financial objectives.</data>
  <data key="d2">1</data>
</node>
<node id="&quot;EXPENSES&quot;">
  <data key="d0">"FINANCIAL_CONCEPT"</data>
  <data key="d1">"The costs incurred by an individual or organization in daily living or business operations.</data>
  <data key="d2">1</data>
</node>
<node id="&quot;FINANCIAL GOALS&quot;">
  <data key="d0">"FINANCIAL_CONCEPT"</data>
  <data key="d1">"Specific objectives an individual or organization aims to achieve through financial planning and management.</data>
  <data key="d2">1</data>
</node>
<node id="&quot;FINANCIAL SHORTFALL&quot;">
  <data key="d0">"RISK"</data>
  <data key="d1">"A situation where available financial resources are insufficient to meet current or impending obligations.</data>
  <data key="d2">1</data>
</node>
<node id="&quot;REDUCED WORK HOURS&quot;">
  <data key="d0">"RISK"</data>
  <data key="d1">"A decrease in the number of hours an individual is employed, often resulting in lower income.</data>
  <data key="d2">1</data>
</node>
<node id="&quot;TEMPORARY UNEMPLOYMENT&quot;">
  <data key="d0">"RISK"</data>
  <data key="d1">"A period during which an individual is out of work for a limited duration, impacting their income.</data>
  <data key="d2">1</data>
</node>
<node id="&quot;DECREASE SPENDING&quot;">
  <data key="d0">"ACTION"</data>
  <data key="d1">"The deliberate act of reducing the amount of money spent on goods and services.</data>
  <data key="d2">1</data>
</node>
<node id="&quot;INCOME&quot;">
  <data key="d0">"FINANCIAL_CONCEPT"</data>
  <data key="d1">"Money received, especially on a regular basis, from work, investments, or other sources.</data>
  <data key="d2">1</data>
</node>
<node id="&quot;FINANCIAL RESOURCES&quot;">
  <data key="d0">"FINANCIAL_CONCEPT"</data>
  <data key="d1">"Assets or funds available for use, investment, or to meet financial obligations.</data>
  <data key="d2">1</data>
</node>
<node id="&quot;TRACKING EXPENSES&quot;">
  <data key="d0">"ACTION"</data>
  <data key="d1">"The systematic process of monitoring, recording, and analyzing expenditures.</data>
  <data key="d2">1</data>
</node>
<node id="LETTER (DEBT DISPUTE)">
  <data key="d0">FINANCIAL_PRODUCT</data>
  <data key="d1">A formal written communication, often using a specific form or template, sent by a consumer to a debt collector to challenge the validity or accuracy of a claimed debt.</data>
  <data key="d2">1</data>
</node>
<node id="HEARING">
  <data key="d0">EVENT</data>
  <data key="d1">A formal legal proceeding in a court where parties involved in a debt lawsuit present their cases, often requiring legal representation.</data>
  <data key="d2">1</data>
</node>
<node id="DOCUMENTATION OF DEBT">
  <data key="d0">FINANCIAL_PRODUCT</data>
  <data key="d1">Official papers or records that serve as proof that a consumer is legally obligated to pay a particular debt, which can be requested for verification.</data>
  <data key="d2">1</data>
</node>
<node id="LAST BILL">
  <data key="d0">FINANCIAL_PRODUCT</data>
  <data key="d1">The most recent invoice, statement, or demand for payment issued for a debt, which a consumer can request for review.</data>
  <data key="d2">2</data>
</node>
<node id="HEALTH CARE PROGRAMS">
  <data key="d0">FINANCIAL_PRODUCT</data>
  <data key="d1">Various initiatives or services designed to provide medical care, insurance, or financial assistance for health-related expenses, impacting a consumer's overall financial health.</data>
  <data key="d2">2</data>
</node>
<node id="CASH UP FRONT">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">A requirement for an immediate, initial payment before any services are rendered or agreements are finalized, which is often a characteristic avoided by unbiased financial advisors.</data>
  <data key="d2">1</data>
</node>
<node id="LOCAL RESOURCE ORGANIZATIONS">
  <data key="d0">ORGANIZATION</data>
  <data key="d1">Community-based entities or services available in a specific geographic area that can offer assistance with various needs, such as utility payments, job searching, or legal aid.</data>
  <data key="d2">1</data>
</node>
<node id="UNBIASED INDIVIDUALS AND ORGANIZATIONS">
  <data key="d0">ORGANIZATION</data>
  <data key="d1">A general category of advisors or groups that provide objective financial information and guidance without attempting to sell products, requiring upfront payment, or having conflicts of interest.</data>
  <data key="d2">1</data>
</node>
<node id="PREMIUM">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">A premium is the amount of money an individual pays to an insurance company for an insurance policy, typically on a regular basis, and is generally lower with higher deductibles.</data>
  <data key="d2">4</data>
</node>
<node id="BUNDLING">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">The strategy of combining the purchase of multiple insurance policies, such as home and auto insurance, with the same insurance company to potentially receive discounts and savings on premiums.</data>
  <data key="d2">2</data>
</node>
<node id="INSURANCE RATINGS">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">A system used by insurance companies to classify vehicles based on factors that influence the cost of auto insurance premiums, where some cars cost more to insure than others.</data>
  <data key="d2">2</data>
</node>
<node id="DRIVE SAFE &amp; SAVE®">
  <data key="d0">FINANCIAL_PRODUCT</data>
  <data key="d1">A specific program from State Farm that allows customers to share their driving information to potentially earn discounts on their auto insurance premiums.</data>
  <data key="d2">1</data>
</node>
<node id="AUTO ACCIDENT">
  <data key="d0">EVENT</data>
  <data key="d1">A specific incident involving one or more vehicles, resulting in damages or injuries, for which insurance coverage may apply, such as uninsured/underinsured motorist coverage or med pay/personal injury protection.</data>
  <data key="d2">1</data>
</node>
<node id="VEHICLE IS DISABLED">
  <data key="d0">RISK</data>
  <data key="d1">A state where a vehicle is unable to operate due to a malfunction, breakdown, or accident, necessitating roadside assistance like emergency road service.</data>
  <data key="d2">1</data>
</node>
<node id="LOCKSMITH">
  <data key="d0">FINANCIAL_PRODUCT</data>
  <data key="d1">A service to assist with vehicle lockouts or key issues, often included as part of emergency road service coverage.</data>
  <data key="d2">1</data>
</node>
<node id="JUMPSTART">
  <data key="d0">FINANCIAL_PRODUCT</data>
  <data key="d1">A service to restart a vehicle with a dead battery, often included as part of emergency road service coverage.</data>
  <data key="d2">1</data>
</node>
<node id="TIRE CHANGES">
  <data key="d0">FINANCIAL_PRODUCT</data>
  <data key="d1">A service to replace a flat or damaged tire, often included as part of emergency road service coverage.</data>
  <data key="d2">1</data>
</node>
<node id="RENTAL REIMBURSEMENT">
  <data key="d0">FINANCIAL_PRODUCT</data>
  <data key="d1">Optional auto insurance coverage that helps pay for the cost of a rental car while the insured's vehicle is being repaired after a covered loss.</data>
  <data key="d2">1</data>
</node>
<node id="RIDESHARING">
  <data key="d0">FINANCIAL_PRODUCT</data>
