</node>
<node id="FINANCIAL OBLIGATIONS">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">Debts or expenses that must be paid, which a death benefit can help cover.</data>
  <data key="d2">1</data>
</node>
<node id="FUNERAL COSTS">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">Expenses associated with funeral services, which can be covered by bodily injury liability in the event of a fatality in an accident for which the policyholder is responsible.</data>
  <data key="d2">2</data>
</node>
<node id="HOUSING COSTS">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">Expenses related to living accommodations, such as rent or mortgage payments.</data>
  <data key="d2">1</data>
</node>
<node id="MORTGAGE PAYMENTS">
  <data key="d0">FINANCIAL_PRODUCT</data>
  <data key="d1">Periodic payments made on a mortgage loan.</data>
  <data key="d2">1</data>
</node>
<node id="LOSS OF FINANCIAL CONTRIBUTION">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">The absence of income or financial support from an insured person due to their death.</data>
  <data key="d2">1</data>
</node>
<node id="LOST INCOME">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">Earnings that are no longer received due to an insured person's death.</data>
  <data key="d2">1</data>
</node>
<node id="CREDIT CARD BILLS">
  <data key="d0">FINANCIAL_PRODUCT</data>
  <data key="d1">Statements or invoices detailing the amount owed for credit card usage, which remain a responsibility during emergencies.</data>
  <data key="d2">2</data>
</node>
<node id="LIVING COSTS">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">Regular expenses required for daily life, such as groceries and utilities.</data>
  <data key="d2">1</data>
</node>
<node id="SMALL BUSINESS OWNERS">
  <data key="d0">PERSON</data>
  <data key="d1">Individuals who own and operate small businesses, for whom life insurance offers specific benefits.</data>
  <data key="d2">1</data>
</node>
<node id="CASH VALUE">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">A component of some life insurance policies that accumulates over time and can be accessed by the policyholder.</data>
  <data key="d2">1</data>
</node>
<node id="DOWNTURN">
  <data key="d0">RISK</data>
  <data key="d1">A decline in economic activity or business conditions.</data>
  <data key="d2">1</data>
</node>
<node id="ACCIDENT">
  <data key="d0">RISK</data>
  <data key="d1">An accident is an unforeseen event, such as a vehicle collision, that can result in damages and trigger the use of an auto insurance policy for a covered claim.</data>
  <data key="d2">3</data>
</node>
<node id="NATURAL CAUSES">
  <data key="d0">RISK</data>
  <data key="d1">Death resulting from internal factors or disease, not external injury.</data>
  <data key="d2">1</data>
</node>
<node id="HOMICIDE">
  <data key="d0">RISK</data>
  <data key="d1">The unlawful killing of one person by another, covered by life insurance policies with certain exclusions.</data>
  <data key="d2">1</data>
</node>
<node id="SUICIDE">
  <data key="d0">RISK</data>
  <data key="d1">The act of intentionally causing one's own death, which may have an exclusion period in life insurance policies.</data>
  <data key="d2">1</data>
</node>
<node id="INSURANCE COMPANY">
  <data key="d0">ORGANIZATION</data>
  <data key="d1">An organization that provides insurance policies and coverages, such as State Farm, and handles claims.</data>
  <data key="d2">2</data>
</node>
<node id="LIFE INSURANCE CLAIM DENIAL">
  <data key="d0">ACTION</data>
  <data key="d1">The act by an insurance company of refusing to pay a life insurance claim.</data>
  <data key="d2">1</data>
</node>
<node id="HIGH-RISK ACTIVITIES">
  <data key="d0">RISK</data>
  <data key="d1">Actions or hobbies that significantly increase the likelihood of injury or death, potentially impacting life insurance coverage.</data>
  <data key="d2">1</data>
</node>
<node id="SKYDIVING">
  <data key="d0">ACTION</data>
  <data key="d1">A high-risk activity involving jumping from an aircraft and descending with a parachute.</data>
  <data key="d2">1</data>
</node>
<node id="HEALTH CONDITION">
  <data key="d0">RISK</data>
  <data key="d1">The state of one's physical or mental health, relevant for life insurance applications.</data>
  <data key="d2">1</data>
</node>
<node id="APPLYING FOR LIFE INSURANCE">
  <data key="d0">ACTION</data>
