  <data key="d2">2</data>
</node>
<node id="BUYING A CAR">
  <data key="d0">EVENT</data>
  <data key="d1">A significant life event or large purchase that typically requires long-term planning and saving.</data>
  <data key="d2">1</data>
</node>
<node id="WEDDING">
  <data key="d0">EVENT</data>
  <data key="d1">A significant life event that typically requires long-term planning and saving.</data>
  <data key="d2">1</data>
</node>
<node id="CAR LOAN">
  <data key="d0">FINANCIAL_PRODUCT</data>
