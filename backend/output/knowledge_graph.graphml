<node id="SIGNING PAPERWORK">
  <data key="d0">ACTION</data>
  <data key="d1">The act of affixing one's signature to official documents, indicating formal agreement to the stated terms and conditions, often for financial contracts like opening an account.</data>
  <data key="d2">1</data>
</node>
<node id="MONEY-TRANSFER COMPANIES">
  <data key="d0">ORGANIZATION</data>
  <data key="d1">A specific type of financial services company that qualifies as a remittance transfer provider under federal law.</data>
  <data key="d2">1</data>
</node>
<node id="COMPANY'S AGENTS ABROAD">
  <data key="d0">ORGANIZATION</data>
  <data key="d1">Entities located in foreign countries that are part of a remittance transfer provider's network and may charge additional fees for the transfer process.</data>
  <data key="d2">1</data>
</node>
<node id="INSTITUTIONS INVOLVED IN THE TRANSFER PROCESS">
  <data key="d0">ORGANIZATION</data>
  <data key="d1">Various organizations, including agents abroad, that play a role in facilitating an international money transfer and may levy fees.</data>
  <data key="d2">1</data>
</node>
<node id="SMALL MONEY TRANSFER COMPANIES">
  <data key="d0">ORGANIZATION</data>
  <data key="d1">Companies that provide 100 or fewer money transfers each year and are exempt from certain federal protections under federal law.</data>
  <data key="d2">1</data>
</node>
<node id="FOREIGN COUNTRY">
  <data key="d0">GEO</data>
  <data key="d1">A nation or territory outside of one's own, where foreign transaction fees may be incurred when using a card.</data>
  <data key="d2">2</data>
</node>
<node id="DESTINATION">
  <data key="d0">GEO</data>
  <data key="d1">The specific location or country where the transferred money will be made available to the recipient.</data>
  <data key="d2">1</data>
</node>
<node id="TRANSACTION">
  <data key="d0">EVENT</data>
  <data key="d1">The entire process of sending money, from initiation by the consumer to receipt by the beneficiary, subject to potential problems and cancellation rights.</data>
  <data key="d2">1</data>
</node>
<node id="RECIPIENT'S ACCOUNT">
  <data key="d0">FINANCIAL_PRODUCT</data>
  <data key="d1">A financial account (e.g., bank account) belonging to the recipient into which transferred money may be deposited.</data>
  <data key="d2">1</data>
</node>
<node id="WIRE TRANSFERS">
  <data key="d0">FINANCIAL_PRODUCT</data>
  <data key="d1">A specific type of electronic money transfer covered by federal protections when sent internationally by consumers.</data>
  <data key="d2">1</data>
</node>
<node id="SERIES OF TRANSFERS">
  <data key="d0">FINANCIAL_PRODUCT</data>
  <data key="d1">Multiple money transfers scheduled in advance by a consumer, for which specific notification rules apply regarding transfer dates.</data>
  <data key="d2">1</data>
</node>
<node id="AMOUNT">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">The specific quantity of money intended to be transferred by the provider, before fees and taxes.</data>
  <data key="d2">1</data>
</node>
<node id="FOREIGN FEES">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">Charges imposed in the recipient's country or by foreign agents that may be deducted from the money received, and which providers may need to disclose.</data>
  <data key="d2">1</data>
</node>
<node id="DISCLOSURES">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">The required information that remittance transfer providers must give to consumers before and after sending money, ensuring transparency.</data>
  <data key="d2">1</data>
</node>
<node id="PROBLEMS">
  <data key="d0">RISK</data>
  <data key="d1">Difficulties or issues encountered with a money transfer transaction, which may lead to errors or complaints.</data>
  <data key="d2">1</data>
</node>
<node id="MISTAKE">
  <data key="d0">RISK</data>
  <data key="d1">An error or inaccuracy made during a money transfer, which consumers have the right to have investigated and resolved by the provider.</data>
  <data key="d2">1</data>
</node>
<node id="MONEY NEVER ARRIVES">
  <data key="d0">RISK</data>
  <data key="d1">A specific and severe type of error in a money transfer where the intended funds are not received by the recipient, potentially entitling the sender to a refund or re-send.</data>
  <data key="d2">1</data>
</node>
<node id="DEDUCTED">
  <data key="d0">ACTION</data>
  <data key="d1">The process by which fees or taxes are subtracted from the transfer amount before the recipient receives it.</data>
  <data key="d2">1</data>
</node>
<node id="MAKE THE TRANSFER">
  <data key="d0">ACTION</data>
  <data key="d1">The action taken by the remittance transfer provider to process and complete the money transfer to the recipient.</data>
  <data key="d2">1</data>
</node>
<node id="PAYING">
  <data key="d0">ACTION</data>
  <data key="d1">The act of the consumer providing funds to the remittance transfer provider to cover the transfer amount and associated fees.</data>
  <data key="d2">1</data>
</node>
<node id="PICKED UP">
  <data key="d0">ACTION</data>
  <data key="d1">The action of the recipient physically collecting the transferred money, typically in cash, at a foreign location.</data>
  <data key="d2">1</data>
</node>
<node id="DEPOSITED">
  <data key="d0">ACTION</data>
  <data key="d1">The action of placing transferred money into the recipient's financial account.</data>
  <data key="d2">1</data>
</node>
<node id="NOTIFY">
  <data key="d0">ACTION</data>
  <data key="d1">The act of informing the provider (e.g., to cancel a transfer or report an error) or the consumer (e.g., investigation results).</data>
  <data key="d2">1</data>
</node>
<node id="RESOLVE ERRORS">
  <data key="d0">ACTION</data>
  <data key="d1">The process undertaken by remittance providers to correct mistakes or inaccuracies in a money transfer, as a consumer right.</data>
  <data key="d2">1</data>
</node>
<node id="INVESTIGATE COMPLAINTS">
  <data key="d0">ACTION</data>
  <data key="d1">The process by which remittance providers examine consumer complaints regarding money transfers to determine the facts and resolve issues.</data>
  <data key="d2">1</data>
</node>
<node id="CONTACT">
  <data key="d0">ACTION</data>
  <data key="d1">The act of communicating with the remittance provider, state agency, or CFPB regarding questions or complaints about a money transfer.</data>
  <data key="d2">1</data>
</node>
<node id="SEND AGAIN">
  <data key="d0">ACTION</data>
  <data key="d1">The act of re-initiating a money transfer, often as a remedy for a previous error where money did not arrive.</data>
  <data key="d2">1</data>
</node>
<node id="GOVERNMENT PROGRAMS">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">A general category of government-sponsored initiatives that provide various forms of financial or other assistance, often a source of benefits.</data>
  <data key="d2">1</data>
</node>
<node id="HOMEOWNERS INSURANCE POLICY">
  <data key="d0">FINANCIAL_PRODUCT</data>
  <data key="d1">An insurance policy that provides coverage for a residential property. New homeowners are encouraged to bundle this policy with existing auto insurance for combined savings and convenience.</data>
  <data key="d2">1</data>
</node>
<node id="CONDO INSURANCE">
  <data key="d0">FINANCIAL_PRODUCT</data>
  <data key="d1">A specific type of insurance tailored for condominium owners, designed to protect their unit and personal property. It can be bundled with car insurance.</data>
  <data key="d2">1</data>
</node>
<node id="SAFE DRIVING PROGRAM">
  <data key="d0">FINANCIAL_PRODUCT</data>
  <data key="d1">A program offered by State Farm designed to encourage safe driving habits among policyholders. Participation can unlock additional discounts beyond those offered by bundling.</data>
  <data key="d2">1</data>
</node>
<node id="COST SAVINGS">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">The monetary benefits customers gain from bundling insurance policies, potentially amounting to hundreds or even over a thousand dollars annually, by reducing overall insurance expenditures.</data>
  <data key="d2">1</data>
</node>
<node id="POLICY MANAGEMENT">
  <data key="d0">ACTION</data>
  <data key="d1">The process of administering, monitoring, and interacting with insurance policies. Bundling simplifies this process through unified digital platforms, single logins, and consolidated claims.</data>
  <data key="d2">1</data>
</node>
<node id="STREAMLINED CLAIMS PROCESS">
  <data key="d0">ACTION</data>
  <data key="d1">An enhanced and simplified procedure for filing and handling insurance claims. This is a practical advantage of bundling, especially when a single incident affects multiple insured items.</data>
  <data key="d2">1</data>
</node>
<node id="UNIFIED BILLING">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">A billing system where all insurance expenses for bundled policies are consolidated into a single statement or view, making it easier for customers to manage their monthly budget.</data>
  <data key="d2">1</data>
</node>
<node id="MULTILINE DISCOUNT">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">A specific type of discount applied when a customer purchases two or more different types of insurance policies (lines of insurance) from the same provider, as part of a bundling strategy.</data>
  <data key="d2">1</data>
</node>
<node id="MULTI-CAR DISCOUNT">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">A specific discount offered on auto insurance policies when multiple vehicles are insured by the same household or policyholder, often part of broader bundle savings.</data>
  <data key="d2">1</data>
</node>
<node id="IN-NETWORK">
  <data key="d0">GEO</data>
  <data key="d1">Refers to ATMs or services that are part of a card provider's designated network, typically offering lower or no fees.</data>
  <data key="d2">1</data>
</node>
<node id="OUT-OF-NETWORK">
  <data key="d0">GEO</data>
  <data key="d1">Refers to ATMs or services that are outside of a card provider's designated network, typically incurring higher fees.</data>
  <data key="d2">1</data>
</node>
<node id="DEFINITIONS OF COMMON PREPAID CARD FEES">
  <data key="d0">EVENT</data>
  <data key="d1">A section of the document providing explanations for various fees associated with prepaid cards.</data>
  <data key="d2">1</data>
</node>
<node id="INACTIVITY">
  <data key="d0">EVENT</data>
  <data key="d1">The state of not using a card for a certain period, which may trigger an inactivity fee.</data>
  <data key="d2">1</data>
</node>
<node id="CARD PACKAGING">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">The physical container or wrapping for a card, where terms and fees are typically located.</data>
  <data key="d2">1</data>
</node>
<node id="PER PURCHASE FEE">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">A charge applied each time a card is used for certain types of transactions, also known as a transaction fee.</data>
  <data key="d2">1</data>
</node>
<node id="FOREIGN CURRENCY">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">Money used in a country other than one's own, transactions involving which may incur foreign transaction fees.</data>
  <data key="d2">1</data>
</node>
<node id="DAMAGED CARD">
  <data key="d0">RISK</data>
  <data key="d1">A physical impairment to a card that renders it unusable, often requiring a card replacement.</data>
  <data key="d2">1</data>
</node>
<node id="REPORT">
  <data key="d0">ACTION</data>
  <data key="d1">To inform authorities or financial institutions immediately about unauthorized transactions or errors.</data>
  <data key="d2">1</data>
</node>
<node id="SCHEDULE AUTOMATIC PAYMENTS">
  <data key="d0">ACTION</data>
  <data key="d1">To set up recurring payments that are automatically deducted from an account on a predetermined schedule.</data>
  <data key="d2">1</data>
</node>
<node id="LINK ACCOUNTS">
  <data key="d0">ACTION</data>
  <data key="d1">To connect two financial accounts, such as a savings and checking account, often for overdraft protection.</data>
  <data key="d2">1</data>
</node>
<node id="MOVE BILL DUE DATE">
  <data key="d0">ACTION</data>
  <data key="d1">To request an adjustment to the deadline for paying a bill.</data>
  <data key="d2">1</data>
</node>
<node id="DELAY PURCHASE">
  <data key="d0">ACTION</data>
  <data key="d1">To postpone the acquisition of goods or services until sufficient funds are available.</data>
  <data key="d2">1</data>
</node>
<node id="EVALUATE PREPAID/PAYROLL CARD">
  <data key="d0">ACTION</data>
  <data key="d1">To assess the features, terms, and fees of a prepaid or payroll card before use.</data>
  <data key="d2">1</data>
</node>
<node id="WITHDRAW MONEY">
  <data key="d0">ACTION</data>
  <data key="d1">To take cash out of an account, typically at an ATM or bank branch.</data>
  <data key="d2">1</data>
</node>
<node id="COMPARE CARDS">
  <data key="d0">ACTION</data>
  <data key="d1">To examine different types of cards to determine which best suits one's needs, based on costs and features.</data>
  <data key="d2">1</data>
</node>
<node id="REVIEW DEFINITIONS">
  <data key="d0">ACTION</data>
  <data key="d1">To examine and understand the meanings of financial terms, especially related to fees.</data>
  <data key="d2">1</data>
</node>
<node id="FIND TERMS AND FEES">
  <data key="d0">ACTION</data>
  <data key="d1">To locate and identify the specific conditions and charges associated with a financial product like a card.</data>
  <data key="d2">1</data>
</node>
<node id="RESEARCH PREPAID CARDS">
  <data key="d0">ACTION</data>
  <data key="d1">To gather information about various prepaid cards, often online, to understand their features and costs before buying.</data>
  <data key="d2">1</data>
</node>
<node id="CHECK CARDHOLDER AGREEMENT">
  <data key="d0">ACTION</data>
  <data key="d1">To consult the legal document detailing the terms and conditions of a card's use.</data>
  <data key="d2">1</data>
</node>
<node id="CANCEL CARD">
  <data key="d0">ACTION</data>
  <data key="d1">To formally terminate a card account.</data>
  <data key="d2">1</data>
</node>
<node id="REPLACE CARD">
  <data key="d0">ACTION</data>
  <data key="d1">To obtain a new card due to the previous one being lost, stolen, or damaged.</data>
  <data key="d2">1</data>
</node>
<node id="TRANSFER MONEY BETWEEN CARDS">
  <data key="d0">ACTION</data>
  <data key="d1">To move funds electronically from one prepaid card to another.</data>
  <data key="d2">1</data>
</node>
<node id="RELOAD CARD">
  <data key="d0">ACTION</data>
  <data key="d1">To add additional funds to a prepaid or payroll card.</data>
  <data key="d2">1</data>
</node>
<node id="REGISTER PREPAID CARD">
  <data key="d0">ACTION</data>
  <data key="d1">To formally activate a prepaid card to unlock full features, protections, and benefits.</data>
  <data key="d2">1</data>
</node>
<node id="GETTING CASH">
  <data key="d0">ACTION</data>
  <data key="d1">The act of obtaining physical currency, typically from an ATM or financial institution.</data>
  <data key="d2">1</data>
</node>
<node id="ADDING MONEY">
  <data key="d0">ACTION</data>
  <data key="d1">The act of depositing funds into an account or onto a card.</data>
  <data key="d2">1</data>
</node>
<node id="COLLEGE COSTS">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">The expenses associated with attending college, which the CFPB provides tools to help compare across different schools.</data>
  <data key="d2">1</data>
</node>
<node id="PAST DUE MEDICAL DEBTS">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">Medical debts that have not been paid by their due date, which credit reporting companies must wait six months to include on credit reports.</data>
  <data key="d2">1</data>
</node>
<node id="EXPLANATION OF BENEFITS">
  <data key="d0">FINANCIAL_PRODUCT</data>
  <data key="d1">A document provided by a health insurance company detailing medical services, the amount charged, and how much the insurer will pay.</data>
  <data key="d2">1</data>
</node>
<node id="BILLER">
  <data key="d0">ORGANIZATION</data>
  <data key="d1">An entity or individual responsible for sending out invoices or requests for payment, such as for medical services.</data>
  <data key="d2">1</data>
</node>
<node id="LOAN DEBT PAYMENTS">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">Regular payments made towards the principal and interest of an outstanding loan debt.</data>
  <data key="d2">1</data>
</node>
<node id="FEDERAL DISASTER">
  <data key="d0">EVENT</data>
  <data key="d1">An incident declared by federal authorities that makes affected individuals eligible for federal assistance.</data>
  <data key="d2">1</data>
</node>
<node id="DISASTER RECOVERY CENTERS">
  <data key="d0">GEO</data>
  <data key="d1">Locations established by FEMA in disaster-affected areas where survivors can speak with FEMA representatives about available recovery programs.</data>
  <data key="d2">1</data>
</node>
<node id="HEALTH INSURANCE COMPANY">
  <data key="d0">ORGANIZATION</data>
  <data key="d1">A company that provides health insurance, from which individuals receive an explanation of benefits.</data>
  <data key="d2">1</data>
</node>
<node id="CASH ADVANCE">
  <data key="d0">FINANCIAL_PRODUCT</data>
  <data key="d1">Another term for a payday loan, referring to a short-term loan usually provided as cash or an electronic deposit.</data>
  <data key="d2">1</data>
</node>
<node id="PAYDAY INSTALLMENT LOANS">
  <data key="d0">FINANCIAL_PRODUCT</data>
  <data key="d1">A type of payday loan structured for repayment in multiple installments over a longer period.</data>
  <data key="d2">1</data>
</node>
<node id="S.R. COLLINS">
  <data key="d0">PERSON</data>
  <data key="d1">An author of the February 2017 publication "How the Affordable Care Act Has Improved Americans’ Ability to Buy Health Insurance on Their Own" for The Commonwealth Fund.</data>
  <data key="d2">1</data>
</node>
<node id="M.Z. GUNJA">
  <data key="d0">PERSON</data>
  <data key="d1">An author of the February 2017 publication "How the Affordable Care Act Has Improved Americans’ Ability to Buy Health Insurance on Their Own" for The Commonwealth Fund.</data>
  <data key="d2">1</data>
</node>
<node id="M.M. DOTY">
  <data key="d0">PERSON</data>
  <data key="d1">An author of the February 2017 publication "How the Affordable Care Act Has Improved Americans’ Ability to Buy Health Insurance on Their Own" for The Commonwealth Fund.</data>
  <data key="d2">1</data>
</node>
<node id="S. BEUTEL">
  <data key="d0">PERSON</data>
  <data key="d1">An author of the February 2017 publication "How the Affordable Care Act Has Improved Americans’ Ability to Buy Health Insurance on Their Own" for The Commonwealth Fund.</data>
  <data key="d2">1</data>
</node>
<node id="THE COMMONWEALTH FUND">
  <data key="d0">ORGANIZATION</data>
  <data key="d1">The organization that published the report "How the Affordable Care Act Has Improved Americans’ Ability to Buy Health Insurance on Their Own" in February 2017.</data>
  <data key="d2">1</data>
</node>
<node id="AFFORDABLE CARE ACT">
  <data key="d0">EVENT</data>
  <data key="d1">Legislation referenced as having improved Americans’ ability to buy health insurance, as described in a 2017 publication.</data>
  <data key="d2">1</data>
</node>
<node id="CHOOSE A LOAN">
  <data key="d0">ACTION</data>
  <data key="d1">An action that tools provided by the CFPB can assist consumers with.</data>
  <data key="d2">1</data>
</node>
<node id="COMPARE FINANCIAL AID PACKAGES AND COLLEGE COSTS">
  <data key="d0">ACTION</data>
  <data key="d1">An action, facilitated by CFPB tools, to evaluate financial aid and costs across multiple schools.</data>
  <data key="d2">1</data>
</node>
<node id="MANAGE MONEY WHILE IN COLLEGE">
  <data key="d0">ACTION</data>
  <data key="d1">An action that tools provided by the CFPB can assist college students with.</data>
  <data key="d2">1</data>
</node>
<node id="REPAY STUDENT LOANS">
  <data key="d0">ACTION</data>
  <data key="d1">An action related to student loan obligations, for which the CFPB provides tools and resources.</data>
  <data key="d2">1</data>
</node>
<node id="ELECTRONIC DEBIT">
  <data key="d0">ACTION</data>
  <data key="d1">A method by which lenders can access a borrower's checking account for loan repayment.</data>
  <data key="d2">1</data>
</node>
<node id="OVERDRAFTS">
  <data key="d0">RISK</data>
  <data key="d1">Situations where an account transaction exceeds the available balance, resulting in a negative balance.</data>
  <data key="d2">1</data>
</node>
<node id="BANKING HISTORY REPORTS">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">Comprehensive summaries of a consumer's past checking and savings account activity compiled by reporting companies, used by financial institutions to assess risk.</data>
  <data key="d2">1</data>
</node>
<node id="529 PLAN">
  <data key="d0">FINANCIAL_PRODUCT</data>
  <data key="d1">A savings plan that operates as an investment account with special tax benefits, designed for saving for education and training costs for oneself or dependent children.</data>
  <data key="d2">1</data>
</node>
<node id="MONEY OR WIRE TRANSFER SERVICE">
  <data key="d0">FINANCIAL_PRODUCT</data>
  <data key="d1">A service used to send money to another person or entity.</data>
  <data key="d2">1</data>
</node>
<node id="FINANCIAL INVESTMENT FIRM">
  <data key="d0">ORGANIZATION</data>
  <data key="d1">An organization that offers financial products, specifically mentioned as a place where 529 Plans are offered.</data>
  <data key="d2">1</data>
</node>
<node id="STATE'S PROGRAM">
  <data key="d0">ORGANIZATION</data>
  <data key="d1">A state-level entity that manages and offers financial products, specifically the 529 Plan.</data>
  <data key="d2">1</data>
</node>
<node id="CAR DEALER">
  <data key="d0">ORGANIZATION</data>
  <data key="d1">An organization that sells cars and trucks and can offer auto loans to facilitate vehicle purchases.</data>
  <data key="d2">1</data>
</node>
<node id="TITLE LOAN COMPANY">
  <data key="d0">ORGANIZATION</data>
  <data key="d1">A specialized company that offers auto title loans.</data>
  <data key="d2">1</data>
</node>
<node id="TAX BENEFITS">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">Special financial advantages related to taxation, such as those offered by a 529 Plan, often leading to reduced tax liability.</data>
  <data key="d2">1</data>
</node>
<node id="PENALTY FEES">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">Charges incurred for specific actions, such as withdrawing money from a Certificate of Deposit before its maturity date.</data>
  <data key="d2">1</data>
</node>
<node id="ACCESS ONLINE OR MOBILE BANKING">
  <data key="d0">ACTION</data>
  <data key="d1">The action of using online or mobile platforms to manage accounts, check balances, or deposit checks using a phone.</data>
  <data key="d2">1</data>
</node>
<node id="DIRECT DEPOSIT PAYCHECK">
  <data key="d0">ACTION</data>
  <data key="d1">The action of having one's paycheck electronically transferred directly into a financial account.</data>
  <data key="d2">1</data>
</node>
<node id="BUILD SAVINGS">
  <data key="d0">ACTION</data>
  <data key="d1">The action of accumulating money over time, often in a savings account or other financial product, for future use.</data>
  <data key="d2">1</data>
</node>
<node id="SAVE FOR EDUCATION AND TRAINING">
  <data key="d0">ACTION</data>
  <data key="d1">The action of setting aside funds specifically for future educational and vocational expenses for oneself or a child.</data>
  <data key="d2">1</data>
</node>
<node id="BUY A CAR">
  <data key="d0">ACTION</data>
  <data key="d1">The action of purchasing an automobile, often financed through a loan.</data>
  <data key="d2">1</data>
</node>
<node id="GET A SMALL LOAN QUICKLY">
  <data key="d0">ACTION</data>
  <data key="d1">The action of obtaining a relatively small amount of money as a loan within a short timeframe.</data>
  <data key="d2">1</data>
</node>
<node id="SEND MONEY TO SOMEONE">
  <data key="d0">ACTION</data>
  <data key="d1">The action of transferring funds to another individual or entity.</data>
  <data key="d2">1</data>
</node>
<node id="DEFAULT ON LOAN">
  <data key="d0">ACTION</data>
  <data key="d1">The action of failing to fulfill the terms of a loan agreement, such as missing payments, which can lead to consequences like repossession of collateral.</data>
  <data key="d2">1</data>
</node>
<node id="WITHDRAW MONEY EARLY">
  <data key="d0">ACTION</data>
  <data key="d1">The action of taking out funds from a financial product, such as a Certificate of Deposit, before its agreed-upon maturity date.</data>
  <data key="d2">1</data>
</node>
<node id="SOCIAL SECURITY ADMINISTRATION (SSA)">
  <data key="d0">ORGANIZATION</data>
  <data key="d1">The federal agency responsible for administering Social Security Disability Insurance (SSDI) and Supplemental Security Income (SSI) programs, providing contact via ssa.gov.</data>
  <data key="d2">1</data>
</node>
<node id="UNITED STATES DEPARTMENT OF AGRICULTURE (USDA)">
  <data key="d0">ORGANIZATION</data>
  <data key="d1">The federal department responsible for the Supplemental Nutrition Assistance Program (SNAP), providing information via fns.usda.gov.</data>
  <data key="d2">1</data>
</node>
<node id="DEPARTMENT OF HEALTH AND HUMAN SERVICES (HHS)">
  <data key="d0">ORGANIZATION</data>
  <data key="d1">A U.S. federal department that oversees programs like Temporary Assistance for Needy Families (TANF) and Low Income Home Energy Assistance Program (LIHEAP), with information available at acf.hhs.gov.</data>
  <data key="d2">1</data>
</node>
<node id="ADMINISTRATION FOR CHILDREN AND FAMILIES (ACF)">
  <data key="d0">ORGANIZATION</data>
  <data key="d1">A division within the U.S. Department of Health and Human Services (HHS) that administers programs such as TANF and LIHEAP, accessible via acf.hhs.gov.</data>
  <data key="d2">1</data>
</node>
<node id="DEPARTMENT OF HOUSING AND URBAN DEVELOPMENT (HUD)">
  <data key="d0">ORGANIZATION</data>
  <data key="d1">The U.S. federal department responsible for public housing programs, with information accessible via portal.hud.gov.</data>
  <data key="d2">1</data>
</node>
<node id="FAMILY MEDICAID">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">A medical assistance program, listed as having no asset limit, with information available through medicaid.gov.</data>
  <data key="d2">1</data>
</node>
<node id="MEDICARE PART D EXTRA HELP (LOW-INCOME SUBSIDY)">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">A program offering assistance with Medicare Part D costs for low-income individuals, subject to an asset limit, with information available via shiptacenter.org.</data>
  <data key="d2">1</data>
</node>
<node id="MEDICARE SAVINGS PROGRAMS">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">Programs designed to help with Medicare costs, subject to an asset limit, with information available via shiptacenter.org.</data>
  <data key="d2">1</data>
</node>
<node id="STATE HEALTH INSURANCE ASSISTANCE PROGRAM (SHIP)">
  <data key="d0">ORGANIZATION</data>
  <data key="d1">An organization that provides free health insurance counseling, including information on Medicare Part D Extra Help and Medicare Savings Programs, via shiptacenter.org.</data>
  <data key="d2">1</data>
</node>
<node id="STATE CHILD HEALTH INSURANCE PROGRAM (SCHIP)">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">A program providing low-cost health coverage for children, subject to an asset limit, with information available through medicaid.gov.</data>
  <data key="d2">1</data>
</node>
<node id="FEDERAL DEPOSIT INSURANCE CORPORATION (FDIC)">
  <data key="d0">ORGANIZATION</data>
  <data key="d1">A U.S. government corporation that insures deposits in banks, protecting up to $250,000 per depositor.</data>
  <data key="d2">1</data>
</node>
<node id="NATIONAL CREDIT UNION ADMINISTRATION (NCUA)">
  <data key="d0">ORGANIZATION</data>
  <data key="d1">An independent federal agency that insures deposits at federal credit unions, protecting up to $250,000 per depositor.</data>
  <data key="d2">1</data>
</node>
<node id="HOME INVASION">
  <data key="d0">RISK</data>
  <data key="d1">The risk of an individual's home being forcibly entered, leading to potential loss of money or assets, and putting inhabitants at risk.</data>
  <data key="d2">1</data>
</node>
<node id="ACCOUNT AT BANK OR CREDIT UNION">
  <data key="d0">FINANCIAL_PRODUCT</data>
  <data key="d1">A type of financial product (e.g., savings, checking, or share draft) held at a bank or credit union, offering federal insurance and protection up to $250,000, but potentially incurring fees.</data>
  <data key="d2">1</data>
</node>
<node id="ASSET LIMIT">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">A restriction on the total value of assets an individual or household can possess to be eligible for certain government assistance programs.</data>
  <data key="d2">1</data>
</node>
<node id="MONEY LOST, STOLEN, OR DESTROYED">
  <data key="d0">RISK</data>
  <data key="d1">A general risk to savings, encompassing various ways money can be lost, including theft, destruction by fire, or betrayal of trust.</data>
  <data key="d2">1</data>
</node>
<node id="BETRAYAL OF TRUST">
  <data key="d0">RISK</data>
  <data key="d1">The risk that a family member or friend, entrusted with savings, might not act in the owner's best interest or might misappropriate the funds.</data>
  <data key="d2">1</data>
</node>
<node id="HOUSING PAYMENTS">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">Financial obligations related to residence, such as rent or mortgage payments, which are crucial to document for disaster assistance.</data>
  <data key="d2">2</data>
</node>
<node id="CREDIT/DEBIT CARD ACCOUNTS">
  <data key="d0">FINANCIAL_PRODUCT</data>
  <data key="d1">Financial instruments for transactions and managing funds, whose information should be recorded for emergencies.</data>
  <data key="d2">2</data>
</node>
<node id="ESTATE PLANNING">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">The process of arranging for the management and disposal of one's estate, included in essential legal documentation.</data>
  <data key="d2">2</data>
</node>
<node id="FDIC">
  <data key="d0">ORGANIZATION</data>
  <data key="d1">The Federal Deposit Insurance Corporation, an organization providing information on the impact of natural disasters on banking.</data>
  <data key="d2">2</data>
</node>
<node id="LEGAL DOCUMENTATION">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">A checklist section for important legal papers such as leases, deeds, and loan documents.</data>
  <data key="d2">2</data>
</node>
<node id="LEASE OR RENTAL AGREEMENT">
  <data key="d0">FINANCIAL_PRODUCT</data>
  <data key="d1">A contract for renting property, required as proof of housing for Federal disaster assistance.</data>
  <data key="d2">2</data>
</node>
<node id="REAL ESTATE DEEDS OF TRUST">
  <data key="d0">FINANCIAL_PRODUCT</data>
  <data key="d1">Legal documents proving home ownership, required for Federal disaster assistance.</data>
  <data key="d2">2</data>
</node>
<node id="EMERGENCY OR DISASTER">
  <data key="d0">EVENT</data>
  <data key="d1">An unforeseen event or crisis that can disrupt financial stability and requires preparedness.</data>
  <data key="d2">2</data>
</node>
<node id="OTHER FINANCIAL OBLIGATIONS">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">A general category of financial commitments that should be documented in an Emergency Financial First Aid Kit.</data>
  <data key="d2">1</data>
</node>
<node id="FINANCIAL RECORDS AND RESPONSIBILITIES">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">The documentation and duties related to managing one's financial situation, important for disaster assistance eligibility.</data>
  <data key="d2">1</data>
</node>
<node id="PROOF OF INCOME">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">Documentation required to verify an individual's earnings, often needed when applying for disaster assistance.</data>
  <data key="d2">1</data>
</node>
<node id="RAINY DAY FUND">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">A financial savings strategy or fund specifically set aside for unexpected emergencies or financial setbacks.</data>
  <data key="d2">1</data>
</node>
<node id="HOME OWNERSHIP">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">The legal status of possessing a residential property, proof of which may be required for disaster assistance.</data>
  <data key="d2">1</data>
</node>
<node id="STATEMENTS FROM ACCOUNTS">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">Documents provided by financial institutions detailing transactions and balances for various accounts.</data>
  <data key="d2">1</data>
</node>
<node id="CREDIT CARD ISSUERS">
  <data key="d0">ORGANIZATION</data>
  <data key="d1">Financial companies or banks that provide credit cards to consumers and manage credit accounts.</data>
  <data key="d2">1</data>
</node>
<node id="RE-ESTABLISH FINANCIAL ACCOUNTS">
  <data key="d0">ACTION</data>
  <data key="d1">The action of restoring or setting up new financial accounts if existing ones are destroyed or inaccessible after a disaster.</data>
  <data key="d2">1</data>
</node>
<node id="MAINTAIN PAYMENTS AND CREDIT">
  <data key="d0">ACTION</data>
  <data key="d1">The ongoing effort to ensure financial obligations are met and a good credit score is preserved, especially during emergencies.</data>
  <data key="d2">1</data>
</node>
<node id="CONTACTING INSURANCE COMPANY">
  <data key="d0">ACTION</data>
  <data key="d1">The act of communicating with an insurance provider to discuss damages, claims, and repairs following an event.</data>
  <data key="d2">1</data>
</node>
<node id="CONTACTING UTILITIES">
  <data key="d0">ACTION</data>
  <data key="d1">The act of communicating with service providers (e.g., electric, water, gas) regarding outages, issues, and solutions.</data>
  <data key="d2">1</data>
</node>
<node id="LOSE INCOME">
  <data key="d0">RISK</data>
  <data key="d1">The potential or occurrence of an individual's earnings stopping or significantly decreasing, often due to an emergency or disaster.</data>
  <data key="d2">1</data>
</node>
<node id="CALL CREDIT CARD ISSUERS">
  <data key="d0">ACTION</data>
  <data key="d1">The act of telephoning credit card companies to inform them of financial difficulties due to an emergency and seek payment solutions.</data>
  <data key="d2">1</data>
</node>
<node id="CREATE A SCHEDULE">
  <data key="d0">ACTION</data>
  <data key="d1">The act of establishing a structured plan, such as a payment arrangement with a credit card issuer, to manage financial obligations.</data>
  <data key="d2">1</data>
</node>
<node id="INDIVIDUALITY">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">A value emphasizing personal autonomy and self-reliance, often associated with Western culture.</data>
  <data key="d2">1</data>
</node>
<node id="PERSONAL WELL-BEING">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">A state of individual welfare and happiness, often valued in Western culture and linked to financial self-support.</data>
  <data key="d2">1</data>
</node>
<node id="FINANCIAL CHOICES">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">Decisions made regarding the allocation and management of money, heavily influenced by culture, values, and emotions.</data>
  <data key="d2">1</data>
</node>
<node id="CULTURAL CONTEXT">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">The broader social and cultural environment that shapes an individual's financial perspectives, behaviors, and values.</data>
  <data key="d2">1</data>
</node>
<node id="CULTURAL NORMS">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">Shared expectations and unwritten rules within a society or group that dictate appropriate financial behaviors.</data>
  <data key="d2">1</data>
</node>
<node id="CULTURAL CONFLICTS">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">Disagreements or tensions arising from differing cultural expectations about money, leading to stress and complex financial decisions.</data>
  <data key="d2">1</data>
</node>
<node id="FINANCIAL DECISION-MAKING">
  <data key="d0">ACTION</data>
  <data key="d1">The active process of making choices about how to earn, spend, save, and invest money, influenced by various factors.</data>
  <data key="d2">1</data>
</node>
<node id="NATIONAL STUDENT LOAN DATA SYSTEM (NSLDS)">
  <data key="d0">ORGANIZATION</data>
  <data key="d1">An online system (nslds.ed.gov) that provides a comprehensive list of all federal student loans, including their respective servicers.</data>
  <data key="d2">1</data>
</node>
<node id="NSLDS.ED.GOV">
  <data key="d0">ORGANIZATION</data>
  <data key="d1">The official website for the National Student Loan Data System, used to access information about federal student loans.</data>
  <data key="d2">1</data>
</node>
<node id="ADJUSTED GROSS INCOME">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">A key component in the calculation of discretionary income for income-driven repayment plans.</data>
  <data key="d2">1</data>
</node>
<node id="FEDERAL POVERTY GUIDELINES">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">Government-issued guidelines used as a benchmark for calculating discretionary income in income-driven repayment plans.</data>
  <data key="d2">1</data>
</node>
<node id="STUDENT AID.ED.GOV">
  <data key="d0">ORGANIZATION</data>
  <data key="d1">An official website providing comprehensive information about federal student loans and various repayment options, linked to the Department of Education.</data>
  <data key="d2">1</data>
</node>
<node id="CHANGING REPAYMENT PLAN">
  <data key="d0">ACTION</data>
  <data key="d1">The process of altering one's existing student loan repayment plan, which is typically free for federal student loans.</data>
  <data key="d2">1</data>
</node>
<node id="OVERDRAWING YOUR ACCOUNT">
  <data key="d0">RISK</data>
  <data key="d1">The act of spending or withdrawing more money than is available in a financial account, resulting in a negative balance and potential fees.</data>
  <data key="d2">1</data>
</node>
<node id="BOUNCED CHECK FEES">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">Charges applied when a check presented for payment cannot be cleared because the payer's account has insufficient funds, often resulting from overdrawing.</data>
  <data key="d2">1</data>
</node>
<node id="TERMS AND FEE DESCRIPTIONS">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">Comprehensive explanations of the rules, conditions, and all associated charges and costs pertaining to a financial product or service, such as a prepaid card.</data>
  <data key="d2">1</data>
</node>
<node id="CREDIT UNION ACCOUNT">
  <data key="d0">FINANCIAL_PRODUCT</data>
  <data key="d1">A financial account held at a credit union, a member-owned cooperative financial institution, offering services that can be compared to prepaid cards.</data>
  <data key="d2">1</data>
</node>
<node id="PREPAID CARD RIGHTS">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">Legal protections and entitlements afforded to consumers who use prepaid cards, ensuring fair practices and transparency.</data>
  <data key="d2">1</data>
</node>
<node id="FINDING FINANCIAL PRODUCTS AND SERVICES TOOL">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">A resource, guide, or instrument designed to assist individuals in locating and assessing various financial products and services.</data>
  <data key="d2">1</data>
</node>
<node id="ATM WITHDRAWAL FEE">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">A charge incurred for withdrawing cash from an Automated Teller Machine using a card, which may vary based on whether the ATM is in-network or out-of-network.</data>
  <data key="d2">1</data>
</node>
<node id="BALANCE INQUIRY FEE">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">A charge for checking the available balance of a card, often applied when using specific methods like an ATM or phone customer service.</data>
  <data key="d2">1</data>
</node>
<node id="BILL PAYMENT FEE">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">A fee charged for using a card provider's online platform to pay bills, sometimes applied per bill paid.</data>
  <data key="d2">1</data>
</node>
<node id="CARD REPLACEMENT FEE">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">A charge for issuing a new card to replace one that has been lost, stolen, or damaged.</data>
  <data key="d2">1</data>
</node>
<node id="CASH RELOAD FEE">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">A charge for adding money (reloading cash) onto a prepaid card at a designated retail location.</data>
  <data key="d2">1</data>
</node>
<node id="DECLINE FEE">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">A charge incurred when a transaction attempted with a card is rejected because the amount exceeds the available funds on the card.</data>
  <data key="d2">1</data>
</node>
<node id="FOREIGN TRANSACTION FEE">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">A surcharge applied when a card is used for purchases in a foreign country or for transactions processed in a foreign currency.</data>
  <data key="d2">1</data>
</node>
<node id="TRANSACTION FEE">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">A fee charged each time a card is used for certain types of transactions, often referred to as a "per purchase fee.</data>
  <data key="d2">1</data>
</node>
<node id="KELLEY BLUE BOOK">
  <data key="d0">ORGANIZATION</data>
  <data key="d1">Kelley Blue Book is a recognized authority in the automotive industry, cited as a source for common auto insurance deductible amounts.</data>
  <data key="d2">1</data>
</node>
<node id="PEDESTRIAN">
  <data key="d0">PERSON</data>
  <data key="d1">A pedestrian is a person traveling on foot who may be involved in an auto crash and can be covered for medical expenses under certain auto insurance policies like Personal Injury Protection or Medical Payments Coverage.</data>
  <data key="d2">1</data>
</node>
<node id="DRIVER">
  <data key="d0">PERSON</data>
  <data key="d1">A driver is an individual operating a vehicle, who may be at fault in an accident or be an uninsured/underinsured motorist, impacting insurance claims and coverages.</data>
  <data key="d2">1</data>
</node>
<node id="COLLISION WITH ANOTHER VEHICLE">
  <data key="d0">EVENT</data>
  <data key="d1">A specific incident where a covered vehicle makes impact with another vehicle, typically covered by collision insurance.</data>
  <data key="d2">1</data>
</node>
<node id="COLLISION WITH AN OBJECT">
  <data key="d0">EVENT</data>
  <data key="d1">A specific incident where a covered vehicle makes impact with an inanimate object, typically covered by collision insurance.</data>
  <data key="d2">1</data>
</node>
<node id="AUTO LIABILITY INSURANCE">
  <data key="d0">FINANCIAL_PRODUCT</data>
  <data key="d1">Auto liability insurance is a coverage type, often required in most states, that protects the insured if they are found to be at fault for an accident by helping to pay for damages to other people or their property.</data>
  <data key="d2">1</data>
</node>
<node id="PERSONAL INJURY PROTECTION (PIP)">
  <data key="d0">FINANCIAL_PRODUCT</data>
  <data key="d1">Personal Injury Protection (PIP) is a coverage type available in certain states that helps pay for reasonable and necessary medical expenses, rehabilitation, lost earnings, replacement of services, and funeral expenses for covered parties regardless of fault in an auto crash.</data>
  <data key="d2">1</data>
</node>
<node id="MEDICAL PAYMENTS COVERAGE (MPC)">
  <data key="d0">FINANCIAL_PRODUCT</data>
  <data key="d1">Medical Payments Coverage (MPC) is a coverage type available in many states that helps pay for necessary medical and funeral expenses for covered parties injured in an auto crash, regardless of fault.</data>
  <data key="d2">1</data>
</node>
<node id="COST TO REPAIR YOUR CAR">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">The cost to repair your car refers to the expenses incurred for fixing damage to a vehicle after a covered loss, with the deductible being the initial portion paid by the insured.</data>
  <data key="d2">1</data>
</node>
<node id="QUOTES">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">Quotes are estimated prices provided by insurance agents for different auto insurance policies, allowing individuals to compare costs based on various deductibles and coverage options.</data>
  <data key="d2">1</data>
</node>
<node id="PAIN AND SUFFERING">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">Pain and suffering refer to non-economic damages, such as physical discomfort and emotional distress, resulting from an injury caused by an accident, often covered under Bodily Injury Liability.</data>
  <data key="d2">1</data>
</node>
<node id="SPECIAL DAMAGES">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">Special damages are specific, quantifiable financial losses resulting from an injury or accident, such as medical bills, lost wages, and property repair costs, covered by Bodily Injury Liability.</data>
  <data key="d2">1</data>
</node>
<node id="DAMAGED PROPERTY">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">Damaged property refers to physical assets, such as vehicles or buildings, that have sustained harm or destruction in an accident, with repair or replacement costs covered by Property Damage Liability.</data>
  <data key="d2">1</data>
</node>
<node id="LOSS OF USE">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">Loss of use refers to the inability to utilize a damaged vehicle or property, for which compensation may be provided under Property Damage Liability.</data>
  <data key="d2">1</data>
</node>
<node id="LEGAL DEFENSE AND COURT COSTS">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">Legal defense and court costs are expenses incurred for legal representation and judicial proceedings following an accident, which can be covered by liability insurance.</data>
  <data key="d2">1</data>
</node>
<node id="FUNERAL EXPENSES">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">Funeral expenses are costs associated with funeral services and burial, which can be covered by Personal Injury Protection or Medical Payments Coverage in the event of a fatality from an auto crash.</data>
  <data key="d2">1</data>
</node>
<node id="REHABILITATION COSTS">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">Rehabilitation costs are expenses for physical or occupational therapy and other recovery treatments needed after injuries sustained in an auto crash, covered by Personal Injury Protection.</data>
  <data key="d2">1</data>
</node>
<node id="REPLACEMENT OF SERVICES COSTS">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">Replacement of services costs are expenses for hiring help to perform tasks (e.g., childcare, household chores) that an injured person can no longer do themselves due to a disability from an auto crash, covered by Personal Injury Protection.</data>
  <data key="d2">1</data>
</node>
<node id="ELECTRONIC ERROR OR THEFT">
  <data key="d0">RISK</data>
  <data key="d1">The risk of funds being lost or compromised due to technical errors in electronic transactions or unauthorized access and stealing of funds.</data>
  <data key="d2">1</data>
</node>
<node id="THIRD-PARTY">
  <data key="d0">ORGANIZATION</data>
  <data key="d1">A general term referring to other organizations or individuals that offer resources, content, products, or services, sometimes referenced by the CFPB without endorsement.</data>
  <data key="d2">1</data>
</node>
<node id="SUED ON A DEBT">
  <data key="d0">EVENT</data>
  <data key="d1">A legal action initiated by a creditor or debt collector against a debtor to recover an unpaid debt, requiring a formal response from the consumer.</data>
  <data key="d2">1</data>
</node>
<node id="COURT ISSUES JUDGMENT">
  <data key="d0">EVENT</data>
  <data key="d1">The formal decision or order handed down by a court in a legal case, which can be a money judgment against a debtor if they fail to respond to a lawsuit.</data>
  <data key="d2">1</data>
</node>
<node id="SAMPLE LETTERS">
  <data key="d0">FINANCIAL_PRODUCT</data>
  <data key="d1">Pre-written letter templates provided by the CFPB that consumers can use to communicate with debt collectors regarding disputes or information requests.</data>
  <data key="d2">1</data>
</node>
<node id="STATUTE OF LIMITATIONS ON DEBT">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">A legal time limit after which a creditor or debt collector can no longer initiate legal action to collect a specific debt.</data>
  <data key="d2">1</data>
</node>
<node id="OBSCENE LANGUAGE">
  <data key="d0">RISK</data>
  <data key="d1">Indecent or offensive language used by debt collectors, which is explicitly stated as a violation of the law.</data>
  <data key="d2">1</data>
</node>
<node id="FALSE OR MISLEADING STATEMENT">
  <data key="d0">RISK</data>
  <data key="d1">Untrue or deceptive claims made by a debt collector, particularly regarding what a consumer owes, which is a violation of law.</data>
  <data key="d2">1</data>
</node>
<node id="PUBLISHING NAME FOR NOT PAYING DEBT">
  <data key="d0">RISK</data>
  <data key="d1">The act of publicly disclosing a consumer's name for unpaid debts, which may be an illegal debt collection practice.</data>
  <data key="d2">1</data>
</node>
<node id="BEING LIED TO">
  <data key="d0">RISK</data>
  <data key="d1">Experiencing deception or untruthful statements from a debt collector, which is considered a violation of the law.</data>
  <data key="d2">1</data>
</node>
<node id="VIOLATING THE LAW">
  <data key="d0">RISK</data>
  <data key="d1">When a debt collector's actions or practices contravene established legal statutes and regulations, exposing them to legal consequences.</data>
  <data key="d2">1</data>
</node>
<node id="LOSING ABILITY TO DISPUTE DEBT">
  <data key="d0">RISK</data>
  <data key="d1">The potential consequence of delaying a debt dispute, which may result in losing the legal right to challenge the debt, especially after a court judgment.</data>
  <data key="d2">1</data>
</node>
<node id="SETTLE WITH DEBT COLLECTOR">
  <data key="d0">ACTION</data>
  <data key="d1">The act of negotiating and agreeing to pay a lesser amount than the full debt owed to fully resolve the account, often by contacting the collector directly.</data>
  <data key="d2">1</data>
</node>
<node id="ENERGY COSTS">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">The expenses incurred for energy consumption, such as electricity or gas, which can be subject to assistance programs or level payment plans.</data>
  <data key="d2">1</data>
</node>
<node id="AUTOMATICALLY DEPOSIT">
  <data key="d0">ACTION</data>
  <data key="d1">A strategy involving setting up automatic transfers of funds into a savings account or savings wallet feature to save for future payments.</data>
  <data key="d2">1</data>
</node>
<node id="FILE YOUR TAXES">
  <data key="d0">ACTION</data>
  <data key="d1">The process of submitting a tax return to the relevant tax authority, typically the IRS, to report income and calculate tax liability.</data>
  <data key="d2">1</data>
</node>
<node id="LANDLORDS">
  <data key="d0">ORGANIZATION</data>
  <data key="d1">Individuals or organizations that rent out property and may use credit reports for tenant screening.</data>
  <data key="d2">1</data>
</node>
<node id="DISPUTE ERRORS">
  <data key="d0">ACTION</data>
  <data key="d1">The process of formally challenging and correcting inaccurate information found in a credit report or other financial document.</data>
  <data key="d2">1</data>
</node>
<node id="LAND">
  <data key="d0">FINANCIAL_PRODUCT</data>
  <data key="d1">Property consisting of ground, considered an asset</data>
  <data key="d2">1</data>
</node>
<node id="BUSINESS INVENTORY">
  <data key="d0">FINANCIAL_PRODUCT</data>
  <data key="d1">The goods and materials held by a business for sale or production, considered an asset</data>
  <data key="d2">1</data>
</node>
<node id="FINANCIAL SECURITY">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">A state of having a stable and protected financial foundation, which assets help people achieve</data>
  <data key="d2">1</data>
</node>
<node id="PERSONAL SAFETY NET">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">A financial reserve built week by week through a savings plan to protect against unexpected expenses and provide peace of mind</data>
  <data key="d2">1</data>
</node>
<node id="MISSED BILL PAYMENTS">
  <data key="d0">RISK</data>
  <data key="d1">The failure to pay bills by their due date, leading to consequences such as late fees and other costs associated with borrowing money to cover expenses</data>
  <data key="d2">1</data>
</node>
<node id="ALLEN">
  <data key="d0">GEO</data>
  <data key="d1">A city in Texas, U.S., where Experian's P.O. Box for dispute mail is located.</data>
  <data key="d2">1</data>
</node>
<node id="CHESTER">
  <data key="d0">GEO</data>
  <data key="d1">A city in Pennsylvania, U.S., where TransUnion Consumer Solutions' P.O. Box for dispute mail is located.</data>
  <data key="d2">1</data>
</node>
<node id="ADDITIONAL INSURANCE">
  <data key="d0">FINANCIAL_PRODUCT</data>
  <data key="d1">An add-on product that lenders may insist on or imply borrowers must buy, which gets incorporated into the loan amount and accrues interest.</data>
  <data key="d2">1</data>
</node>
<node id="UNNEEDED WARRANTIES">
  <data key="d0">FINANCIAL_PRODUCT</data>
  <data key="d1">An add-on product that lenders may insist on or imply borrowers must buy, which gets incorporated into the loan amount and accrues interest.</data>
  <data key="d2">1</data>
</node>
<node id="COMPLAINT PROCESS">
  <data key="d0">EVENT</data>
  <data key="d1">A structured, multi-step procedure followed by the CFPB to address consumer complaints, involving submission, review, routing, company response, publication, and consumer review.</data>
  <data key="d2">1</data>
</node>
<node id="CONSUMER COMPLAINT DATABASE">
  <data key="d0">FINANCIAL_PRODUCT</data>
  <data key="d1">A public database managed by the CFPB that publishes anonymized information about consumer complaints, including the subject and date.</data>
  <data key="d2">1</data>
</node>
<node id="YOUR MONEY, YOUR GOALS: A FINANCIAL EMPOWERMENT TOOLKIT">
  <data key="d0">FINANCIAL_PRODUCT</data>
  <data key="d1">An educational resource prepared by the CFPB to empower the public with financial knowledge and tools.</data>
  <data key="d2">1</data>
</node>
<node id="FINANCIAL COMPANIES">
  <data key="d0">ORGANIZATION</data>
  <data key="d1">General term for companies offering financial products and services that are subject to consumer complaints handled by the CFPB.</data>
  <data key="d2">1</data>
</node>
