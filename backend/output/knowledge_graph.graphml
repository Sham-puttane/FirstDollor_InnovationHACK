</node>
<node id="DRESS FOR SUCCESS FASHION HOUSE">
  <data key="d0">ORGANIZATION</data>
  <data key="d1">A company located in Big City, WI, that received limited information about the Individual Consumer in July 2019 for a promotional offer of credit, categorized as a soft inquiry.</data>
  <data key="d2">1</data>
</node>
<node id="EZ LOAN STORE">
  <data key="d0">ORGANIZATION</data>
