  <data key="d2">2</data>
</node>
<node id="CHECKING IN">
  <data key="d0">ACTION</data>
  <data key="d1">The activity of regularly communicating with a friend or family member to maintain accountability for a goal.</data>
  <data key="d2">1</data>
</node>
