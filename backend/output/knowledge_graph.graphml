<node id="LARGE PERIODIC PAYMENTS">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">Significant financial outlays that occur at regular intervals, often targeted for adjustment to improve cash flow.</data>
  <data key="d2">1</data>
</node>
<node id="SMALLER PAYMENTS">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">Reduced financial outlays made more frequently over a period, often used as a strategy to manage large payments.</data>
  <data key="d2">1</data>
</node>
<node id="DUE DATES">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">The scheduled dates by which payments or obligations must be met, which can be negotiated to improve cash flow.</data>
  <data key="d2">1</data>
</node>
<node id="LOAN PAYMENTS">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">Scheduled payments made to repay a debt, including principal and interest, which are part of regular financial obligations.</data>
  <data key="d2">3</data>
</node>
<node id="ADJUSTING YOUR CASH FLOW TOOL">
  <data key="d0">FINANCIAL_PRODUCT</data>
  <data key="d1">A specific interactive tool used for setting new target spending levels and reorganizing the timing of expenses to optimize and improve weekly cash flow.</data>
  <data key="d2">3</data>
</node>
<node id="NEGOTIATE NEW DUE DATE">
  <data key="d0">ACTION</data>
  <data key="d1">A strategy to change the payment deadline for bills with a company to align better with income receipt.</data>
  <data key="d2">1</data>
</node>
<node id="SPLITTING LARGE MONTHLY PAYMENT">
  <data key="d0">ACTION</data>
  <data key="d1">A strategy to divide a significant monthly payment (e.g., rent) into two or more smaller payments due at different times.</data>
  <data key="d2">1</data>
</node>
<node id="CHANGE LUMP-SUM PAYMENTS">
  <data key="d0">ACTION</data>
  <data key="d1">A strategy to convert large, one-time payments (e.g., car insurance, school tuition) into smaller, more manageable monthly installments.</data>
  <data key="d2">1</data>
</node>
<node id="ENERGY ASSISTANCE PROGRAM">
  <data key="d0">ORGANIZATION</data>
  <data key="d1">A local or national program designed to help low-income families pay for part of their energy costs.</data>
  <data key="d2">1</data>
</node>
<node id="LIHEAP">
  <data key="d0">ORGANIZATION</data>
  <data key="d1">Low Income Home Energy Assistance Program, a federal program that helps low-income households with their energy bills.</data>
  <data key="d2">3</data>
</node>
<node id="LEVEL PAYMENT PLANS">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">A billing method for utility bills that averages annual use over 12 months, resulting in consistent monthly payments to avoid seasonal spikes.</data>
  <data key="d2">1</data>
</node>
<node id="WITHHOLDING ENOUGH TAX">
  <data key="d0">ACTION</data>
  <data key="d1">A strategy to ensure that the correct amount of income tax is deducted from paychecks to avoid underpayment or overpayment when filing taxes.</data>
  <data key="d2">1</data>
</node>
<node id="TAX ALLOWANCES">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">Also known as exemptions, these reduce the amount of income tax withheld from a paycheck, affecting tax obligations.</data>
  <data key="d2">1</data>
</node>
<node id="IRS WITHHOLDING CALCULATOR">
  <data key="d0">FINANCIAL_PRODUCT</data>
  <data key="d1">An online tool provided by the IRS to help individuals determine the correct amount of income tax to withhold from their paychecks.</data>
  <data key="d2">1</data>
</node>
<node id="MODULE 8: EVALUATING YOUR PREPAID OR PAYROLL CARD">
  <data key="d0">FINANCIAL_PRODUCT</data>
  <data key="d1">A specific section within the "Your Money, Your Goals Toolkit" focused on assessing prepaid and payroll cards.</data>
  <data key="d2">1</data>
</node>
<node id="LATE FEE">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">A penalty charged when a payment for a financial obligation, such as a credit card bill or loan installment, is not made by the due date.</data>
  <data key="d2">2</data>
</node>
<node id="PROMOTIONAL RATE">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">A temporary, lower interest rate offered for an initial period on financial products like credit cards, which will revert to a higher rate after the promotion ends.</data>
  <data key="d2">2</data>
</node>
<node id="PROMOTION">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">A special offer or limited-time arrangement, often involving a promotional rate, designed to attract customers to a financial product.</data>
  <data key="d2">1</data>
</node>
<node id="FOREIGN TRANSACTION FEES">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">Charges applied when a financial card is used for purchases or withdrawals in a country different from the issuer's or in a foreign currency.</data>
  <data key="d2">1</data>
</node>
<node id="COUNTRY">
  <data key="d0">GEO</data>
  <data key="d1">A sovereign state or nation, relevant in the context of international financial transactions and associated fees.</data>
  <data key="d2">1</data>
</node>
<node id="LIMITS ON USE">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">Restrictions or conditions placed on where, when, or how a financial card or service can be utilized.</data>
  <data key="d2">1</data>
</node>
<node id="BALANCE CHECKING SERVICES">
  <data key="d0">ACTION</data>
  <data key="d1">The functionality provided by financial institutions that allows users to inquire about and view their current account balance through various channels like phone, online, or mobile apps.</data>
  <data key="d2">1</data>
</node>
<node id="DUE DATE SELECTION">
  <data key="d0">ACTION</data>
  <data key="d1">The option for a customer to choose or modify the specific calendar date by which their recurring bill or loan payments are expected.</data>
  <data key="d2">1</data>
</node>
<node id="BILL">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">A statement detailing the amount of money owed for services or products, or a summary of financial account activity for a given period.</data>
  <data key="d2">3</data>
</node>
<node id="GETTING THE LOAN">
  <data key="d0">ACTION</data>
  <data key="d1">The complete process of applying for, undergoing approval, and successfully receiving funds from a loan.</data>
  <data key="d2">1</data>
</node>
<node id="LOAN APPROVAL PROCESS">
  <data key="d0">ACTION</data>
  <data key="d1">The series of steps a lender takes to evaluate a loan application and determine whether to grant the loan.</data>
  <data key="d2">1</data>
</node>
<node id="LOAN LENGTH">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">The specified duration or term over which a loan is structured to be repaid.</data>
  <data key="d2">1</data>
</node>
<node id="OWE MONEY">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">The financial state of having an outstanding debt or obligation that needs to be settled.</data>
  <data key="d2">1</data>
</node>
<node id="EXCHANGING CURRENCIES">
  <data key="d0">ACTION</data>
  <data key="d1">The act of converting funds from one national currency to another, typically for international transactions, often incurring fees.</data>
  <data key="d2">1</data>
</node>
<node id="RECEIVING FUNDS">
  <data key="d0">ACTION</data>
  <data key="d1">The act of a designated recipient obtaining the money that has been sent through a money transfer service.</data>
  <data key="d2">1</data>
</node>
<node id="FUNDS ARRIVAL SPEED">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">The time taken for money to be transferred and become available to the recipient, a key consideration for money transfer services.</data>
  <data key="d2">1</data>
</node>
<node id="MONTHLY FEES">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">A regular charge applied each month for maintaining a financial account or for specific services associated with it.</data>
  <data key="d2">1</data>
</node>
<node id="INACTIVITY FEE">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">A recurring charge applied to an account if the card has not been used for transactions over a specified period of time.</data>
  <data key="d2">2</data>
</node>
<node id="DORMANCY FEE">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">Another term for an inactivity fee, levied on accounts considered dormant due to a lack of activity.</data>
  <data key="d2">1</data>
</node>
<node id="PER-TRANSACTION FEES">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">Charges applied each time a specific transaction, such as a purchase or withdrawal, is made using a financial product.</data>
  <data key="d2">3</data>
</node>
<node id="SPENDING LIMITS">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">Maximum amounts that can be spent using a financial card or account within a specified timeframe, such as daily or per transaction.</data>
  <data key="d2">1</data>
</node>
<node id="WITHDRAWAL LIMITS">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">Maximum amounts that can be withdrawn from an account using a card or service within a specified period, typically daily.</data>
  <data key="d2">1</data>
</node>
<node id="TRANSACTION LIMITS">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">Maximum amounts allowed for a single financial transaction, whether for spending or withdrawal.</data>
  <data key="d2">1</data>
</node>
<node id="SECURITY">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">The measures and systems implemented to protect financial assets, personal data, and transactions from fraud, theft, and unauthorized access.</data>
  <data key="d2">1</data>
</node>
<node id="UNAUTHORIZED USE">
  <data key="d0">RISK</data>
  <data key="d1">The risk of a financial card or account being used by someone other than the rightful owner without their permission, potentially leading to financial loss.</data>
  <data key="d2">1</data>
</node>
<node id="GETTING MONEY BACK">
  <data key="d0">ACTION</data>
  <data key="d1">The process of recovering funds that have been lost due to unauthorized transactions, theft, or other financial irregularities.</data>
  <data key="d2">1</data>
</node>
<node id="FRIENDLINESS">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">A quality of customer service indicating a welcoming, polite, and helpful attitude from staff at financial institutions.</data>
  <data key="d2">1</data>
</node>
<node id="RESPECT">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">The courteous and considerate treatment customers expect to receive from financial service providers.</data>
  <data key="d2">1</data>
</node>
<node id="CONVENIENCE">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">The ease and practicality of accessing and using financial services, often influenced by factors like physical location, operating hours, and digital accessibility.</data>
  <data key="d2">1</data>
</node>
<node id="LOCATIONS">
  <data key="d0">GEO</data>
  <data key="d1">Physical branches or offices of financial institutions where customers can conduct business.</data>
  <data key="d2">1</data>
</node>
<node id="LIVE">
  <data key="d0">GEO</data>
  <data key="d1">Referring to the geographical area where an individual resides, important for assessing the convenience of nearby financial institution locations.</data>
  <data key="d2">1</data>
</node>
<node id="WORK">
  <data key="d0">GEO</data>
  <data key="d1">Referring to the geographical area of an individual's employment, important for assessing the convenience of nearby financial institution locations.</data>
  <data key="d2">3</data>
</node>
<node id="SHOP">
  <data key="d0">GEO</data>
  <data key="d1">Referring to geographical areas where an individual performs shopping activities, important for assessing the convenience of nearby financial institution locations.</data>
  <data key="d2">1</data>
</node>
<node id="OPENING TIMES">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">The hours of operation for a financial institution or its branches, impacting customer access and convenience.</data>
  <data key="d2">1</data>
</node>
<node id="ACCESS">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">The ability to readily obtain information, assistance, or services from a financial institution.</data>
  <data key="d2">1</data>
</node>
<node id="INFORMATION ACCESSIBILITY">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">The ease with which financial information and disclosures can be understood and obtained by diverse users, including those needing specific languages or formats.</data>
  <data key="d2">1</data>
</node>
<node id="LANGUAGE SUPPORT">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">The availability of financial services, information, and customer support in multiple languages to cater to a diverse clientele.</data>
  <data key="d2">1</data>
</node>
<node id="CUSTOMER SUPPORT CHANNELS">
  <data key="d0">FINANCIAL_PRODUCT</data>
  <data key="d1">Various platforms and methods offered by financial institutions for customers to seek help or provide feedback, such as phone, text, email, or online chat.</data>
  <data key="d2">1</data>
</node>
<node id="TEXT">
  <data key="d0">ACTION</data>
  <data key="d1">The act of sending or receiving short written messages, often used as a method for customer support or account notifications by financial services.</data>
  <data key="d2">1</data>
</node>
<node id="ONLINE CHAT">
  <data key="d0">ACTION</data>
  <data key="d1">Real-time text-based communication conducted via a website or application, commonly offered by financial institutions for immediate customer support.</data>
  <data key="d2">1</data>
</node>
<node id="GETTING STARTED">
  <data key="d0">ACTION</data>
  <data key="d1">The initial phase or preparatory steps taken at the beginning of a process, such as setting up new financial accounts.</data>
  <data key="d2">2</data>
</node>
<node id="DOCUMENTS">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">Official papers, records, or forms required by financial institutions for identity verification, account opening, or transaction processing.</data>
  <data key="d2">1</data>
</node>
<node id="BILL WITH NAME AND ADDRESS">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">A utility bill or similar statement displaying a person's name and residential address, typically used as secondary identification or proof of residency for financial purposes.</data>
  <data key="d2">1</data>
</node>
<node id="GATHER DOCUMENTS">
  <data key="d0">ACTION</data>
  <data key="d1">The act of collecting all necessary papers and forms in preparation for a financial process, such as opening an account.</data>
  <data key="d2">1</data>
</node>
<node id="SAVE TIME">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">The benefit of reducing the duration or effort required for a task, often achieved through preparedness in financial activities.</data>
  <data key="d2">1</data>
</node>
<node id="SAVE MONEY">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">The benefit of reducing financial expenditure or increasing financial assets, often resulting from informed choices and preparation in financial matters.</data>
  <data key="d2">2</data>
</node>
<node id="CREDIT SCORING FORMULAS">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">The methodologies and calculations used by credit reporting companies to determine a consumer's credit score, often penalizing high credit utilization.</data>
  <data key="d2">1</data>
</node>
<node id="HIGH USAGE">
  <data key="d0">RISK</data>
  <data key="d1">The potential negative impact on a credit score resulting from utilizing a large percentage of available credit, which is linked to a high credit utilization rate.</data>
  <data key="d2">1</data>
</node>
<node id="SCORING MODEL">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">The specific algorithm or methodology employed by credit reporting companies to calculate a consumer's credit score, which assesses credit utilization rates.</data>
  <data key="d2">1</data>
</node>
<node id="RISK OF LOWERING YOUR CREDIT SCORES">
  <data key="d0">RISK</data>
  <data key="d1">The exposure to a reduction in one's credit scores due to certain financial behaviors, such as maintaining a high credit utilization rate.</data>
  <data key="d2">1</data>
</node>
<node id="EXPANDING ACCESS TO CREDIT">
  <data key="d0">ACTION</data>
  <data key="d1">An initiative or strategy focused on increasing the availability of credit to a broader segment of the population, including those traditionally underserved like 'credit invisibles'.</data>
  <data key="d2">1</data>
</node>
<node id="CREDIT INVISIBLES">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">Individuals who lack sufficient credit history for credit reporting companies to generate a credit score for them, often facing barriers to credit, housing, and employment.</data>
  <data key="d2">1</data>
</node>
<node id="DENIED ACCESS TO CREDIT">
  <data key="d0">RISK</data>
  <data key="d1">The negative outcome where consumers are unable to secure credit products due to factors like insufficient credit history, commonly faced by 'credit invisibles'.</data>
  <data key="d2">1</data>
</node>
<node id="HIGHER COSTS FOR BORROWING MONEY">
  <data key="d0">RISK</data>
  <data key="d1">The financial disadvantage faced by consumers with limited or no credit history, resulting in increased interest rates or fees on loans due to perceived higher risk.</data>
  <data key="d2">1</data>
</node>
<node id="BARRIERS TO HOUSING AND EMPLOYMENT">
  <data key="d0">RISK</data>
  <data key="d1">Obstacles encountered by individuals with poor or limited credit history when attempting to rent housing or secure certain jobs, impacting 'credit invisibles'.</data>
  <data key="d2">1</data>
</node>
<node id="LIMITED CREDIT HISTORY">
  <data key="d0">RISK</data>
  <data key="d1">A situation where a consumer's credit file lacks enough information or activity to establish a robust credit profile, often leading to being "unscorable.</data>
  <data key="d2">1</data>
</node>
<node id="UNSCORABLE">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">A designation for a credit file that cannot generate a credit score due to insufficient (thin) or stale data, impacting individuals with limited credit history.</data>
  <data key="d2">1</data>
</node>
<node id="THIN CREDIT FILE">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">A credit file characterized by a limited number of credit accounts or a short credit history, making it difficult for credit reporting companies to generate a score.</data>
  <data key="d2">1</data>
</node>
<node id="STALE CREDIT FILE">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">A credit file that contains no recent credit account activity, making it less relevant for current credit scoring and potentially rendering a consumer "unscorable.</data>
  <data key="d2">1</data>
</node>
<node id="LOAN APPROVAL">
  <data key="d0">ACTION</data>
  <data key="d1">The act of a lender granting a loan application, signifying agreement to provide funds under specified terms, which credit reports can be used for.</data>
  <data key="d2">1</data>
</node>
<node id="YOUTH IN FOSTER CARE">
  <data key="d0">PERSON</data>
  <data key="d1">Young individuals who are placed in a foster family or facility, under the care of a state or private agency, with specific guidance available for their credit reports.</data>
  <data key="d2">2</data>
</node>
<node id="ACTION PLAN">
  <data key="d0">ACTION</data>
  <data key="d1">A structured outline of specific, actionable steps, necessary resources, and deadlines, designed to guide the accomplishment of a particular goal.</data>
  <data key="d2">4</data>
</node>
<node id="GOOD CREDIT">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">A positive financial status indicated by a strong credit history and high credit scores, which facilitates access to loans, housing, and other financial services.</data>
  <data key="d2">1</data>
</node>
<node id="BAD CREDIT">
  <data key="d0">RISK</data>
  <data key="d1">A negative financial status characterized by a problematic credit history and low credit scores, which creates obstacles to obtaining loans, housing, and other services.</data>
  <data key="d2">1</data>
</node>
<node id="BILL PAYMENT HISTORY">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">A record of an individual's past performance in paying bills on time, which is a key component reported in credit reports and influences credit scores.</data>
  <data key="d2">1</data>
</node>
<node id="PUBLIC RECORD INFORMATION">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">Data from public sources, such as bankruptcies or tax liens, that may be included in an individual's credit report and affect their creditworthiness.</data>
  <data key="d2">2</data>
</node>
<node id="AVAILABLE CREDIT">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">The total amount of credit an individual has access to across all their credit accounts, indicating their borrowing capacity.</data>
  <data key="d2">2</data>
</node>
<node id="MILITARY POSITION">
  <data key="d0">FINANCIAL_PRODUCT</data>
  <data key="d1">A role or employment within the armed forces, often requiring a security clearance which can be affected by an individual's credit history.</data>
  <data key="d2">1</data>
</node>
<node id="GOOD CREDIT HISTORY">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">A history of responsible borrowing and timely repayment, which is reflected in positive credit reports and high credit scores.</data>
  <data key="d2">1</data>
</node>
<node id="CREATING A POSITIVE CREDIT HISTORY">
  <data key="d0">ACTION</data>
  <data key="d1">The deliberate process of establishing a favorable record of borrowing and repayment, often through responsible financial behaviors.</data>
  <data key="d2">1</data>
</node>
<node id="BOOSTING CREDIT SCORES">
  <data key="d0">ACTION</data>
  <data key="d1">The act of improving an individual's credit scores through various financial management strategies, primarily by demonstrating responsible credit behavior.</data>
  <data key="d2">1</data>
</node>
<node id="CREDIT MONITORING">
  <data key="d0">FINANCIAL_PRODUCT</data>
  <data key="d1">A service designed to track changes and activity on a credit report, often offered by companies, though consumers can self-monitor by checking reports annually.</data>
  <data key="d2">2</data>
</node>
<node id="BORROWING">
  <data key="d0">ACTION</data>
  <data key="d1">The act of obtaining money or resources with the intention of returning them, typically with interest, which is influenced by one's credit report and score.</data>
  <data key="d2">6</data>
</node>
<node id="GETTING CREDIT">
  <data key="d0">ACTION</data>
  <data key="d1">The process of successfully applying for and receiving financial credit, such as a loan or credit card, often contingent on a positive credit history.</data>
  <data key="d2">2</data>
</node>
<node id="INCORRECT ACCOUNT STATUS">
  <data key="d0">RISK</data>
  <data key="d1">A specific type of inaccurate information on a credit report where the current state of a financial account (e.g., open, closed, delinquent) is wrongly presented.</data>
  <data key="d2">3</data>
</node>
<node id="INCORRECT DATES OF DELINQUENCY">
  <data key="d0">RISK</data>
  <data key="d1">A type of error on a credit report where the dates associated with a past-due account are inaccurately recorded.</data>
  <data key="d2">2</data>
</node>
<node id="WRONGLY LISTED LATE ACCOUNTS">
  <data key="d0">RISK</data>
  <data key="d1">An error on a credit report where an account is mistakenly indicated as having late payments.</data>
  <data key="d2">2</data>
</node>
<node id="INCORRECT BALANCES">
  <data key="d0">RISK</data>
  <data key="d1">An error on a credit report where the outstanding amount owed on a credit account is incorrectly stated.</data>
  <data key="d2">2</data>
</node>
<node id="INCORRECT CREDIT LIMITS">
  <data key="d0">RISK</data>
  <data key="d1">An error on a credit report where the maximum credit available on an account is inaccurately specified.</data>
  <data key="d2">2</data>
</node>
<node id="CLOSED ACCOUNTS LISTED AS OPEN">
  <data key="d0">RISK</data>
  <data key="d1">An error on a credit report where an account that has been formally closed by the consumer is still incorrectly reported as active.</data>
  <data key="d2">2</data>
</node>
<node id="DUPLICATE ACCOUNT LISTINGS">
  <data key="d0">RISK</data>
  <data key="d1">An error on a credit report where the same credit account is listed multiple times by creditors.</data>
