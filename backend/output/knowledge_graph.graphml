  <data key="d2">1</data>
</node>
<node id="AGE TO GET LIFE INSURANCE">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">The optimal or recommended age at which an individual should purchase life insurance.</data>
  <data key="d2">1</data>
</node>
<node id="LIFE INSURANCE NEEDS CALCULATOR">
  <data key="d0">FINANCIAL_CONCEPT</data>
