</edge>
<edge source="CONSUMER LOANS" target="DEPOSIT ADVANCE PRODUCTS">
  <data key="d3">9.0</data>
  <data key="d4">Deposit advance products are a type of consumer loan.</data>
</edge>
<edge source="CONSUMER LOANS" target="OVERDRAFT LINES OF CREDIT">
