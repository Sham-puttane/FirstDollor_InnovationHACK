  <data key="d2">2</data>
</node>
<node id="SAVINGS JAR">
  <data key="d0">FINANCIAL_PRODUCT</data>
  <data key="d1">A physical container used at home to store cash savings temporarily.</data>
  <data key="d2">2</data>
</node>
<node id="ENVELOPE (FOR SAVINGS)">
  <data key="d0">FINANCIAL_PRODUCT</data>
  <data key="d1">A physical container used at home to store cash savings temporarily.</data>
  <data key="d2">2</data>
</node>
