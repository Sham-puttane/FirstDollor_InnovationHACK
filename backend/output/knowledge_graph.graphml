  <data key="d2">1</data>
</node>
<node id="TERM LIFE INSURANCE POLICY">
  <data key="d0">FINANCIAL_PRODUCT</data>
  <data key="d1">A type of life insurance that provides coverage for a specific period (term) and pays a death benefit if the insured dies during that term.</data>
  <data key="d2">1</data>
</node>
<node id="LIFE INSURANCE COVERAGE">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">The amount of financial protection provided by a life insurance policy.</data>
  <data key="d2">1</data>
</node>
<node id="AGE">
  <data key="d0">RISK</data>
  <data key="d1">A personal demographic factor used in insurance calculations, often correlating with driving experience and accident likelihood, impacting premiums.</data>
  <data key="d2">2</data>
</node>
<node id="COST OF HAVING LIFE INSURANCE">
  <data key="d0">FINANCIAL_CONCEPT</data>
