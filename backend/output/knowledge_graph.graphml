  <data key="d2">1</data>
</node>
<node id="CURRENT INCOME">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">The present earnings of an individual.</data>
  <data key="d2">1</data>
</node>
<node id="GOOD DEBT">
  <data key="d0">FINANCIAL_CONCEPT</data>
  <data key="d1">A financial concept referring to debt that helps individuals reach goals or build assets, such as borrowing for education, a reliable car, or a home.</data>
  <data key="d2">1</data>
</node>
<node id="REPOSSESS (REPO)">
  <data key="d0">ACTION</data>
