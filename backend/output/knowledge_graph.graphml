  <data key="d2">1</data>
</node>
<node id="FICO">
  <data key="d0">ORGANIZATION</data>
  <data key="d1">A widely recognized brand of credit score produced by Fair Isaac Corporation, whose calculation considers payment history, amounts owed, length of credit history, new credit, and types of credit used.</data>
  <data key="d2">2</data>
</node>
<node id="FAIR ISAAC CORPORATION">
  <data key="d0">ORGANIZATION</data>
  <data key="d1">The full name for FICO, a company that develops and publishes commonly used credit scores.</data>
  <data key="d2">2</data>
</node>
<node id="VANTAGESCORE">
  <data key="d0">ORGANIZATION</data>
  <data key="d1">A credit score developed by VantageScore Solutions, influenced by factors such as payment history, age and type of credit, and percent of credit limit used.</data>
  <data key="d2">2</data>
</node>
<node id="VANTAGESCORE SOLUTIONS">
  <data key="d0">ORGANIZATION</data>
  <data key="d1">The full name for VantageScore, a company that develops and publishes credit scores.</data>
  <data key="d2">2</data>
</node>
<node id="INFORMATION FURNISHER">
  <data key="d0">ORGANIZATION</data>
