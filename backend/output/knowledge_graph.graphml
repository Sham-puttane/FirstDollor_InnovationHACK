  <data key="d2">1</data>
</node>
<node id="WORKFORCE DEVELOPMENT PROGRAMS">
  <data key="d0">ORGANIZATION</data>
  <data key="d1">Workforce development programs provide skills training to help individuals prepare for new job opportunities.</data>
  <data key="d2">1</data>
</node>
<node id="CAREER-TECHNICAL SCHOOLS">
  <data key="d0">ORGANIZATION</data>
  <data key="d1">Career-technical schools are educational institutions that offer specialized training for specific trades and careers.</data>
  <data key="d2">1</data>
</node>
<node id="UNIVERSITIES">
  <data key="d0">ORGANIZATION</data>
  <data key="d1">Universities are institutions of higher education that offer a wide range of academic degrees and professional qualifications.</data>
  <data key="d2">1</data>
</node>
<node id="UNIONS">
  <data key="d0">ORGANIZATION</data>
