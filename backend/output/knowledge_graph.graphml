  <data key="d2">2</data>
</node>
<node id="&quot;BUREAU OF THE FISCAL SERVICE&quot;">
  <data key="d0">"ORGANIZATION"</data>
  <data key="d1">"A bureau within the U.S. Department of the Treasury responsible for managing federal finances and operating programs such as Go Direct.</data>
  <data key="d2">2</data>
</node>
<node id="&quot;MEDICAL INFORMATION&quot;">
  <data key="d0">"FINANCIAL_CONCEPT"</data>
